---
/*
  SiteNav — JEDNA wspolna nawigacja dla calej strony (pasek + drawer z boku + Start).
  Celowo NIE zarzadza i18n ani motywem: linki maja PODWOJNE atrybuty
  (data-i18n="nav.x"  ORAZ  data-pl/-de/-en), a przelacznik jezyka ma id="lang"
  + data-i18n-toggle. Dzieki temu istniejacy skrypt KAZDEJ strony (Chrome client-i18n,
  zywy/home applyLang, pracownia DLi18n) tlumaczy te elementy SWOIM mechanizmem,
  bez zadnych zmian w logice canvas/iframe. Komponent obsluguje tylko drawer + cien paska.

  Props:
    mode      'client' (data-i18n / data-pl) | 'routed' (tekst z serwera + linki sw)
    active    sciezka aktywnej zakladki, np. '/oferta/'
    lang      'pl'|'en'|'de'  (dla mode='routed' + poczatkowy stan przelacznika)
    sw        { pl, en, de }  (mode='routed' — linki przelacznika jezyka)
    overlay   true  -> przezroczysty pasek na pelnoekranowych stronach (zywy-algorytm)
    showTheme false -> ukryj przycisk motywu (pracownia nie ma trybu jasnego)
*/
const {
  mode = 'client',
  active = '',
  lang = 'pl',
  sw = null,
  overlay = false,
  showTheme = true,
} = Astro.props;

const routed = mode === 'routed';
const base = routed && lang !== 'pl' ? `/${lang}` : '';

// Podstrony sekcji Projekty — wysuwane z menu "Projekty"
const projects = [
  { href: '/gambit/',             pl: 'GAMBIT',     en: 'GAMBIT',     de: 'GAMBIT',     live: true },
  { href: '/zywy-algorytm/',      pl: 'Order Flow', en: 'Order Flow', de: 'Order Flow', live: true },
  { href: '/projekty/clawbot/',   pl: 'clawbot',    en: 'clawbot',    de: 'clawbot',    routed: true },
  { href: '/projekty/forex-lab/', pl: 'forex-lab',  en: 'forex-lab',  de: 'forex-lab',  routed: true },
  { href: '/projekty/aai/',       pl: 'AAI',        en: 'AAI',        de: 'AAI',        routed: true },
  { href: '/projekty/mocps/',     pl: 'MOCPS',      en: 'MOCPS',      de: 'MOCPS',      routed: true },
];
const items = [
  { href: '/',               key: 'nav.home',      pl: 'Start',         en: 'Home',             de: 'Start' },
  { href: '/o-mnie/',        key: 'nav.about',     pl: 'O mnie',        en: 'About',            de: 'Über mich' },
  { href: '/oferta/',        key: 'nav.work',      pl: 'Oferta',        en: 'Services',         de: 'Leistungen' },
  { href: '/pracownia/',     key: 'nav.pracownia', pl: 'Pracownia',     en: 'Workshop',         de: 'Werkstatt' },
  { href: '/projekty/',      key: 'nav.projects',  pl: 'Projekty',      en: 'Projects',         de: 'Projekte', dd: projects },
  { href: '/blog/',          key: 'nav.blog',      pl: 'Blog',          en: 'Blog',             de: 'Blog' },
  { href: '/#kontakt',       key: 'nav.contact',   pl: 'Kontakt',       en: 'Contact',          de: 'Kontakt' },
];
// W trybie routed projekty/blog maja warianty jezykowe (/en/blog/ itd.)
const hrefOf = (it) =>
  routed && (it.href === '/projekty/' || it.href === '/blog/') ? base + it.href : it.href;
// Podstrony content-collection (clawbot itd.) maja warianty jezykowe; gambit/order-flow nie.
const projHref = (p) => (routed && p.routed && lang !== 'pl') ? `/${lang}${p.href}` : p.href;
const projText = (p) => (routed ? p[lang] : p.pl);
// Tekst poczatkowy: routed = z serwera; client = PL (skrypt strony nadpisze przy applyLang)
const textOf = (it) => (routed ? it[lang] : it.pl);
const langs = ['pl', 'en', 'de'];
---
<header id="snav" class="snav" data-mode={mode} data-variant={overlay ? 'overlay' : 'solid'}>
  <div class="snav-in">
    <a href="/" class="snav-brand" aria-label="D-LOGIC studio, strona główna">
      <span class="snav-glyph">◢</span>D&#8209;<b>LOGIC</b>&nbsp;<span class="snav-dim">studio</span>
    </a>

    <nav class="snav-links" aria-label="Główna nawigacja">
      {items.map((it) => it.dd ? (
        <div class="snav-dd">
          <a
            href={hrefOf(it)}
            class={`snav-dd-trig${active === it.href || it.dd.some((p) => p.href === active) ? ' snav-on' : ''}`}
            data-i18n={it.key} data-pl={it.pl} data-en={it.en} data-de={it.de}
          >{textOf(it)}<span class="snav-caret" aria-hidden="true">▾</span></a>
          <div class="snav-dd-menu">
            {it.dd.map((p) => (
              <a href={projHref(p)} class={`snav-dd-item${active === p.href ? ' snav-on' : ''}`} data-pl={p.pl} data-en={p.en} data-de={p.de}>
                <span>{projText(p)}</span>{p.live && <span class="snav-live" aria-hidden="true">●</span>}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a
          href={hrefOf(it)}
          class={active === it.href ? 'snav-on' : ''}
          aria-current={active === it.href ? 'page' : undefined}
          data-i18n={it.key}
          data-pl={it.pl}
          data-en={it.en}
          data-de={it.de}
        >{textOf(it)}</a>
      ))}
    </nav>

    <div class="snav-tools">
      <div class="snav-seg" id="lang" data-i18n-toggle aria-label="Język / Language / Sprache">
        {routed
          ? langs.map((l) => <a href={sw ? sw[l] : '/'} data-lang={l} class={lang === l ? 'on' : ''}>{l.toUpperCase()}</a>)
          : langs.map((l) => <button type="button" data-lang={l} class={lang === l ? 'on' : ''}>{l.toUpperCase()}</button>)}
      </div>
      {showTheme && (
        <button class="snav-icon" id="theme" type="button" aria-label="Motyw / Theme">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
        </button>
      )}
      <button class="snav-icon snav-hamb" id="snav-hamb" type="button" aria-label="Menu" aria-expanded="false" aria-controls="snav-drawer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

<div class="snav-drawer" id="snav-drawer" role="dialog" aria-modal="true" aria-label="Menu">
  <div class="snav-drawer-bg" data-snav-close></div>
  <div class="snav-drawer-panel">
    <div class="snav-drawer-head">
      <span class="snav-mono">menu</span>
      <button class="snav-icon" type="button" data-snav-close aria-label="Zamknij / Close">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
    {items.map((it) => it.dd ? (
      <div class={`snav-dl-group${it.dd.some((p) => p.href === active) ? ' open' : ''}`}>
        <div class="snav-dl-row">
          <a href={hrefOf(it)} class={`snav-dl${active === it.href ? ' snav-on' : ''}`} data-i18n={it.key} data-pl={it.pl} data-en={it.en} data-de={it.de}>{textOf(it)}</a>
          <button type="button" class="snav-dl-toggle" aria-label="Rozwiń / zwiń projekty" aria-expanded="false"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button>
        </div>
        <div class="snav-dl-subwrap"><div class="snav-dl-subinner">
          {it.dd.map((p) => (
            <a href={projHref(p)} class={`snav-dl snav-dl-sub${active === p.href ? ' snav-on' : ''}`} data-pl={p.pl} data-en={p.en} data-de={p.de}><span>{projText(p)}</span>{p.live && <span class="snav-live" aria-hidden="true">●</span>}</a>
          ))}
        </div></div>
      </div>
    ) : (
      <a
        href={hrefOf(it)}
        class={`snav-dl${active === it.href ? ' snav-on' : ''}`}
        data-i18n={it.key}
        data-pl={it.pl}
        data-en={it.en}
        data-de={it.de}
      >{textOf(it)}</a>
    ))}
  </div>
</div>

<style>
  .snav {
    position: sticky; top: 0; z-index: 100;
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    background: color-mix(in srgb, var(--bg, #0C0E12) 76%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color .3s, background .5s;
  }
  .snav.snav--scrolled { border-bottom-color: var(--line, rgba(231,233,236,.14)); }
  /* wariant pelnoekranowy (zywy-algorytm): przezroczysty pasek nad canvasem */
  .snav[data-variant="overlay"] { position: fixed; left: 0; right: 0; background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; }
  .snav[data-variant="overlay"].snav--scrolled { background: color-mix(in srgb, var(--bg, #06070A) 55%, transparent); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }

  .snav-in {
    display: flex; align-items: center; justify-content: space-between; gap: 18px;
    max-width: 1300px; margin: 0 auto; padding: 15px clamp(18px, 4vw, 40px);
  }
  .snav-brand {
    display: inline-flex; align-items: center; white-space: nowrap;
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-weight: 600; font-size: 15px; letter-spacing: .03em;
    color: var(--text, var(--bone, #E7E9EC)); text-decoration: none;
  }
  .snav-glyph { color: var(--accent, #E8B23A); margin-right: 9px; font-size: 13px; }
  .snav-brand b { color: var(--accent, #E8B23A); font-weight: 600; }
  .snav-dim { color: var(--muted, var(--bone-soft, #9AA1AB)); font-weight: 400; }

  .snav-links { display: flex; align-items: center; gap: clamp(14px, 1.7vw, 26px); }
  .snav-links a {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 13px; letter-spacing: .03em; color: var(--muted, var(--bone-soft, #9AA1AB));
    text-decoration: none; position: relative; padding: 4px 0; transition: color .2s; white-space: nowrap;
  }
  .snav-links a::after {
    content: ""; position: absolute; left: 0; bottom: -2px; width: 0; height: 1.5px;
    background: var(--accent, #E8B23A); transition: width .28s ease;
  }
  .snav-links a:hover { color: var(--text, var(--bone, #E7E9EC)); }
  .snav-links a:hover::after { width: 100%; }
  .snav-links a.snav-on { color: var(--accent, #E8B23A); }
  .snav-links a.snav-on::after { width: 100%; }

  /* ---- dropdown Projekty ---- */
  .snav-dd { position: relative; display: flex; align-items: center; }
  .snav-caret { font-size: 9px; margin-left: 5px; opacity: .6; transition: transform .25s; display: inline-block; }
  .snav-dd:hover .snav-caret { transform: rotate(180deg); opacity: 1; }
  .snav-dd::after { content: ""; position: absolute; top: 100%; left: -10px; right: -10px; height: 16px; } /* most hover */
  .snav-dd-menu {
    position: absolute; top: calc(100% + 11px); left: 50%; transform: translateX(-50%) translateY(7px);
    min-width: 184px; padding: 7px; border-radius: 13px; z-index: 110;
    background: var(--surface, var(--bg-2, #14161A)); border: 1px solid var(--line, rgba(231,233,236,.14));
    box-shadow: 0 20px 44px -18px rgba(0,0,0,.65);
    display: flex; flex-direction: column; gap: 1px;
    opacity: 0; visibility: hidden; transition: opacity .22s ease, transform .22s ease;
  }
  .snav-dd:hover .snav-dd-menu, .snav-dd:focus-within .snav-dd-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .snav-dd-item {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace; font-size: 12.5px;
    color: var(--muted, #9AA1AB); text-decoration: none; padding: 9px 11px; border-radius: 8px;
    white-space: nowrap; transition: background .18s, color .18s;
  }
  .snav-dd-item::after { display: none !important; }
  .snav-dd-item:hover { background: var(--surface-2, rgba(231,233,236,.06)); color: var(--text, #E7E9EC); }
  .snav-dd-item.snav-on { color: var(--accent, #E8B23A); }
  .snav-live { color: var(--live, #4ADE80); font-size: 8px; line-height: 1; }
  /* drawer: akordeon "Projekty" */
  .snav-dl-group { display: flex; flex-direction: column; }
  .snav-dl-row { display: flex; align-items: center; border-bottom: 1px solid var(--line, rgba(231,233,236,.12)); }
  .snav-dl-row .snav-dl { flex: 1; border-bottom: none; }
  .snav-dl-toggle { width: 44px; height: 48px; flex: none; display: grid; place-items: center; color: var(--muted, #9AA1AB); transition: transform .28s ease, color .2s; background: none; border: none; cursor: pointer; }
  .snav-dl-group.open .snav-dl-toggle { transform: rotate(180deg); color: var(--accent, #E8B23A); }
  .snav-dl-subwrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .32s cubic-bezier(.2,.7,.3,1); }
  .snav-dl-group.open .snav-dl-subwrap { grid-template-rows: 1fr; }
  .snav-dl-subinner { overflow: hidden; min-height: 0; }
  .snav-dl-sub { font-size: 16px; padding: 11px 2px 11px 18px; color: var(--muted, #9AA1AB); border-bottom: 1px solid var(--line, rgba(231,233,236,.08)); display: flex; align-items: center; justify-content: space-between; }
  .snav-dl-sub:hover { padding-left: 24px; color: var(--text, var(--bone, #E7E9EC)); }

  .snav-tools { display: flex; align-items: center; gap: 8px; }
  .snav-seg {
    display: flex; gap: 2px; padding: 3px; border-radius: 9px;
    background: var(--surface-2, var(--panel, rgba(231,233,236,.05)));
    border: 1px solid var(--line, rgba(231,233,236,.14));
  }
  .snav-seg button, .snav-seg a {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 11.5px; font-weight: 500; letter-spacing: .05em;
    padding: 6px 9px; border-radius: 6px; cursor: pointer; border: none; background: none;
    color: var(--muted, var(--bone-soft, #9AA1AB)); text-decoration: none; transition: .2s;
  }
  .snav-seg button.on, .snav-seg a.on, .snav-seg button.is-on, .snav-seg a.is-on {
    background: var(--accent, #E8B23A); color: #0C0E12; font-weight: 600;
  }
  .snav-seg button:not(.on):not(.is-on):hover, .snav-seg a:not(.on):not(.is-on):hover { color: var(--text, var(--bone, #E7E9EC)); }

  .snav-icon {
    width: 38px; height: 38px; flex: none; border-radius: 9px; cursor: pointer;
    border: 1px solid var(--line, rgba(231,233,236,.14));
    background: var(--surface-2, var(--panel, rgba(231,233,236,.05)));
    color: var(--muted, var(--bone-soft, #9AA1AB));
    display: flex; align-items: center; justify-content: center; transition: .2s;
  }
  .snav-icon:hover { color: var(--accent, #E8B23A); border-color: var(--chip-line, var(--accent, #E8B23A)); }
  .snav-icon svg { width: 17px; height: 17px; }
  .snav-hamb { display: none; }

  /* ---- drawer z boku ---- */
  .snav-drawer { position: fixed; inset: 0; z-index: 200; display: none; opacity: 0; transition: opacity .3s ease; }
  .snav-drawer.open { display: block; opacity: 1; }
  .snav-drawer-bg { position: absolute; inset: 0; background: rgba(0,0,0,.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .snav-drawer-panel {
    position: absolute; top: 0; right: 0; height: 100%; width: min(82vw, 340px);
    background: var(--surface, var(--bg-2, var(--panel, #14161A)));
    border-left: 1px solid var(--line, rgba(231,233,236,.14));
    padding: 22px; display: flex; flex-direction: column; gap: 4px; overflow-y: auto;
    transform: translateX(100%); transition: transform .34s cubic-bezier(.2,.7,.3,1);
  }
  .snav-drawer.open .snav-drawer-panel { transform: none; }
  .snav-drawer-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .snav-mono { font-family: 'JetBrains Mono Variable', ui-monospace, monospace; font-size: 12px; letter-spacing: .12em; color: var(--accent, #E8B23A); }
  .snav-dl {
    font-family: 'Space Grotesk Variable', system-ui, sans-serif; font-size: 21px; font-weight: 500;
    color: var(--text, var(--bone, #E7E9EC)); text-decoration: none; padding: 13px 2px;
    border-bottom: 1px solid var(--line, rgba(231,233,236,.12)); transition: color .2s, padding-left .2s;
  }
  .snav-dl:hover { color: var(--accent, #E8B23A); padding-left: 7px; }
  .snav-dl.snav-on { color: var(--accent, #E8B23A); }

  @media (max-width: 860px) {
    .snav-links { display: none; }
    .snav-hamb { display: flex; }
  }
  @media (max-width: 560px) {
    .snav-seg button, .snav-seg a { padding: 6px 7px; font-size: 11px; letter-spacing: 0; }
    .snav-tools { gap: 6px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .snav-drawer, .snav-drawer-panel, .snav-links a::after { transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var nav = document.getElementById('snav');
    var drawer = document.getElementById('snav-drawer');
    var hamb = document.getElementById('snav-hamb');
    if (hamb && drawer) {
      var open = function () { drawer.classList.add('open'); document.body.style.overflow = 'hidden'; hamb.setAttribute('aria-expanded', 'true'); };
      var close = function () { drawer.classList.remove('open'); document.body.style.overflow = ''; hamb.setAttribute('aria-expanded', 'false'); };
      hamb.addEventListener('click', open);
      drawer.querySelectorAll('[data-snav-close], .snav-dl').forEach(function (el) { el.addEventListener('click', close); });
      drawer.querySelectorAll('.snav-dl-toggle').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault(); e.stopPropagation();
          var grp = btn.closest('.snav-dl-group');
          if (grp) { var op = grp.classList.toggle('open'); btn.setAttribute('aria-expanded', op ? 'true' : 'false'); }
        });
      });
      window.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
    }
    if (nav) {
      var onScroll = function () { nav.classList.toggle('snav--scrolled', (window.scrollY || window.pageYOffset || 0) > 10); };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  })();
</script>
