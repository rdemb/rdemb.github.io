---
const { lang = 'pl' } = Astro.props;
const t = {
  pl: { uslugi: 'usługi', lab: 'lab', blog: 'blog', kontakt: 'kontakt' },
  en: { uslugi: 'services', lab: 'lab', blog: 'writing', kontakt: 'contact' },
  de: { uslugi: 'leistungen', lab: 'lab', blog: 'blog', kontakt: 'kontakt' },
}[lang] ?? {};
const base = lang === 'pl' ? '' : `/${lang}`;
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href={`${base}/`}>
      <span class="brand-mark">◢</span> D-LOGIC<span class="brand-dim">·STUDIO</span>
    </a>
    <nav class="nav-links">
      <a href={`${base}/uslugi/`}>{t.uslugi}</a>
      <a href={`${base}/lab/`}>{t.lab}</a>
      <a href={`${base}/blog/`}>{t.blog}</a>
      <a href={`${base}/kontakt/`}>{t.kontakt}</a>
      <span class="sep">/</span>
      <span class="lang">
        <a href="/" class={lang === 'pl' ? 'on' : ''}>pl</a>
        <a href="/en/" class={lang === 'en' ? 'on' : ''}>en</a>
        <a href="/de/" class={lang === 'de' ? 'on' : ''}>de</a>
      </span>
      <button id="theme-toggle" class="theme-toggle" aria-label="Przełącz motyw">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--line-soft);
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 14px 0; }
  .brand {
    font-family: var(--font-mono); font-weight: 600; font-size: 15px; letter-spacing: 0.02em;
    color: var(--text); display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;
  }
  .brand-mark { color: var(--accent); }
  .brand-dim { color: var(--faint); }
  .nav-links { display: flex; align-items: center; gap: 16px; font-family: var(--font-mono); font-size: 13.5px; }
  .nav-links > a { color: var(--muted); transition: color 200ms var(--ease); }
  .nav-links > a:hover { color: var(--text); }
  .sep { color: var(--line); }
  .lang { display: inline-flex; gap: 7px; }
  .lang a { color: var(--faint); }
  .lang a.on { color: var(--accent); }
  .theme-toggle {
    display: inline-grid; place-items: center; width: 32px; height: 32px;
    border: 1px solid var(--line); border-radius: 999px; background: var(--surface); color: var(--muted);
    cursor: pointer; transition: color 200ms var(--ease), border-color 200ms var(--ease), transform 200ms var(--ease);
  }
  .theme-toggle:hover { color: var(--accent); border-color: var(--faint); transform: translateY(-1px); }
  @media (max-width: 720px) {
    .nav-links > a:not(:first-child) { display: none; }
    .nav-links { gap: 12px; }
  }
</style>
