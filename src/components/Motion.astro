---
// Reusable premium motion layer for the standalone example pages.
// Lenis smooth scroll + reveal-on-scroll + safe parallax + magnetic buttons + custom cursor + count-up.
---
<div class="mcursor" id="mcursor" aria-hidden="true"></div>

<script>
  import Lenis from 'lenis';

  const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
  const fine = matchMedia('(pointer:fine)').matches;

  if (!reduce) {
    const lenis = new Lenis({ lerp: 0.085, wheelMultiplier: 1, smoothWheel: true });
    function raf(t: number) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // anchor links go through lenis
    document.querySelectorAll('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = (a as HTMLAnchorElement).getAttribute('href')!;
        if (id.length > 1) { const t = document.querySelector(id); if (t) { e.preventDefault(); lenis.scrollTo(t as HTMLElement, { offset: -10 }); } }
      });
    });

    // safe parallax (decorative elements only)
    const px = Array.from(document.querySelectorAll('[data-parallax]')) as HTMLElement[];
    if (px.length) lenis.on('scroll', ({ scroll }: any) => {
      for (const el of px) {
        const speed = parseFloat(el.dataset.parallax || '0.12');
        const r = el.getBoundingClientRect();
        const c = r.top + r.height / 2 - innerHeight / 2 + scroll - scroll;
        el.style.transform = `translate3d(0, ${(r.top + r.height / 2 - innerHeight / 2) * -speed}px, 0)`;
      }
    });

    // header shrink
    const hd = document.querySelector('header');
    if (hd) lenis.on('scroll', ({ scroll }: any) => hd.classList.toggle('scrolled', scroll > 24));
  }

  // reveal on scroll
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  }, { threshold: 0.12, rootMargin: '0px 0px -7% 0px' });
  document.querySelectorAll('[data-reveal]').forEach((el, i) => {
    (el as HTMLElement).style.setProperty('--ri', String(i % 5));
    io.observe(el);
  });

  // hero intro
  requestAnimationFrame(() => requestAnimationFrame(() => document.body.classList.add('ready')));

  // count up
  document.querySelectorAll('[data-count]').forEach((el) => {
    const target = parseFloat((el as HTMLElement).dataset.count || '0');
    const ob = new IntersectionObserver((ents) => {
      for (const e of ents) if (e.isIntersecting) {
        ob.disconnect();
        const dur = 1500, t0 = performance.now();
        const tick = (t: number) => { const k = Math.min((t - t0) / dur, 1); (el as HTMLElement).textContent = String(Math.round(target * (1 - Math.pow(1 - k, 3)))); if (k < 1) requestAnimationFrame(tick); };
        requestAnimationFrame(tick);
      }
    }, { threshold: 0.6 });
    ob.observe(el);
  });

  if (fine && !reduce) {
    // magnetic
    document.querySelectorAll('[data-magnetic]').forEach((el) => {
      const b = el as HTMLElement;
      b.addEventListener('pointermove', (e) => {
        const r = b.getBoundingClientRect();
        b.style.transform = `translate(${((e as PointerEvent).clientX - r.left - r.width / 2) * 0.25}px, ${((e as PointerEvent).clientY - r.top - r.height / 2) * 0.4}px)`;
      });
      b.addEventListener('pointerleave', () => { b.style.transform = ''; });
    });
    // custom cursor
    const cur = document.getElementById('mcursor')!;
    let cx = innerWidth / 2, cy = innerHeight / 2, tx = cx, ty = cy;
    addEventListener('pointermove', (e) => { tx = (e as PointerEvent).clientX; ty = (e as PointerEvent).clientY; });
    const loop = () => { cx += (tx - cx) * 0.2; cy += (ty - cy) * 0.2; cur.style.transform = `translate(${cx}px, ${cy}px)`; requestAnimationFrame(loop); };
    loop();
    document.querySelectorAll('a, button, [data-magnetic], input').forEach((el) => {
      el.addEventListener('pointerenter', () => cur.classList.add('on'));
      el.addEventListener('pointerleave', () => cur.classList.remove('on'));
    });
  }
</script>

<style is:global>
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }

  [data-reveal] { opacity: 0; transform: translateY(28px); transition: opacity .85s cubic-bezier(.22,1,.36,1), transform .85s cubic-bezier(.22,1,.36,1); transition-delay: calc(var(--ri,0) * .08s); will-change: opacity, transform; }
  [data-reveal].in { opacity: 1; transform: none; }
  [data-reveal="img"] { overflow: hidden; }
  [data-reveal="img"] > img { transform: scale(1.16); transition: transform 1.25s cubic-bezier(.22,1,.36,1); }
  [data-reveal="img"].in > img { transform: scale(1); }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { opacity: 1 !important; transform: none !important; } [data-reveal="img"] > img { transform: none !important; } }

  .kenburns { overflow: hidden; }
  .kenburns > img { animation: kb 24s ease-in-out infinite alternate; }
  @keyframes kb { from { transform: scale(1.02) translate(0,0); } to { transform: scale(1.14) translate(-2%, -2%); } }

  .marquee { overflow: hidden; white-space: nowrap; }
  .marquee-in { display: inline-flex; will-change: transform; animation: mq 28s linear infinite; }
  .marquee:hover .marquee-in { animation-play-state: paused; }
  @keyframes mq { to { transform: translateX(-50%); } }

  [data-hero] { opacity: 0; transform: translateY(22px); transition: opacity .95s cubic-bezier(.22,1,.36,1), transform .95s cubic-bezier(.22,1,.36,1); transition-delay: calc(.12s + var(--hi,0) * .13s); }
  body.ready [data-hero] { opacity: 1; transform: none; }

  .mcursor { position: fixed; top: 0; left: 0; width: 32px; height: 32px; margin: -16px 0 0 -16px; border: 1.5px solid #fff; border-radius: 50%; pointer-events: none; z-index: 9999; mix-blend-mode: difference; opacity: 0; transition: width .25s, height .25s, margin .25s, opacity .3s, background .25s; }
  body.ready .mcursor { opacity: .65; }
  .mcursor.on { width: 56px; height: 56px; margin: -28px 0 0 -28px; opacity: .9; }
  @media (pointer: coarse) { .mcursor { display: none; } }
</style>
