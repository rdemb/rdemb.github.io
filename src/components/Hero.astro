---
const { lang = 'pl' } = Astro.props;
const c = {
  pl: {
    eye: 'D-LOGIC STUDIO · narzędzia AI · web · dane',
    h1a: 'Buduję narzędzia AI, które',
    h1b: 'naprawdę działają.',
    sub: 'I jestem uczciwy co do tego, czego nie potrafią. Testuję je jak własne strategie tradingowe — baseline, koszt, wynik out-of-sample. Najpierw na sobie, potem dla Ciebie.',
    cta1: 'Zobacz ofertę', cta2: 'Żywy dowód: clawbot',
    status: 'aktywne: clawbot — autonomiczny quant-desk na realnych pieniądzach',
  },
}[lang];
const base = lang === 'pl' ? '' : `/${lang}`;
---
<section class="hero">
  <canvas class="signal" id="signal" aria-hidden="true"></canvas>
  <div class="container hero-inner">
    <p class="eyebrow reveal">{c.eye}</p>
    <h1 class="reveal" data-delay="1">{c.h1a} <span class="hl">{c.h1b}</span></h1>
    <p class="sub reveal measure" data-delay="2">{c.sub}</p>
    <div class="hero-cta reveal" data-delay="3">
      <a class="btn btn-accent" href={`${base}/uslugi/`}>{c.cta1} <span class="arrow">→</span></a>
      <a class="btn" href={`${base}/lab/clawbot/`}>{c.cta2}</a>
    </div>
    <p class="status mono reveal" data-delay="3"><span class="dot"></span>{c.status}</p>
  </div>
</section>

<style>
  .hero { position: relative; padding: clamp(64px, 13vw, 132px) 0 clamp(48px, 8vw, 88px); overflow: hidden; }
  .signal { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.9; pointer-events: none;
    -webkit-mask-image: linear-gradient(180deg, #000 35%, transparent 100%);
            mask-image: linear-gradient(180deg, #000 35%, transparent 100%); }
  .hero-inner { position: relative; z-index: 1; }
  .hero h1 { margin: 18px 0 0; max-width: 16ch; }
  .hl { color: var(--accent); }
  .sub { margin-top: 22px; font-size: clamp(16px, 2.1vw, 19px); color: var(--muted); }
  .hero-cta { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
  .status { margin-top: 30px; font-size: 12.5px; color: var(--faint); display: flex; align-items: center; gap: 9px; }
  .dot { width: 7px; height: 7px; border-radius: 999px; background: var(--pos); box-shadow: 0 0 0 0 color-mix(in srgb, var(--pos) 60%, transparent); animation: pulse 2.4s var(--ease) infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--pos) 55%, transparent);} 70%{ box-shadow: 0 0 0 7px transparent;} 100%{ box-shadow:0 0 0 0 transparent;} }
  @media (prefers-reduced-motion: reduce) { .dot { animation: none; } }
</style>

<script>
  // — "pole sygnału": kilka spokojnych, dryfujących linii (oscyloskop/tape) w akcencie —
  const cv = document.getElementById('signal');
  if (cv) {
    const ctx = cv.getContext('2d');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#E8B23A';
    let w = 0, h = 0, dpr = Math.min(2, devicePixelRatio || 1), raf = 0;
    const lines = [
      { amp: 14, freq: 0.6, speed: 0.00018, y: 0.30, op: 0.5 },
      { amp: 22, freq: 0.9, speed: 0.00026, y: 0.52, op: 0.35 },
      { amp: 10, freq: 1.4, speed: 0.00034, y: 0.70, op: 0.22 },
    ];
    function size() {
      const r = cv.getBoundingClientRect(); w = r.width; h = r.height;
      cv.width = w * dpr; cv.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function draw(t) {
      ctx.clearRect(0, 0, w, h);
      for (const L of lines) {
        ctx.beginPath();
        for (let x = 0; x <= w; x += 6) {
          const ph = (x / w) * Math.PI * 2 * L.freq + t * L.speed * 1000;
          const y = h * L.y + Math.sin(ph) * L.amp + Math.sin(ph * 0.5) * L.amp * 0.4;
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.strokeStyle = accent; ctx.globalAlpha = L.op; ctx.lineWidth = 1.4; ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }
    function loop(t) { draw(t); raf = requestAnimationFrame(loop); }
    size(); addEventListener('resize', size, { passive: true });
    if (reduce) { draw(1200); } else { raf = requestAnimationFrame(loop); }
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else if (!reduce) raf = requestAnimationFrame(loop);
    });
  }
</script>
