---
/*
  ConceptEmbed — karta-ODNOŚNIK do interaktywnej wizualizacji 3D "D-LOGIC DAY".
  NIE osadzamy iframe (decyzja Rafała 2026-06-14): klik otwiera standalone
  wizualizację w NOWEJ KARCIE. Plik Rafała kopiowany verbatim do
  public/projekty/dlogic-fx/concept-3d.html, NIETKNIĘTY. Prop: lang.
  Wzorzec jak mocps-live: link-karta z badge / tytuł / opis / CTA, target=_blank.
*/
const { lang = 'pl' } = Astro.props;
const t = {
  pl: {
    tag: 'interaktywnie · 3D',
    title: 'Koncept w przestrzeni',
    sub: 'Sześć gałęzi konceptu jako żywa sieć 3D: teza, dane, modele, rygor, mapa dnia i pochowane pomysły. Obróć scenę, przybliż, najedź na węzeł, żeby go odczytać.',
    cta: 'Otwórz wizualizację w nowej karcie →',
  },
  en: {
    tag: 'interactive · 3D',
    title: 'The concept, in space',
    sub: 'Six branches of the concept as a living 3D network: thesis, inputs, models, rigour, the day map and the buried ideas. Orbit the scene, zoom, hover a node to read it.',
    cta: 'Open the visualization in a new tab →',
  },
  de: {
    tag: 'interaktiv · 3D',
    title: 'Das Konzept im Raum',
    sub: 'Sechs Äste des Konzepts als lebendes 3D-Netz: These, Daten, Modelle, Rigorosität, die Tageskarte und die begrabenen Ideen. Drehe die Szene, zoome, fahre über einen Knoten zum Lesen.',
    cta: 'Visualisierung in neuem Tab öffnen →',
  },
}[lang] ?? {} as any;
const src = '/projekty/dlogic-fx/concept-3d.html';
---
<a class="concept-link" href={src} target="_blank" rel="noopener">
  <span class="concept-badge"><span class="concept-dot"></span>{t.tag}</span>
  <span class="concept-title">{t.title}</span>
  <span class="concept-sub">{t.sub}</span>
  <span class="concept-cta">{t.cta}</span>
</a>

<style>
  .concept-link{ display:block; margin:0 0 2.4rem; padding:1.8rem 1.6rem; border:1px solid var(--line);
    border-radius:16px; background:radial-gradient(130% 150% at 50% -10%, #06241f 0%, #081016 45%, #04060a 100%);
    text-decoration:none; position:relative; overflow:hidden; transition:border-color .2s ease, transform .2s ease; }
  .concept-link::after{ content:""; position:absolute; inset:0;
    background:linear-gradient(115deg, transparent 40%, rgba(55,227,208,.07) 50%, transparent 60%); pointer-events:none; }
  .concept-link:hover{ border-color:rgba(55,227,208,.45); transform:translateY(-2px); }
  .concept-badge{ display:inline-flex; align-items:center; gap:7px; font-family:'JetBrains Mono Variable',monospace;
    font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:#37e3d0; }
  .concept-dot{ width:7px; height:7px; border-radius:50%; background:#37e3d0; box-shadow:0 0 8px #37e3d0;
    animation:concept-pulse 2.4s ease-in-out infinite; }
  @keyframes concept-pulse{ 0%,100%{ opacity:1 } 50%{ opacity:.35 } }
  .concept-title{ display:block; font-family:'Space Grotesk Variable',sans-serif; font-size:clamp(22px,4.5vw,30px);
    color:var(--text); margin:.5rem 0 .55rem; }
  .concept-sub{ display:block; color:var(--muted); font-size:14px; line-height:1.6; max-width:60ch; }
  .concept-cta{ display:inline-block; margin-top:1rem; font-weight:600; font-size:14px; color:#37e3d0; }
</style>
