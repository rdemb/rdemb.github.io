---
// Wspolny shell stron marketingowych (oferta / o-mnie): SiteNav + footer + i18n client-side.
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import SiteNav from './SiteNav.astro';
const { title, description = '', dict, active = '' } = Astro.props;
---
<!doctype html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0E12" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (() => { try { document.documentElement.setAttribute('data-theme', localStorage.getItem('dlogic-theme') || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')); } catch (e) {} })();
    </script>
    <script is:inline set:html={`window.__I18N=${JSON.stringify(dict)};window.__ACTIVE=${JSON.stringify(active)};`}></script>
  </head>
  <body>
    <div id="progress"></div>
    <SiteNav mode="client" active={active} />

    <main id="top"><slot /></main>

    <footer>
      <div class="wrap">
        <div class="foot-grid">
          <div>
            <div class="brand"><span class="dot"></span>D&#8209;<b>LOGIC</b>&nbsp;<span style="color:var(--muted);font-weight:400">studio</span></div>
            <p class="tag" data-i18n="foot.tag">•</p>
          </div>
          <div class="foot-links">
            <div class="foot-col">
              <h4 data-i18n="foot.h1">•</h4>
              <a href="/o-mnie/" data-i18n="nav.about">•</a>
              <a href="/oferta/" data-i18n="nav.work">•</a>
              <a href="/pracownia/" data-i18n="nav.pracownia">•</a>
              <a href="/projekty/" data-i18n="nav.projects">•</a>
              <a href="/zywy-algorytm/" data-i18n="nav.zywy">•</a>
              <a href="/blog/" data-i18n="nav.blog">•</a>
            </div>
            <div class="foot-col">
              <h4 data-i18n="foot.h2">•</h4>
              <a href="mailto:rdem91@gmail.com">rdem91@gmail.com</a>
              <a href="https://x.com/takitamrafal" target="_blank" rel="noopener">x.com/takitamrafal</a>
              <a href="https://github.com/rdemb" target="_blank" rel="noopener">github.com/rdemb</a>
            </div>
          </div>
        </div>
        <div class="foot-base">
          <span>© <span id="yr">2026</span> D-LOGIC studio</span>
          <span data-i18n="foot.made">•</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      const D = document.documentElement;
      const I18N = window.__I18N || {};
      function applyLang(lang){
        const dict = I18N[lang] || I18N.pl || {};
        D.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach(el=>{ const v=dict[el.getAttribute('data-i18n')]; if(v!=null) el.textContent=v; });
        document.querySelectorAll('[data-i18n-html]').forEach(el=>{ const v=dict[el.getAttribute('data-i18n-html')]; if(v!=null) el.innerHTML=v; });
        document.querySelectorAll('#lang button').forEach(b=>b.classList.toggle('on', b.dataset.lang===lang));
        try{ localStorage.setItem('dlogic-lang', lang); }catch(e){}
      }
      const seg = document.getElementById('lang');
      seg && seg.addEventListener('click', e=>{ const b=e.target.closest('button'); if(b) applyLang(b.dataset.lang); });

      const sun='<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>';
      const moon='<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>';
      function setTheme(t){ D.setAttribute('data-theme',t); const s=document.querySelector('#theme svg'); if(s) s.innerHTML=t==='dark'?sun:moon; try{localStorage.setItem('dlogic-theme',t);}catch(e){} }
      const themeBtn = document.getElementById('theme');
      themeBtn && themeBtn.addEventListener('click', ()=>setTheme(D.getAttribute('data-theme')==='dark'?'light':'dark'));

      applyLang(localStorage.getItem('dlogic-lang')||'pl');
      setTheme(D.getAttribute('data-theme')||'dark');

      const prog=document.getElementById('progress');
      function onScroll(){ const st=scrollY; const h=D.scrollHeight-innerHeight; if(prog) prog.style.width=(h>0?(st/h)*100:0)+'%'; }
      addEventListener('scroll', onScroll, {passive:true}); onScroll();

      const reduce=matchMedia('(prefers-reduced-motion:reduce)').matches;
      const io=new IntersectionObserver(es=>es.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} }), {threshold:.12, rootMargin:'0px 0px -8% 0px'});
      document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

      function countUp(el){ const tg=parseFloat(el.dataset.count),dc=parseInt(el.dataset.dec||'0',10),pr=el.dataset.prefix||'',sf=el.dataset.suffix||''; if(reduce){el.textContent=pr+tg.toFixed(dc)+sf;return;} const t0=performance.now(),du=1200; (function s(n){const p=Math.min((n-t0)/du,1),e=1-Math.pow(1-p,3); el.textContent=pr+(tg*e).toFixed(dc)+sf; if(p<1)requestAnimationFrame(s);})(performance.now()); }
      const ioc=new IntersectionObserver(es=>es.forEach(e=>{ if(e.isIntersecting){ countUp(e.target); ioc.unobserve(e.target);} }), {threshold:.5});
      document.querySelectorAll('[data-count]').forEach(el=>ioc.observe(el));
      const yr=document.getElementById('yr'); if(yr) yr.textContent=new Date().getFullYear();
    </script>
    <slot name="page-script" />
  </body>
</html>
