---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

const {
  title = 'D-LOGIC Studio · narzędzia AI, web i dane',
  description = 'Solo studio (człowiek + AI): narzędzia AI, strony i produkty danowe. Uczciwość zamiast hype. Testowane jak strategie tradingowe, najpierw na sobie.',
  lang = 'pl',
} = Astro.props;
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0E12" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (() => { try {
        const t = localStorage.getItem('dlogic-theme') || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) { document.documentElement.setAttribute('data-theme','dark'); } })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
