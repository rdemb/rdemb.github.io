---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import Share from '../components/Share.astro';

const { lang = 'pl', title, description = '', sw = { pl: '/', en: '/en/', de: '/de/' }, share = true } = Astro.props;
// Aktywna zakladka wyliczana z biezacej sciezki (dziala dla /blog, /en/blog, /projekty, ...)
const path = Astro.url?.pathname || '';
const active = path.includes('/projekty') ? '/projekty/' : path.includes('/blog') ? '/blog/' : '';
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0E12" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {sw.pl && <link rel="alternate" hreflang="pl" href={sw.pl} />}
    {sw.en && <link rel="alternate" hreflang="en" href={sw.en} />}
    {sw.de && <link rel="alternate" hreflang="de" href={sw.de} />}
    <script is:inline>
      (() => { try { document.documentElement.setAttribute('data-theme', localStorage.getItem('dlogic-theme') || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')); } catch (e) {} })();
    </script>
  </head>
  <body>
    <SiteNav mode="routed" lang={lang} active={active} sw={sw} />

    <main class="wrap page-wrap"><slot />{share && <Share lang={lang} />}</main>

    <footer>
      <div class="wrap"><div class="foot-base" style="margin-top:0;border-top:none">
        <span class="mono">© 2026 D-LOGIC studio</span>
        <span class="mono"><a href="mailto:rdem91@gmail.com">rdem91@gmail.com</a> · <a href="https://x.com/takitamrafal" target="_blank" rel="noopener">x</a> · <a href="https://github.com/rdemb" target="_blank" rel="noopener">github</a></span>
      </div></div>
    </footer>

    <script is:inline>
      const D = document.documentElement;
      const sun='<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>';
      const moon='<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>';
      const svg=document.querySelector('#theme svg'); if(svg) svg.innerHTML=D.getAttribute('data-theme')==='dark'?sun:moon;
      const themeBtn=document.getElementById('theme');
      themeBtn && themeBtn.addEventListener('click', function(){ var t=D.getAttribute('data-theme')==='dark'?'light':'dark'; D.setAttribute('data-theme',t); if(svg) svg.innerHTML=t==='dark'?sun:moon; try{localStorage.setItem('dlogic-theme',t);}catch(e){} });
    </script>
  </body>
</html>
