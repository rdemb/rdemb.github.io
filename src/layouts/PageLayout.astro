---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

const { lang = 'pl', title, description = '', sw = { pl: '/', en: '/en/', de: '/de/' } } = Astro.props;
const base = lang === 'pl' ? '' : `/${lang}`;
const L = {
  pl: { work: 'Oferta', lab: 'Lab', blog: 'Notatki', contact: 'Kontakt' },
  en: { work: 'Work', lab: 'Lab', blog: 'Notes', contact: 'Contact' },
  de: { work: 'Leistungen', lab: 'Lab', blog: 'Notizen', contact: 'Kontakt' },
}[lang];
const blogHref = base + '/blog/';
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0E12" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {sw.pl && <link rel="alternate" hreflang="pl" href={sw.pl} />}
    {sw.en && <link rel="alternate" hreflang="en" href={sw.en} />}
    {sw.de && <link rel="alternate" hreflang="de" href={sw.de} />}
    <script is:inline>
      (() => { try { document.documentElement.setAttribute('data-theme', localStorage.getItem('dlogic-theme') || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')); } catch (e) {} })();
    </script>
  </head>
  <body>
    <header class="nav" id="nav">
      <div class="wrap nav-inner">
        <a href="/" class="brand"><span class="dot"></span>D&#8209;<b>LOGIC</b>&nbsp;<span style="color:var(--muted);font-weight:400">studio</span></a>
        <nav class="nav-links">
          <a href="/#oferta">{L.work}</a>
          <a href={blogHref}>{L.blog}</a>
          <a href="/#kontakt">{L.contact}</a>
        </nav>
        <div class="nav-tools">
          <div class="seg" aria-label="Język / Language">
            <a href={sw.pl} class={'mono ' + (lang === 'pl' ? 'on' : '')} style="padding:6px 9px;border-radius:6px">PL</a>
            <a href={sw.en} class={'mono ' + (lang === 'en' ? 'on' : '')} style="padding:6px 9px;border-radius:6px">EN</a>
            <a href={sw.de} class={'mono ' + (lang === 'de' ? 'on' : '')} style="padding:6px 9px;border-radius:6px">DE</a>
          </div>
          <button class="icon-btn" id="theme" aria-label="Theme">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
          </button>
        </div>
      </div>
    </header>
    <main class="wrap page-wrap">
      <slot />
    </main>
    <footer>
      <div class="wrap">
        <div class="foot-base" style="margin-top:0;border-top:none">
          <span class="mono">© 2026 D-LOGIC studio</span>
          <span class="mono"><a href="mailto:rdem91@gmail.com">rdem91@gmail.com</a> · <a href="https://x.com/takitamrafal" target="_blank" rel="noopener">x</a> · <a href="https://github.com/rdemb" target="_blank" rel="noopener">github</a></span>
        </div>
      </div>
    </footer>
    <script is:inline>
      const d = document.documentElement;
      const sun = '<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>';
      const moon = '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>';
      const svg = document.querySelector('#theme svg');
      if (svg) svg.innerHTML = d.getAttribute('data-theme') === 'dark' ? sun : moon;
      document.getElementById('theme').addEventListener('click', () => {
        const t = d.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        d.setAttribute('data-theme', t); if (svg) svg.innerHTML = t === 'dark' ? sun : moon;
        try { localStorage.setItem('dlogic-theme', t); } catch (e) {}
      });
      const nav = document.getElementById('nav');
      addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 10), { passive: true });
    </script>
  </body>
</html>
