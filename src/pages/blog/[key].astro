---
import PageLayout from '../../layouts/PageLayout.astro';
import { postsByLang, postSw, blogText, kindLabel } from '../../lib/content';
import { render } from 'astro:content';
const lang = 'pl';
export async function getStaticPaths() {
  const posts = await postsByLang('pl');
  return posts.map((p) => ({ params: { key: p.data.key }, props: { entry: p } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const t = blogText[lang];
---
<PageLayout lang={lang} title={`${entry.data.title} · D-LOGIC studio`} description={entry.data.excerpt} sw={postSw(entry.data.key)}>
  <div class="crumbs"><a href="/">D-LOGIC</a> <span>/</span> <a href="/blog/">{t.title}</a></div>
  <header class="article-head">
    <span class="meta mono">{entry.data.date.replaceAll('-', '.')} · {kindLabel[lang][entry.data.kind] ?? entry.data.kind}</span>
    <h1>{entry.data.title}</h1>
    {entry.data.excerpt && <p class="excerpt">{entry.data.excerpt}</p>}
  </header>
  <article class="prose"><Content /></article>
  <div class="article-foot">
    <a class="mono" href="/blog/" style="color:var(--accent)">{t.all} →</a>
  </div>
</PageLayout>
