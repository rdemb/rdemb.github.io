---
import Chrome from '../components/Chrome.astro';
import { withUi } from '../i18n';

const dict = withUi({
  pl: {
    'za.eyebrow': 'Organizm rynku · na żywo',
    'za.title': "Żywy algorytm, <span class='hl'>karmiony rynkiem.</span>",
    'za.lead': 'To nie animacja. Tysiące cząstek niesie PRAWDZIWY przepływ zleceń z rynku (na żywo, 24/7). Napór kupna i sprzedaży to widzialny prąd, zmienność to turbulencja, spokój to cisza. Dzisiejszy rynek = dzisiejszy organizm. Patrz, dokąd popłynie.',
    'za.asset': 'instrument', 'za.price': 'cena', 'za.flow': 'przepływ zleceń', 'za.vol': 'zmienność',
    'za.mom': 'momentum', 'za.regime': 'reżim', 'za.chg': 'zmiana 24h',
    'za.offline': 'łączę z rynkiem…',
    'za.legend': 'Kolor = przepływ zleceń (zielony: napór kupna, czerwony: napór sprzedaży, bursztyn: równowaga). Chaos ruchu = zmienność. Prąd = kierunek przewagi kupujących/sprzedających.',
    'za.chart': 'Przepływ zleceń i cena w czasie (realne dane Binance)',
    'za.cl1': 'przepływ zleceń', 'za.cl2': 'cena',
    'za.how.h': 'Jak to działa (uczciwie)',
    'za.how.b': 'Czytam publiczne, realne transakcje z giełdy (tylko odczyt, zero handlu) i z agresora każdej transakcji liczę PRZEPŁYW ZLECEŃ, czyli kto naciska: kupujący czy sprzedający. To, a nie świece OHLC, jest moją tezą o przewadze. Ten przepływ, zmienność i momentum napędzają pole sił, w którym żyje rój. Proces liczy się 24/7 na serwerze; organizm reaguje na to, co rynek robi w tej chwili. Wkrótce: obstawiaj, dokąd popłynie, i sprawdzaj swoją trafność.',
  },
  en: {
    'za.eyebrow': 'Market organism · live',
    'za.title': "A living algorithm, <span class='hl'>fed by the market.</span>",
    'za.lead': 'Not an animation. Thousands of particles are carried by REAL order flow from the market (live, 24/7). Buy and sell pressure is a visible current, volatility is turbulence, calm is stillness. Today\'s market = today\'s organism. Watch where it flows.',
    'za.asset': 'instrument', 'za.price': 'price', 'za.flow': 'order flow', 'za.vol': 'volatility',
    'za.mom': 'momentum', 'za.regime': 'regime', 'za.chg': '24h change',
    'za.offline': 'connecting to the market…',
    'za.legend': 'Colour = order flow (green: buy pressure, red: sell pressure, amber: balance). Motion chaos = volatility. Current = direction of buyer/seller dominance.',
    'za.chart': 'Order flow and price over time (real Binance data)',
    'za.cl1': 'order flow', 'za.cl2': 'price',
    'za.how.h': 'How it works (honestly)',
    'za.how.b': 'I read public, real exchange trades (read-only, zero trading) and from the aggressor of each trade I compute ORDER FLOW, who is pushing: buyers or sellers. That, not OHLC candles, is my thesis on edge. This flow, volatility and momentum drive the force field the swarm lives in. The process runs 24/7 on the server; the organism reacts to what the market is doing right now. Soon: bet on where it flows and track your accuracy.',
  },
  de: {
    'za.eyebrow': 'Markt-Organismus · live',
    'za.title': "Ein lebender Algorithmus, <span class='hl'>vom Markt genährt.</span>",
    'za.lead': 'Keine Animation. Tausende Partikel werden vom ECHTEN Orderfluss des Marktes getragen (live, 24/7). Kauf- und Verkaufsdruck ist eine sichtbare Strömung, Volatilität ist Turbulenz, Ruhe ist Stille. Der heutige Markt = der heutige Organismus. Sieh, wohin er fließt.',
    'za.asset': 'Instrument', 'za.price': 'Preis', 'za.flow': 'Orderfluss', 'za.vol': 'Volatilität',
    'za.mom': 'Momentum', 'za.regime': 'Regime', 'za.chg': '24h Änderung',
    'za.offline': 'verbinde mit dem Markt…',
    'za.legend': 'Farbe = Orderfluss (grün: Kaufdruck, rot: Verkaufsdruck, bernstein: Gleichgewicht). Bewegungschaos = Volatilität. Strömung = Richtung der Käufer/Verkäufer-Dominanz.',
    'za.chart': 'Orderfluss und Preis über Zeit (echte Binance-Daten)',
    'za.cl1': 'Orderfluss', 'za.cl2': 'Preis',
    'za.how.h': 'So funktioniert es (ehrlich)',
    'za.how.b': 'Ich lese öffentliche, echte Börsen-Trades (nur lesend, kein Handel) und berechne aus dem Aggressor jedes Trades den ORDERFLUSS, wer drückt: Käufer oder Verkäufer. Das, nicht OHLC-Kerzen, ist meine These zum Edge. Dieser Fluss, Volatilität und Momentum treiben das Kraftfeld, in dem der Schwarm lebt. Der Prozess läuft 24/7 auf dem Server; der Organismus reagiert auf das, was der Markt gerade tut. Bald: wette, wohin er fließt, und verfolge deine Trefferquote.',
  },
});
---
<Chrome title="Organizm rynku , żywy algorytm karmiony rynkiem · D-LOGIC studio" description="Żywy rój napędzany realnym przepływem zleceń z rynku (na żywo, 24/7). Order-flow jako widzialny prąd, zmienność jako turbulencja. Nie animacja , prawdziwe dane." dict={dict} active="/zywy-algorytm/">
  <section class="za">
    <div class="wrap">
      <span class="eyebrow" data-i18n="za.eyebrow">•</span>
      <h1 class="za-h1" data-i18n-html="za.title">•</h1>
      <p class="za-lead" data-i18n="za.lead">•</p>

      <div class="za-bar">
        <div class="za-assets" id="za-assets">
          <button data-asset="BTC" class="on">BTC</button>
          <button data-asset="ETH">ETH</button>
          <button data-asset="SOL">SOL</button>
        </div>
        <div class="za-hud">
          <div class="za-stat"><b id="za-price">·</b><span data-i18n="za.price">•</span></div>
          <div class="za-stat"><b id="za-flow">·</b><span data-i18n="za.flow">•</span></div>
          <div class="za-stat"><b id="za-vol">·</b><span data-i18n="za.vol">•</span></div>
          <div class="za-stat"><b id="za-mom">·</b><span data-i18n="za.mom">•</span></div>
          <div class="za-stat"><b id="za-chg">·</b><span data-i18n="za.chg">•</span></div>
          <div class="za-stat"><b id="za-regime">·</b><span data-i18n="za.regime">•</span></div>
        </div>
      </div>

      <div class="za-stage">
        <canvas id="org"></canvas>
        <div class="za-off" id="za-off" data-i18n="za.offline">•</div>
      </div>
      <p class="za-legend" data-i18n="za.legend">•</p>

      <div class="za-chart-box">
        <div class="za-chart-head">
          <span data-i18n="za.chart">•</span>
          <span class="za-keys"><i class="k k1"></i><span data-i18n="za.cl1">•</span><i class="k k2"></i><span data-i18n="za.cl2">•</span></span>
        </div>
        <canvas id="za-chart"></canvas>
      </div>

      <div class="za-how">
        <h3 data-i18n="za.how.h">•</h3>
        <p data-i18n="za.how.b">•</p>
      </div>
    </div>
  </section>

  <style>
    .za{ padding:60px 0 90px; }
    .za-h1{ font-family:'Space Grotesk Variable',sans-serif; font-weight:600; font-size:clamp(34px,5.4vw,62px); line-height:1.02; letter-spacing:-.02em; margin:18px 0 0; }
    .za-h1 :global(.hl){ color:var(--accent); }
    .za-lead{ color:var(--muted); font-size:clamp(16px,1.7vw,19px); max-width:66ch; margin:18px 0 24px; line-height:1.6; }
    .za-bar{ display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
    .za-assets{ display:flex; gap:3px; border:1px solid var(--line); border-radius:10px; padding:3px; background:var(--surface); }
    .za-assets button{ font-family:'JetBrains Mono Variable',monospace; font-size:12.5px; font-weight:600; letter-spacing:.04em; padding:7px 13px; border-radius:7px; color:var(--muted); transition:.2s; }
    .za-assets button.on{ background:var(--accent); color:#0C0E12; }
    .za-assets button:not(.on):hover{ color:var(--text); }
    .za-hud{ display:flex; gap:8px; flex-wrap:wrap; flex:1; }
    .za-stat{ border:1px solid var(--line); border-radius:11px; background:var(--surface); padding:9px 13px; min-width:84px; }
    .za-stat b{ font-family:'Space Grotesk Variable',sans-serif; font-size:clamp(15px,1.9vw,20px); font-weight:600; color:var(--accent); display:block; line-height:1; font-variant-numeric:tabular-nums; }
    .za-stat span{ font-family:'JetBrains Mono Variable',monospace; font-size:10px; color:var(--muted); margin-top:6px; display:block; letter-spacing:.02em; }
    .za-stage{ position:relative; width:100%; aspect-ratio:1200/660; border:1px solid var(--line); border-radius:16px; overflow:hidden; background:#070809; box-shadow:0 30px 80px -42px rgba(0,0,0,.8); }
    .za-stage canvas{ width:100%; height:100%; display:block; }
    .za-off{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono Variable',monospace; font-size:13px; color:var(--muted); background:var(--bg); }
    .za-legend{ font-family:'JetBrains Mono Variable',monospace; font-size:12px; color:var(--muted); margin:14px 0 0; max-width:80ch; line-height:1.5; }
    .za-chart-box{ margin-top:32px; border:1px solid var(--line); border-radius:14px; background:var(--surface); padding:18px; }
    .za-chart-head{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; font-family:'JetBrains Mono Variable',monospace; font-size:12px; color:var(--muted); margin-bottom:12px; }
    .za-keys{ display:inline-flex; align-items:center; gap:6px; }
    .za-keys .k{ width:11px; height:3px; border-radius:2px; display:inline-block; margin-left:8px; }
    .za-keys .k1{ background:#4ADE80; } .za-keys .k2{ background:#E8B23A; }
    #za-chart{ width:100%; height:140px; display:block; }
    .za-how{ margin-top:32px; max-width:64ch; }
    .za-how h3{ font-family:'Space Grotesk Variable',sans-serif; font-size:18px; font-weight:600; margin:0 0 12px; }
    .za-how p{ color:var(--muted); font-size:15px; line-height:1.65; }
    @media(max-width:620px){ .za-hud .za-stat{ min-width:72px; } }
  </style>

  <script slot="page-script" is:inline>
    (function(){
      const cv=document.getElementById('org'); if(!cv) return;
      const ctx=cv.getContext('2d',{alpha:false}); const off=document.getElementById('za-off'); const $=id=>document.getElementById(id);
      let base=null, asset='BTC', W=0,H=0, dpr=Math.min(devicePixelRatio||1,1.75);
      let M={flow:0,vol:.18,mom:0,intensity:.5}, T={flow:0,vol:.18,mom:0,intensity:.5};
      let series=[], assetsData={}, parts=[], t=0;
      function fit(){ const r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*dpr; cv.height=H*dpr; ctx.setTransform(dpr,0,0,dpr,0,0); seed(); }
      addEventListener('resize',fit);
      function seed(){ const n=Math.min(2200,Math.max(500,Math.floor(W*H*0.0016))); parts=[]; for(let i=0;i<n;i++) parts.push({x:Math.random()*W,y:Math.random()*H,vx:0,vy:0,l:30+Math.random()*200}); }
      // value noise
      const perm=new Uint8Array(512),p=[]; for(let i=0;i<256;i++)p[i]=i; let s=7; for(let i=255;i>0;i--){s=(s*16807)%2147483647;const j=s%(i+1);const tm=p[i];p[i]=p[j];p[j]=tm;} for(let i=0;i<512;i++)perm[i]=p[i&255];
      const fade=t=>t*t*t*(t*(t*6-15)+10), lerp=(a,b,t)=>a+t*(b-a), grad=(h,x,y)=>((h&1)?-x:x)+((h&2)?-y:y);
      function noise(x,y){ const X=Math.floor(x)&255,Y=Math.floor(y)&255; x-=Math.floor(x);y-=Math.floor(y); const u=fade(x),v=fade(y); const aa=perm[perm[X]+Y],ab=perm[perm[X]+Y+1],ba=perm[perm[X+1]+Y],bb=perm[perm[X+1]+Y+1]; return lerp(lerp(grad(aa,x,y),grad(ba,x-1,y),u),lerp(grad(ab,x,y-1),grad(bb,x-1,y-1),u),v); }
      function angle(x,y){ const sc=0.0013+M.vol*0.004; let a=noise(x*sc,y*sc+t*0.10)*Math.PI*(2.2+M.vol*3.0); const cur=Math.atan2(M.mom*0.7,(M.flow)+0.0001); const mag=Math.min(0.85,Math.abs(M.flow)*0.9+Math.abs(M.mom)*0.7); return a*(1-mag)+cur*mag; }
      function hue(){ return M.flow>=0 ? 45+M.flow*95 : 45+M.flow*38; }   // +zielony .. bursztyn .. -czerwony
      function frame(){
        for(const k in T) M[k]+=(T[k]-M[k])*0.04;
        const bg='rgba(7,8,9,'+(0.12-M.vol*0.05)+')'; ctx.globalCompositeOperation='source-over'; ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
        ctx.globalCompositeOperation='lighter';
        const h=hue(), spd=0.6+M.intensity*1.6+Math.abs(M.mom)*1.2;
        for(const q of parts){
          const a=angle(q.x,q.y); q.vx=(q.vx+Math.cos(a)*0.12*spd)*0.92; q.vy=(q.vy+Math.sin(a)*0.12*spd)*0.92;
          const px=q.x,py=q.y; q.x+=q.vx; q.y+=q.vy; q.l--;
          const v=Math.min(Math.hypot(q.vx,q.vy),3), al=Math.min(0.7,0.1+v*0.4);
          ctx.strokeStyle='hsla('+h+','+(55+M.vol*35)+'%,'+(52+v*8)+'%,'+al+')'; ctx.lineWidth=0.9+M.intensity*0.7;
          ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(q.x,q.y); ctx.stroke();
          if(q.l<0||q.x<-20||q.x>W+20||q.y<-20||q.y>H+20){ q.x=Math.random()*W; q.y=Math.random()*H; q.vx=q.vy=0; q.l=30+Math.random()*200; }
        }
        ctx.globalCompositeOperation='source-over'; t+=0.016; requestAnimationFrame(frame);
      }
      function setHUD(){ const a=assetsData[asset]; if(!a)return;
        $('za-price').textContent=a.price; $('za-flow').textContent=(a.flow>0?'+':'')+a.flow;
        $('za-vol').textContent=a.vol; $('za-mom').textContent=(a.mom>0?'+':'')+a.mom;
        $('za-chg').textContent=(a.chg24h>0?'+':'')+a.chg24h+'%'; $('za-regime').textContent=a.regime||'·';
        T.flow=a.flow; T.vol=a.vol; T.mom=a.mom; T.intensity=a.intensity; }
      function chart(){ const cc=$('za-chart'); if(!cc||series.length<2)return; const r=cc.getBoundingClientRect(); cc.width=r.width*dpr; cc.height=r.height*dpr; const x=cc.getContext('2d'); x.setTransform(dpr,0,0,dpr,0,0); const w=r.width,hh=r.height; x.clearRect(0,0,w,hh);
        const n=series.length, PX=i=>i/(n-1)*w;
        // flow -1..1 (zielony), znormalizowana cena (bursztyn)
        const ps=series.map(s=>s.price), mn=Math.min.apply(null,ps), mx=Math.max.apply(null,ps)||1;
        x.strokeStyle='#4ADE80'; x.lineWidth=1.6; x.beginPath(); series.forEach((sv,i)=>{const y=hh/2-(sv.flow)*(hh/2-6); i?x.lineTo(PX(i),y):x.moveTo(PX(i),y);}); x.stroke();
        x.strokeStyle='#E8B23A'; x.lineWidth=1.6; x.beginPath(); series.forEach((sv,i)=>{const y=hh-6-((sv.price-mn)/((mx-mn)||1))*(hh-12); i?x.lineTo(PX(i),y):x.moveTo(PX(i),y);}); x.stroke();
        x.strokeStyle='rgba(255,255,255,.08)'; x.lineWidth=1; x.beginPath(); x.moveTo(0,hh/2); x.lineTo(w,hh/2); x.stroke(); }
      async function poll(){
        try{
          if(!base){ const j=await (await fetch('/pracownia-demos.json',{cache:'no-store'})).json(); base=(j.base||'').replace(/\/+$/,''); }
          if(base){ const d=await (await fetch(base+'/_live/market.json',{cache:'no-store'})).json(); assetsData=d.assets||{}; series=d.series||[]; setHUD(); chart(); if(off) off.style.display='none'; }
        }catch(e){ if(off) off.style.display=''; }
        setTimeout(poll,4000);
      }
      const ab=$('za-assets'); ab&&ab.addEventListener('click',e=>{ const b=e.target.closest('button'); if(!b)return; asset=b.dataset.asset; ab.querySelectorAll('button').forEach(x=>x.classList.toggle('on',x===b)); setHUD(); });
      fit(); requestAnimationFrame(frame); poll();
    })();
  </script>
</Chrome>
