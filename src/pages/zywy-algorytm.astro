---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import SiteNav from '../components/SiteNav.astro';
---
<!DOCTYPE html>
<html lang="pl" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Order Flow, Organizm rynku · D-LOGIC studio</title>
<meta name="description" content="Cztery żywe algorytmy (Splot, Rój, Orbita, Nurt) napędzane na żywo realnym przepływem rynku. Organizm rynku, nie animacja. D-LOGIC studio." />
<meta name="theme-color" content="#06070A" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="canonical" href="https://rdemb.github.io/zywy-algorytm/" />
<meta property="og:title" content="Order Flow, Organizm rynku · D-LOGIC studio" />
<meta property="og:description" content="Cztery żywe algorytmy napędzane na żywo realnym przepływem rynku. Organizm rynku, nie animacja." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://rdemb.github.io/zywy-algorytm/" />
<meta property="og:site_name" content="D-LOGIC studio" />
<meta property="og:image" content="https://rdemb.github.io/og-default.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Order Flow, Organizm rynku" />
<meta name="twitter:description" content="Cztery żywe algorytmy napędzane realnym przepływem rynku, na żywo." />
<meta name="twitter:image" content="https://rdemb.github.io/og-default.png" />
<style is:global>
:root[data-theme="dark"]{
  --bg:#06070A; --panel:rgba(14,16,20,0.55); --line:rgba(231,233,236,0.14); --line-2:rgba(231,233,236,0.07);
  --text:#E7E9EC; --muted:#9AA1AB; --accent:#E8B23A; --accent-soft:#F0C766; --live:#4ADE80;
  --chip:rgba(232,178,58,0.10); --chip-line:rgba(232,178,58,0.32); --scrim:rgba(6,7,10,0.6);
}
:root[data-theme="light"]{
  --bg:#FBFBFA; --panel:rgba(255,255,255,0.7); --line:rgba(22,24,27,0.16); --line-2:rgba(22,24,27,0.08);
  --text:#16181B; --muted:#565D66; --accent:#B6831F; --accent-soft:#C8922A; --live:#1A8F4C;
  --chip:rgba(182,131,31,0.10); --chip-line:rgba(182,131,31,0.34); --scrim:rgba(251,251,250,0.6);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{background:var(--bg);color:var(--text);font-family:'Inter Variable',system-ui,sans-serif;-webkit-font-smoothing:antialiased;overflow:hidden;transition:background .6s ease,color .6s ease}
.mono{font-family:'JetBrains Mono Variable',ui-monospace,monospace}
.dsp{font-family:'Space Grotesk Variable',sans-serif}
::selection{background:var(--accent);color:#06070A}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:4px}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}

/* ---------- STAGE ---------- */
#stage-wrap{position:fixed;inset:0;z-index:0}
#stage{position:absolute;inset:0;width:100%;height:100%;display:block}
/* subtle instrument grid + vignette over the canvas */
.stage-grid{position:absolute;inset:0;pointer-events:none;z-index:1;
  background-image:linear-gradient(var(--line-2) 1px,transparent 1px),linear-gradient(90deg,var(--line-2) 1px,transparent 1px);
  background-size:54px 54px;opacity:.5;
  -webkit-mask-image:radial-gradient(ellipse 120% 120% at 50% 50%,transparent 55%,#000 100%);
  mask-image:radial-gradient(ellipse 120% 120% at 50% 50%,transparent 55%,#000 100%)}
.vignette{position:absolute;inset:0;pointer-events:none;z-index:2;
  background:radial-gradient(ellipse 95% 85% at 50% 48%, transparent 40%, var(--scrim) 100%)}
.crossfade{position:absolute;inset:0;z-index:5;background:var(--bg);opacity:0;pointer-events:none;transition:opacity .42s ease}
.crossfade.on{opacity:1}

/* ---------- NAV ---------- */
header.nav{position:fixed;top:0;left:0;right:0;z-index:40;display:flex;align-items:center;justify-content:space-between;padding:22px 34px}
.brand{display:flex;align-items:center;gap:9px;white-space:nowrap;font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:15px;letter-spacing:.04em}
.brand .glyph{color:var(--accent)} .brand b{color:var(--accent);font-weight:600}
.nav-links{display:flex;gap:26px}
.nav-links a{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;letter-spacing:.04em;color:var(--muted);transition:color .2s;position:relative;padding:3px 0}
.nav-links a.cur{color:var(--accent)}
.nav-links a::after{content:"";position:absolute;left:0;bottom:-3px;width:0;height:1.5px;background:var(--accent);transition:width .28s}
.nav-links a:hover{color:var(--text)} .nav-links a:hover::after{width:100%}
.nav-tools{display:flex;align-items:center;gap:8px}
.seg{display:flex;background:var(--panel);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid var(--line);border-radius:9px;padding:3px;gap:2px}
.seg button{font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;font-weight:500;letter-spacing:.05em;padding:6px 9px;border-radius:6px;color:var(--muted);transition:.2s}
.seg button.on{background:var(--accent);color:#06070A;font-weight:600}
.seg button:not(.on):hover{color:var(--text)}
.icon-btn{width:36px;height:36px;border-radius:9px;border:1px solid var(--line);background:var(--panel);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;color:var(--muted);transition:.2s}
.icon-btn:hover{color:var(--accent);border-color:var(--chip-line)}
.icon-btn svg{width:17px;height:17px}

/* ---------- HUD ---------- */
.hud{position:fixed;inset:0;z-index:30;pointer-events:none}
.hud .corner{position:absolute;font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}

/* title block bottom-left */
.hud-title{position:absolute;left:34px;bottom:120px;max-width:min(560px,72vw)}
.hud-eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;letter-spacing:.26em;text-transform:uppercase;color:var(--accent);margin-bottom:16px}
.hud-eyebrow::before{content:"";width:24px;height:1px;background:var(--accent);opacity:.7}
.hud-eyebrow .blink{width:7px;height:7px;border-radius:50%;background:var(--live);box-shadow:0 0 8px var(--live);animation:blink 1.6s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.hud-name{font-family:'Space Grotesk Variable',sans-serif;font-weight:600;font-size:clamp(40px,6vw,82px);line-height:.98;letter-spacing:-.025em}
.hud-latin{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;letter-spacing:.12em;color:var(--accent-soft);margin-top:12px;font-style:italic}
.hud-sub{font-family:'JetBrains Mono Variable',monospace;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-top:6px}
.hud-desc{font-size:15.5px;line-height:1.6;color:var(--muted);margin-top:18px;max-width:46ch;text-wrap:pretty}

/* metrics top-right (under nav) */
.hud-metrics{position:absolute;right:34px;top:84px;display:flex;flex-direction:column;gap:2px;align-items:flex-end;text-align:right}
.hud-metrics .mrow{font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;color:var(--muted);display:flex;gap:12px;align-items:baseline;justify-content:flex-end;padding:3px 0}
.hud-metrics .mrow .k{letter-spacing:.12em;text-transform:uppercase;font-size:10px;opacity:.8}
.hud-metrics .mrow .v{color:var(--text);min-width:64px;text-align:right;font-variant-numeric:tabular-nums}
.hud-metrics .mrow .v.am{color:var(--accent)}
.fps-bar{width:120px;height:2px;background:var(--line);margin-top:8px;border-radius:2px;overflow:hidden}
.fps-bar i{display:block;height:100%;width:100%;background:linear-gradient(90deg,var(--accent),var(--accent-soft));transform-origin:left;transition:transform .3s}

/* hint bottom-left tiny */
.hud-hint{position:absolute;left:34px;bottom:96px;font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted);display:flex;align-items:center;gap:9px;opacity:.85}
.hud-hint .ring{width:13px;height:13px;border:1.5px solid var(--accent);border-radius:50%;position:relative;flex:none}
.hud-hint .ring::after{content:"";position:absolute;inset:3px;border-radius:50%;background:var(--accent);animation:blink 1.6s infinite}

/* ---------- SWITCHER ---------- */
.switch{position:fixed;left:0;right:0;bottom:0;z-index:35;display:flex;justify-content:center;padding:22px 16px 26px;pointer-events:none}
.switch-inner{pointer-events:auto;display:flex;gap:8px;background:var(--panel);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:14px;padding:8px}
.chip{display:flex;align-items:center;gap:11px;padding:11px 16px 11px 13px;border-radius:9px;transition:background .25s,color .25s;color:var(--muted);position:relative}
.chip .kbd{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;width:19px;height:19px;border:1px solid var(--line);border-radius:5px;display:grid;place-items:center;color:var(--muted);transition:.25s;flex:none}
.chip .lab{display:flex;flex-direction:column;gap:1px;line-height:1.15;text-align:left}
.chip .lab b{font-family:'Space Grotesk Variable',sans-serif;font-weight:600;font-size:14px;letter-spacing:-.01em;color:var(--text);transition:color .25s}
.chip .lab span{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.chip:hover{background:var(--line-2)}
.chip.on{background:var(--chip)}
.chip.on .kbd{background:var(--accent);color:#06070A;border-color:var(--accent)}
.chip.on .lab b{color:var(--accent)}
.chip .spark{position:absolute;left:13px;right:13px;bottom:6px;height:1.5px;background:var(--accent);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.chip.on .spark{transform:scaleX(1)}

/* control cluster (auto-cycle + reseed) bottom-right */
.controls{position:fixed;right:34px;bottom:30px;z-index:35;display:flex;gap:8px}
.ctl{pointer-events:auto;font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.08em;color:var(--muted);border:1px solid var(--line);background:var(--panel);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-radius:9px;padding:9px 13px;display:inline-flex;align-items:center;gap:8px;transition:.2s}
.ctl:hover{color:var(--accent);border-color:var(--chip-line)}
.ctl .led{width:7px;height:7px;border-radius:50%;background:var(--muted);transition:.2s}
.ctl.live .led{background:var(--live);box-shadow:0 0 8px var(--live)}

/* loader */
#load{position:fixed;inset:0;z-index:60;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;font-family:'JetBrains Mono Variable',monospace;transition:opacity .6s ease,visibility .6s}
#load.done{opacity:0;visibility:hidden;pointer-events:none}
#load .lm{font-size:14px;letter-spacing:.12em;color:var(--accent)}
#load .ls{font-size:11.5px;color:var(--muted);letter-spacing:.06em}
.spinner{width:30px;height:30px;border:2px solid var(--line);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

@media (prefers-reduced-motion:reduce){
  .blink,.hud-hint .ring::after,.spinner{animation:none!important}
}
@media (max-width:860px){
  header.nav{padding:16px 18px}
  .nav-links{display:none}
  .hud-title{left:18px;right:18px;bottom:150px;max-width:none}
  .hud-metrics{right:18px;top:70px}
  .hud-hint{left:18px;bottom:132px}
  .controls{right:18px;bottom:96px}
  .switch{padding:14px 10px 18px}
  .switch-inner{gap:4px;padding:6px;border-radius:12px;overflow-x:auto;max-width:calc(100vw - 20px)}
  .chip{padding:9px 11px 9px 9px}
  .chip .lab span{display:none}
  .chip .kbd{display:none}
  .stage-grid{background-size:40px 40px}
}
.menu-btn{display:none}
@media (max-width:860px){
  .menu-btn{display:flex}
  header.nav.menuopen .nav-links{display:flex;position:absolute;top:60px;left:18px;right:18px;flex-direction:column;align-items:flex-start;gap:15px;background:var(--panel);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:12px;padding:18px 20px}
}
@media (max-width:860px){
  .hud-title{bottom:178px}
  .hud-hint{bottom:116px}
}
@media (max-width:560px){
  .corner{display:none}
  .hud-title{left:16px;right:16px;bottom:178px}
  .hud-name{font-size:clamp(30px,10vw,44px)}
  .hud-desc{display:none}
  .hud-hint{bottom:116px;left:16px}
  .hud-latin{font-size:11px}.hud-sub{font-size:10.5px}
  .hud-metrics{top:58px;right:16px}
  .controls{right:16px;bottom:148px}
}
@media (max-width:860px){
  .corner{display:none}
  .hud-title{bottom:184px}
  .hud-hint{bottom:122px}
  .hud-metrics{top:58px;right:16px}
  .switch{justify-content:flex-start}
  .switch-inner{margin-left:8px;max-width:calc(100vw - 142px)}
  .controls{right:10px;bottom:20px;flex-direction:row;gap:6px}
  .ctl{padding:8px 10px;font-size:10px}
}
</style>
</head>
<body>
<!-- STAGE -->
<div id="stage-wrap">
  <canvas id="stage"></canvas>
  <div class="stage-grid"></div>
  <div class="vignette"></div>
  <div class="crossfade" id="xfade"></div>
</div>

<!-- NAV -->
<SiteNav mode="client" active="/zywy-algorytm/" overlay={true} />

<!-- HUD -->
<div class="hud" aria-hidden="true">
  <div class="corner" style="left:34px;top:84px" id="cTL">◢ ŻYWY ALGORYTM // LAB</div>
  <div class="hud-metrics" id="metrics"></div>
  <div class="fps-bar" style="position:absolute;right:34px;top:152px"><i id="fpsBar"></i></div>

  <div class="hud-title">
    <span class="hud-eyebrow"><span class="blink"></span><span id="ebText" data-i18n="hud.eyebrow">organizm · emergencja na żywo</span></span>
    <div class="hud-name dsp" id="algoName">Splot</div>
    <div class="hud-latin" id="algoLatin">Physarum polycephalum</div>
    <div class="hud-sub" id="algoSub">emergentna sieć · optymalizacja przepływu</div>
    <div class="hud-desc" id="algoDesc"></div>
  </div>

  <div class="hud-hint"><span class="ring"></span><span id="hintText" data-i18n="hud.hint">porusz kursorem, nakarm organizm · przytrzymaj, by przyciągać</span></div>
</div>

<!-- SWITCHER -->
<div class="switch">
  <div class="switch-inner" id="switcher" role="tablist" aria-label="Algorytmy"></div>
</div>

<!-- CONTROLS -->
<div class="controls">
  <button class="ctl" id="cycle" title="Auto-cykl"><span class="led"></span><span data-i18n="ctl.auto">auto</span></button>
  <button class="ctl" id="reseed" title="Zasiej od nowa">↻ <span data-i18n="ctl.reseed">zasiej</span></button>
</div>

<!-- LOADER -->
<div id="load">
  <div class="spinner"></div>
  <div class="lm">◢ inicjalizacja organizmu</div>
  <div class="ls" id="loadSub">kompilacja reguł emergencji…</div>
</div>

<script is:inline src="/algo.js"></script>
<script is:inline>
(function(){
"use strict";
const docEl=document.documentElement;
const reduce=window.matchMedia("(prefers-reduced-motion:reduce)").matches;
const mq=window.matchMedia("(max-width:860px)");

/* ---------- i18n (HUD chrome) ---------- */
const T={
  pl:{ "nav.home":"start","nav.zywy":"order flow","nav.about":"o mnie","nav.work":"oferta","nav.xray":"prześwietlenie","nav.pracownia":"pracownia","nav.projects":"projekty","nav.algo":"order flow","nav.blog":"blog","nav.contact":"kontakt",
       "hud.eyebrow":"organizm · emergencja na żywo","hud.hint":"porusz kursorem, wpłyń na żywy organizm · 1, 4 zmienia algorytm",
       "ctl.auto":"auto","ctl.reseed":"zasiej","load":"kompilacja reguł emergencji…" },
  en:{ "nav.home":"home","nav.zywy":"order flow","nav.about":"about","nav.work":"services","nav.xray":"x-ray","nav.pracownia":"workshop","nav.projects":"projects","nav.algo":"order flow","nav.blog":"blog","nav.contact":"contact",
       "hud.eyebrow":"organism · emergence, live","hud.hint":"move the cursor, shape the living organism · 1, 4 swaps the algorithm",
       "ctl.auto":"auto","ctl.reseed":"reseed","load":"compiling rules of emergence…" },
  de:{ "nav.home":"start","nav.zywy":"order flow","nav.about":"über mich","nav.work":"Leistungen","nav.xray":"Röntgen","nav.pracownia":"Werkstatt","nav.projects":"Projekte","nav.algo":"order flow","nav.blog":"Blog","nav.contact":"Kontakt",
       "hud.eyebrow":"Organismus · Emergenz, live","hud.hint":"bewege den Cursor, forme den lebenden Organismus · 1, 4 wechselt den Algorithmus",
       "ctl.auto":"auto","ctl.reseed":"neu säen","load":"kompiliere Emergenzregeln…" }
};
let lang="pl";
try{ lang=localStorage.getItem("dlogic-lang")||"pl"; }catch(e){}
function applyLang(l){
  lang=l; docEl.lang=l; const d=T[l]||T.pl;
  document.querySelectorAll("[data-i18n]").forEach(el=>{ const v=d[el.getAttribute("data-i18n")]; if(v!=null) el.textContent=v; });
  document.querySelectorAll("#lang button").forEach(b=>b.classList.toggle("on",b.dataset.lang===l));
  try{ localStorage.setItem("dlogic-lang",l); }catch(e){}
  paintMeta();
}
document.getElementById("lang").addEventListener("click",e=>{ const b=e.target.closest("button"); if(b) applyLang(b.dataset.lang); });

/* ---------- theme ---------- */
const sun='<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>';
const moon='<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>';
let theme="dark"; try{ theme=localStorage.getItem("dlogic-theme")||"dark"; }catch(e){}
function applyTheme(t){ theme=t; docEl.setAttribute("data-theme",t); const s=document.querySelector("#theme svg"); if(s) s.innerHTML=t==="dark"?sun:moon; try{localStorage.setItem("dlogic-theme",t);}catch(e){} if(env){ env.theme=t; if(current&&current.resize) current.resize(env); } }
document.getElementById("theme").addEventListener("click",()=>applyTheme(theme==="dark"?"light":"dark"));

/* ---------- stage / framework ---------- */
const canvas=document.getElementById("stage"), ctx=canvas.getContext("2d");
let env=null, current=null, currentIdx=0, raf=0, last=performance.now(), fps=60, frames=0, fpsT=0;
const pointer={x:-9999,y:-9999,down:false,active:false};
const engines=(window.ALGO_ENGINES||[]).map(f=>f());

function size(){
  const dpr=Math.min(window.devicePixelRatio||1, mq.matches?1.3:1.6);
  const W=window.innerWidth, H=window.innerHeight;
  canvas.width=Math.round(W*dpr); canvas.height=Math.round(H*dpr);
  canvas.style.width=W+"px"; canvas.style.height=H+"px";
  ctx.setTransform(dpr,0,0,dpr,0,0);
  if(!env) env={ctx,W,H,dpr,mobile:mq.matches,pointer,theme,t:0};
  else { env.W=W; env.H=H; env.dpr=dpr; env.mobile=mq.matches; }
  if(current && current.resize) current.resize(env);
}

/* scramble for the engine name on switch */
const GLY="ABCDEFGHJKLMNPQRSTUVWXYZ0123456789◢▮/·";
function scramble(el,target,dur){
  if(reduce){ el.textContent=target; return; }
  const chars=target.split(""), t0=performance.now();
  (function f(now){ const p=Math.min((now-t0)/dur,1), rev=Math.floor(p*chars.length); let o="";
    for(let i=0;i<chars.length;i++){ const c=chars[i]; if(c===" "){o+=" ";continue;} o+= i<rev?c:GLY[(Math.random()*GLY.length)|0]; }
    el.textContent=o; if(p<1) requestAnimationFrame(f); else el.textContent=target; })(t0);
}

function paintMeta(){
  if(!current) return; const m=current.meta;
  document.getElementById("algoLatin").textContent=m.latin;
  document.getElementById("algoSub").textContent=m.sub[lang]||m.sub.pl;
  document.getElementById("algoDesc").textContent=m.desc[lang]||m.desc.pl;
}
function paintMetrics(){
  if(!current||!current.info) return;
  const rows=current.info();
  let html="";
  for(const r of rows) html+='<div class="mrow"><span class="k">'+r.k+'</span><span class="v am">'+r.v+'</span></div>';
  html+='<div class="mrow"><span class="k">fps</span><span class="v">'+Math.round(fps)+'</span></div>';
  document.getElementById("metrics").innerHTML=html;
}

function buildSwitcher(){
  const sw=document.getElementById("switcher"); sw.innerHTML="";
  engines.forEach((e,i)=>{
    const m=e.meta; const b=document.createElement("button");
    b.className="chip"+(i===currentIdx?" on":""); b.setAttribute("role","tab"); b.dataset.idx=i;
    b.innerHTML='<span class="kbd">'+(i+1)+'</span><span class="lab"><b>'+(m.name[lang]||m.name.pl)+'</b><span>'+m.latin.split('·')[0].trim()+'</span></span><span class="spark"></span>';
    b.addEventListener("click",()=>switchTo(i,true));
    sw.appendChild(b);
  });
}
function refreshSwitcherLabels(){ document.querySelectorAll(".chip").forEach((c,i)=>{ const m=engines[i].meta; c.querySelector(".lab b").textContent=m.name[lang]||m.name.pl; }); }

let switching=false;
function switchTo(idx, user){
  if(idx===currentIdx && current) return;
  if(user) stopCycle();
  const xf=document.getElementById("xfade"); xf.classList.add("on"); switching=true;
  setTimeout(()=>{
    currentIdx=idx; current=engines[idx];
    document.querySelectorAll(".chip").forEach((c,i)=>c.classList.toggle("on",i===idx));
    ctx.setTransform(env.dpr,0,0,env.dpr,0,0);
    current.init(env);
    scramble(document.getElementById("algoName"), current.meta.name[lang]||current.meta.name.pl, 600);
    paintMeta(); paintMetrics();
    setTimeout(()=>{ xf.classList.remove("on"); switching=false; },60);
  }, 360);
}

/* ---------- pointer ---------- */
function setPtr(cx,cy){ const r=canvas.getBoundingClientRect(); pointer.x=cx-r.left; pointer.y=cy-r.top; pointer.active=true; }
window.addEventListener("mousemove",e=>setPtr(e.clientX,e.clientY),{passive:true});
window.addEventListener("mousedown",e=>{ if(e.target.closest("button,a")) return; pointer.down=true; });
window.addEventListener("mouseup",()=>pointer.down=false);
window.addEventListener("mouseleave",()=>{ pointer.active=false; pointer.down=false; });
window.addEventListener("touchmove",e=>{ const t=e.touches[0]; if(t) setPtr(t.clientX,t.clientY); },{passive:true});
window.addEventListener("touchstart",e=>{ const t=e.touches[0]; if(t){ setPtr(t.clientX,t.clientY); pointer.down=true; } },{passive:true});
window.addEventListener("touchend",()=>{ pointer.down=false; });

/* keyboard */
window.addEventListener("keydown",e=>{
  if(e.key>="1" && e.key<="9"){ const i=+e.key-1; if(i<engines.length) switchTo(i,true); }
  else if(e.key===" "){ e.preventDefault(); reseed(); }
});

/* ---------- controls ---------- */
let cycleOn=false, cycleT=0;
function startCycle(){ cycleOn=true; document.getElementById("cycle").classList.add("live"); cycleT=performance.now(); }
function stopCycle(){ cycleOn=false; document.getElementById("cycle").classList.remove("live"); }
document.getElementById("cycle").addEventListener("click",()=>{ cycleOn?stopCycle():startCycle(); });
function reseed(){ if(current){ current.init(env); scramble(document.getElementById("algoName"), current.meta.name[lang]||current.meta.name.pl, 450); } }
document.getElementById("reseed").addEventListener("click",reseed);

/* ---------- loop ---------- */
function loop(now){
  raf=requestAnimationFrame(loop);
  let dt=now-last; last=now; if(dt>50)dt=50; env.t=now;
  // fps
  frames++; fpsT+=dt; if(fpsT>=500){ fps=frames*1000/fpsT; frames=0; fpsT=0;
    const fb=document.getElementById("fpsBar"); if(fb) fb.style.transform="scaleX("+Math.min(1,fps/60)+")";
    paintMetrics();
  }
  if(!switching && current) current.frame(env,dt);
  // auto-cycle every ~16s
  if(cycleOn && !switching && now-cycleT>16000){ cycleT=now; const ni=(currentIdx+1)%engines.length; switchTo(ni,false); }
}

/* ---------- boot ---------- */
function boot(){
  applyTheme(theme);
  size();
  buildSwitcher();
  current=engines[0]; currentIdx=0;
  if(reduce){
    current.still ? current.still(env) : current.init(env);
    document.getElementById("algoName").textContent=current.meta.name[lang]||current.meta.name.pl;
    paintMeta(); paintMetrics();
  } else {
    current.init(env);
    document.getElementById("algoName").textContent=current.meta.name[lang]||current.meta.name.pl;
    paintMeta(); paintMetrics();
    raf=requestAnimationFrame(loop);
  }
  applyLang(lang);
  setTimeout(()=>{ const l=document.getElementById("load"); if(l){ l.classList.add("done"); setTimeout(()=>{ l.style.display="none"; },650); } }, reduce?0:900);
}

let rsz; window.addEventListener("resize",()=>{ clearTimeout(rsz); rsz=setTimeout(size,160); });
document.addEventListener("visibilitychange",()=>{ if(document.hidden){ cancelAnimationFrame(raf); } else if(!reduce){ last=performance.now(); raf=requestAnimationFrame(loop); } });

// debug hook for static capture (advance N frames synchronously)
window.__ALGO={ switchTo:(id)=>{ const i=engines.findIndex(e=>e.meta.id===id); if(i>=0){ currentIdx=i; current=engines[i]; current.init(env); document.querySelectorAll(".chip").forEach((c,k)=>c.classList.toggle("on",k===i)); document.getElementById("algoName").textContent=current.meta.name[lang]; paintMeta(); } },
  kick:(nn)=>{ for(let k=0;k<(nn||60);k++){ env.t=performance.now()+k*16; current.frame(env,16);} paintMetrics(); } };

if(window.ALGO_ENGINES && window.ALGO_ENGINES.length){ boot(); }
else { document.getElementById("loadSub").textContent="błąd: silnik nie załadowany"; }
})();
</script><script is:inline src="/predict.js"></script>
