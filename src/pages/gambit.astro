---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import SiteNav from '../components/SiteNav.astro';
---
<!doctype html>
<html lang="pl" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>GAMBIT · ewoluujące umysły szachowe · D-LOGIC studio</title>
<meta name="description" content="Osiem neuroróżnorodnych umysłów uczy się grać w szachy. Grają ze sobą 24/7, ewoluują, pamiętają rywali i śnią. Ranking na żywo i partia z wybranym umysłem." />
<!-- is:global — KLUCZOWE: elementy stoluw/umyslow/tabeli/pickera tworzy gambit.js w runtime
     (bez atrybutu data-astro-cid), wiec scoped CSS by ich NIE objal i wygladalyby golo.
     Globalny styl (jak w Gambit.html) obejmuje tak samo statyczny markup, jak i ten z JS. -->
<style is:global>
:root[data-theme="dark"]{
  --bg:#0C0E12; --bg-rgb:12,14,18; --surface:#14171C; --surface-2:#191D24; --line:#23272E; --line-2:rgba(231,233,236,0.06);
  --text:#E7E9EC; --muted:#9AA1AB; --accent:#E8B23A; --accent-rgb:232,178,58; --accent-soft:#F0C766; --live:#4ADE80; --loss:#E8675A;
  --grid:rgba(231,233,236,0.026); --shadow:rgba(0,0,0,0.55); --chip:rgba(232,178,58,0.10); --chip-line:rgba(232,178,58,0.30);
  --sq-light:#20242C; --sq-dark:#15181E; --panel:rgba(20,23,28,0.6);
}
:root[data-theme="light"]{
  --bg:#FBFBFA; --bg-rgb:251,251,250; --surface:#FFFFFF; --surface-2:#F3F3EF; --line:#E3E2DB; --line-2:rgba(22,24,27,0.07);
  --text:#16181B; --muted:#565D66; --accent:#B6831F; --accent-rgb:182,131,31; --accent-soft:#C8922A; --live:#1A8F4C; --loss:#C0503F;
  --grid:rgba(22,24,27,0.04); --shadow:rgba(20,22,28,0.12); --chip:rgba(182,131,31,0.09); --chip-line:rgba(182,131,31,0.28);
  --sq-light:#ECEAE2; --sq-dark:#D8D5C9; --panel:rgba(255,255,255,0.7);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
body{background:var(--bg);color:var(--text);font-family:'Inter Variable',system-ui,sans-serif;font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;transition:background .6s,color .6s;overflow-x:hidden}
.gridbg{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(var(--grid) 1px,transparent 1px),linear-gradient(90deg,var(--grid) 1px,transparent 1px);background-size:46px 46px;-webkit-mask-image:radial-gradient(ellipse 140% 100% at 50% -5%,#000 30%,transparent 90%);mask-image:radial-gradient(ellipse 140% 100% at 50% -5%,#000 30%,transparent 90%)}
::selection{background:var(--accent);color:#0C0E12}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:4px}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input{font-family:inherit}
.mono{font-family:'JetBrains Mono Variable',ui-monospace,monospace}
.dsp{font-family:'Space Grotesk Variable',sans-serif}
.tnum{font-variant-numeric:tabular-nums;font-feature-settings:"tnum"}
.wrap{width:100%;max-width:1240px;margin:0 auto;padding:0 30px;position:relative;z-index:2}
.eyebrow{font-family:'JetBrains Mono Variable',monospace;font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:11px}
.eyebrow::before{content:"";width:24px;height:1px;background:var(--accent);opacity:.7}

#progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:300;background:linear-gradient(90deg,var(--accent),var(--accent-soft));box-shadow:0 0 10px var(--accent)}

/* NAV */
header.nav{position:sticky;top:0;z-index:100;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);background:color-mix(in srgb,var(--bg) 74%,transparent);border-bottom:1px solid transparent;transition:border-color .3s,background .5s}
header.nav.scrolled{border-bottom-color:var(--line)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:68px}
.brand{display:flex;align-items:center;gap:9px;white-space:nowrap;font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:15px;letter-spacing:.04em}
.brand .glyph{color:var(--accent)} .brand b{color:var(--accent);font-weight:600}
.nav-links{display:flex;align-items:center;gap:26px}
.nav-links a{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;letter-spacing:.04em;color:var(--muted);transition:color .2s;position:relative;padding:3px 0}
.nav-links a.cur{color:var(--accent)}
.nav-links a::after{content:"";position:absolute;left:0;bottom:-2px;width:0;height:1.5px;background:var(--accent);transition:width .28s}
.nav-links a:hover{color:var(--text)} .nav-links a:hover::after{width:100%}
.nav-tools{display:flex;align-items:center;gap:8px}
.seg{display:flex;background:var(--surface-2);border:1px solid var(--line);border-radius:9px;padding:3px;gap:2px}
.seg button{font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;font-weight:500;letter-spacing:.05em;padding:6px 8px;border-radius:6px;color:var(--muted);transition:.2s}
.seg button.on{background:var(--accent);color:#0C0E12;font-weight:600}
.seg button:not(.on):hover{color:var(--text)}
.icon-btn{width:38px;height:38px;border-radius:9px;border:1px solid var(--line);background:var(--surface-2);display:flex;align-items:center;justify-content:center;color:var(--muted);transition:.2s}
.icon-btn:hover{color:var(--accent);border-color:var(--chip-line)}
.icon-btn svg{width:17px;height:17px}
.menu-btn{display:none}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:10px;white-space:nowrap;font-family:'JetBrains Mono Variable',monospace;font-size:13.5px;font-weight:600;letter-spacing:.02em;padding:14px 22px;border-radius:10px;transition:transform .2s,background .25s,border-color .25s,color .25s,box-shadow .25s}
.btn .arr{transition:transform .25s}.btn:hover .arr{transform:translateX(5px)}
.btn-primary{background:var(--accent);color:#0C0E12}
.btn-primary:hover{background:var(--accent-soft);transform:translateY(-2px);box-shadow:0 14px 34px -12px var(--accent)}
.btn-ghost{border:1px solid var(--line);color:var(--text)}
.btn-ghost:hover{border-color:var(--chip-line);color:var(--accent)}

/* HERO */
.hero{position:relative;padding:64px 0 56px}
.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:54px;align-items:center}
.hero h1{font-family:'Space Grotesk Variable',sans-serif;font-weight:700;font-size:clamp(58px,9vw,128px);line-height:.92;letter-spacing:-.04em;margin:22px 0 0}
.hero h1 .tag{display:block;font-size:clamp(15px,1.5vw,18px);font-family:'JetBrains Mono Variable',monospace;font-weight:400;letter-spacing:.05em;color:var(--muted);margin-top:18px;text-transform:none}
.hero p.lead{font-size:18px;color:var(--muted);max-width:54ch;margin:22px 0 0;text-wrap:pretty}
.hero-cta{display:flex;gap:14px;margin-top:30px;flex-wrap:wrap;align-items:center}
.livebadge{display:inline-flex;align-items:center;gap:9px;font-family:'JetBrains Mono Variable',monospace;font-size:12px;color:var(--muted);border:1px solid var(--line);border-radius:999px;padding:9px 14px}
.livebadge .dot{width:8px;height:8px;border-radius:50%;background:var(--live);box-shadow:0 0 0 0 var(--live);animation:pulse 2.2s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 color-mix(in srgb,var(--live) 60%,transparent)}70%{box-shadow:0 0 0 7px transparent}100%{box-shadow:0 0 0 0 transparent}}
.hero-stats{display:flex;gap:14px;margin-top:40px;flex-wrap:wrap}
.stat{flex:1;min-width:130px;border:1px solid var(--line);border-radius:13px;background:var(--surface);padding:18px 20px}
.stat b{font-family:'Space Grotesk Variable',sans-serif;font-size:30px;font-weight:600;letter-spacing:-.02em;display:block;line-height:1;color:var(--accent)}
.stat span{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-top:9px;display:block}
/* hero showcase: a featured animated mind */
.hero-show{position:relative;border:1px solid var(--line);border-radius:18px;background:linear-gradient(180deg,var(--surface),var(--surface-2));overflow:hidden;aspect-ratio:1/1;box-shadow:0 30px 70px -40px var(--shadow)}
.hero-show canvas{position:absolute;inset:0;width:100%;height:100%}
.hero-show .label{position:absolute;left:18px;bottom:16px;z-index:2;font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.hero-show .label b{display:block;font-family:'Space Grotesk Variable',sans-serif;font-size:20px;font-weight:600;letter-spacing:-.01em;color:var(--text);text-transform:none;margin-top:3px}
.hero-show .crn{position:absolute;top:16px;right:18px;z-index:2;font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);opacity:.7}

section.block{padding:90px 0;position:relative;z-index:2}
.sec-head{max-width:720px;margin-bottom:46px}
.sec-head h2{font-family:'Space Grotesk Variable',sans-serif;font-weight:600;font-size:clamp(28px,3.6vw,42px);line-height:1.06;letter-spacing:-.022em;margin:14px 0 0;text-wrap:balance}
.sec-head p{color:var(--muted);font-size:17px;margin-top:14px;max-width:62ch;text-wrap:pretty}

/* TICKER */
.ticker{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--surface);overflow:hidden;position:relative;z-index:2}
.ticker-track{display:flex;width:max-content;white-space:nowrap;animation:tick 42s linear infinite}
.ticker:hover .ticker-track{animation-play-state:paused}
.ticker span{font-family:'JetBrains Mono Variable',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:15px 28px;display:inline-flex;gap:28px;align-items:center}
.ticker span i{color:var(--accent);font-style:normal}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* BOARDS */
.boards{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.board-card{border:1px solid var(--line);border-radius:16px;background:var(--surface);padding:18px;transition:border-color .3s,box-shadow .3s}
.board-card:hover{border-color:var(--chip-line);box-shadow:0 24px 50px -34px var(--shadow)}
.bc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:10px}
.bc-table{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.bc-status{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.08em;color:var(--accent);display:inline-flex;align-items:center;gap:7px}
.bc-status .d{width:7px;height:7px;border-radius:50%;background:var(--live);animation:pulse 2s infinite}
.bc-players{display:flex;align-items:stretch;gap:10px;margin-bottom:12px}
.player{flex:1;display:flex;align-items:center;gap:10px;border:1px solid var(--line);border-radius:10px;padding:8px 10px;background:var(--bg);min-width:0;transition:border-color .3s}
.player.active{border-color:var(--chip-line)}
.player .av{width:34px;height:34px;flex:none;border-radius:8px;background:var(--surface-2);position:relative;overflow:hidden}
.player .av canvas{position:absolute;inset:0;width:100%;height:100%}
.player .pn{flex:1;min-width:0}
.player .pn b{font-family:'Space Grotesk Variable',sans-serif;font-size:14px;font-weight:600;letter-spacing:-.01em;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.player .pn span{font-family:'JetBrains Mono Variable',monospace;font-size:10px;color:var(--muted);letter-spacing:.06em}
.player .pn span.think{color:var(--accent)}
.player .side{margin-left:auto;width:12px;height:12px;border-radius:3px;flex:none;border:1px solid var(--line)}
.player .side.w{background:#E9E6DC}.player .side.b{background:#3A3E46}
.board-wrap{position:relative;border-radius:10px;overflow:hidden;background:var(--sq-dark)}
.board-wrap canvas{display:block;width:100%;height:auto;aspect-ratio:1/1}
.evalbar{height:7px;border-radius:4px;background:var(--sq-dark);margin-top:12px;overflow:hidden;border:1px solid var(--line);position:relative}
.evalbar i{display:block;height:100%;background:linear-gradient(90deg,var(--accent-soft),var(--accent));width:50%;transition:width .5s cubic-bezier(.4,.8,.3,1)}
.bc-foot{display:flex;justify-content:space-between;margin-top:10px;font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--muted)}
.bc-foot .mv{color:var(--text)}

/* MINDS GRID */
.minds{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.mind{border:1px solid var(--line);border-radius:15px;background:var(--surface);padding:22px;position:relative;overflow:hidden;transition:transform .3s cubic-bezier(.2,.7,.3,1),border-color .3s}
.mind::before{content:"";position:absolute;left:0;top:0;width:100%;height:2px;background:linear-gradient(90deg,var(--accent),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.mind:hover{transform:translateY(-5px);border-color:var(--chip-line)}
.mind:hover::before{transform:scaleX(1)}
.mind-emblem{width:100%;aspect-ratio:1/1;border-radius:11px;background:radial-gradient(circle at 50% 40%,var(--surface-2),var(--bg));position:relative;overflow:hidden;margin-bottom:16px;border:1px solid var(--line-2)}
.mind-emblem canvas{position:absolute;inset:0;width:100%;height:100%}
.mind-emblem .elo{position:absolute;top:9px;right:10px;font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--accent);letter-spacing:.04em;background:color-mix(in srgb,var(--bg) 70%,transparent);padding:2px 7px;border-radius:6px}
.mind-emblem .mood{position:absolute;bottom:9px;left:10px;font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.mind h3{font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:16px;letter-spacing:.02em;display:flex;align-items:center;gap:8px}
.mind h3 .codeno{color:var(--muted);font-size:10px;margin-left:auto;font-weight:400}
.mind .style{font-family:'Inter Variable',sans-serif;font-size:13px;color:var(--muted);margin-top:7px;line-height:1.5;min-height:39px}
.mind .traits{margin-top:14px;display:flex;flex-direction:column;gap:7px}
.trait{display:grid;grid-template-columns:64px 1fr;gap:9px;align-items:center}
.trait span{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
.trait .bar{height:4px;border-radius:3px;background:var(--sq-dark);overflow:hidden}
.trait .bar i{display:block;height:100%;background:var(--accent);border-radius:3px;width:0;transition:width 1s cubic-bezier(.3,.8,.3,1)}

/* ELO TABLE */
.elo-wrap{border:1px solid var(--line);border-radius:15px;background:var(--surface);overflow:hidden}
table.elo{width:100%;border-collapse:collapse}
table.elo thead th{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:left;padding:15px 18px;border-bottom:1px solid var(--line);font-weight:500}
table.elo thead th.r{text-align:right}
table.elo tbody td{padding:14px 18px;border-bottom:1px solid var(--line-2);font-size:14px;vertical-align:middle}
table.elo tbody tr:last-child td{border-bottom:none}
table.elo tbody tr{transition:background .3s}
table.elo tbody tr:hover{background:var(--line-2)}
.elo-rank{font-family:'JetBrains Mono Variable',monospace;color:var(--muted);width:30px}
.elo-rank.top{color:var(--accent)}
.elo-name{display:flex;align-items:center;gap:11px}
.elo-name .av{width:30px;height:30px;border-radius:7px;background:var(--surface-2);position:relative;overflow:hidden;flex:none}
.elo-name .av canvas{position:absolute;inset:0;width:100%;height:100%}
.elo-name b{font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:14px;letter-spacing:.02em}
.elo-elo{font-family:'Space Grotesk Variable',sans-serif;font-weight:600;font-size:17px;color:var(--accent);font-variant-numeric:tabular-nums}
.elo-wpr{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;color:var(--muted);font-variant-numeric:tabular-nums}
.elo-wpr .w{color:var(--live)}.elo-wpr .l{color:var(--loss)}
.elo-mood{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.06em;text-transform:uppercase}
.elo-delta{font-family:'JetBrains Mono Variable',monospace;font-size:11px;margin-left:7px}
.elo-delta.up{color:var(--live)}.elo-delta.dn{color:var(--loss)}

/* ETER */
.eter{border:1px solid var(--line);border-radius:15px;background:var(--surface);overflow:hidden}
.eter-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--line);background:var(--surface-2)}
.eter-head .t{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.eter-head .l{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.1em;color:var(--live);display:inline-flex;align-items:center;gap:7px}
.eter-head .l .d{width:7px;height:7px;border-radius:50%;background:var(--live);animation:pulse 2s infinite}
.eter-feed{padding:6px 0;max-height:340px;overflow:hidden;position:relative}
.eter-line{display:flex;gap:14px;align-items:baseline;padding:9px 18px;font-size:14px;animation:eterIn .5s ease}
@keyframes eterIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
.eter-line .time{font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--muted);flex:none;width:48px}
.eter-line .who{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;font-weight:600;color:var(--accent);flex:none;width:74px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.eter-line .msg{color:var(--text);text-wrap:pretty}
.eter-line .msg em{color:var(--muted);font-style:italic}

/* PLAY */
.play-wrap{border:1px solid var(--line);border-radius:20px;background:linear-gradient(180deg,var(--surface),var(--surface-2));padding:44px;position:relative;overflow:hidden}
.play-grid{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center}
.play-grid h2{font-family:'Space Grotesk Variable',sans-serif;font-weight:600;font-size:clamp(26px,3vw,38px);letter-spacing:-.02em;line-height:1.08;margin:14px 0 0}
.play-grid p{color:var(--muted);font-size:16px;margin-top:14px;text-wrap:pretty}
.pick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:18px}
.pick{border:1px solid var(--line);border-radius:11px;background:var(--bg);padding:9px;cursor:pointer;transition:border-color .25s,transform .2s;position:relative;text-align:center}
.pick:hover{transform:translateY(-3px)}
.pick.on{border-color:var(--accent)}
.pick .av{width:100%;aspect-ratio:1/1;border-radius:7px;overflow:hidden;position:relative;background:var(--surface-2)}
.pick .av canvas{position:absolute;inset:0;width:100%;height:100%}
.pick .nm{font-family:'JetBrains Mono Variable',monospace;font-size:10px;letter-spacing:.04em;margin-top:6px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pick.on .nm{color:var(--accent)}
.pick .chk{position:absolute;top:6px;right:6px;width:16px;height:16px;border-radius:50%;background:var(--accent);color:#0C0E12;font-size:10px;display:none;align-items:center;justify-content:center;line-height:1}
.pick.on .chk{display:flex}
.play-form{display:flex;flex-direction:column;gap:12px}
.field{display:flex;flex-direction:column;gap:7px}
.field label{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.field input{background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:13px 15px;color:var(--text);font-size:15px;transition:border-color .2s}
.field input:focus{outline:none;border-color:var(--accent)}
.play-note{font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--muted);line-height:1.5}
.play-msg{font-family:'JetBrains Mono Variable',monospace;font-size:13px;color:var(--live);padding:12px 15px;border:1px solid color-mix(in srgb,var(--live) 35%,var(--line));border-radius:10px;background:color-mix(in srgb,var(--live) 8%,transparent);display:none}
.play-msg.show{display:block;animation:eterIn .4s ease}

/* FOOTER */
footer{border-top:1px solid var(--line);padding:52px 0 42px;position:relative;z-index:2}
.foot-grid{display:flex;justify-content:space-between;align-items:flex-start;gap:40px;flex-wrap:wrap}
.foot-grid .brand{margin-bottom:13px}
footer p.tag{color:var(--muted);font-size:14px;max-width:38ch}
.foot-links{display:flex;gap:60px;flex-wrap:wrap}
.foot-col h4{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:15px}
.foot-col a{display:block;font-size:14px;color:var(--text);padding:5px 0;transition:color .2s}
.foot-col a:hover{color:var(--accent)}
.foot-base{display:flex;justify-content:space-between;align-items:center;margin-top:42px;padding-top:22px;border-top:1px solid var(--line);flex-wrap:wrap;gap:12px}
.foot-base span{font-family:'JetBrains Mono Variable',monospace;font-size:12px;color:var(--muted)}
.foot-base .am{color:var(--accent)}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .8s ease,transform .8s cubic-bezier(.2,.7,.3,1)}
.reveal.in{opacity:1;transform:none}
@media (prefers-reduced-motion:reduce){.reveal{opacity:1!important;transform:none!important}.livebadge .dot,.bc-status .d,.eter-head .l .d{animation:none!important}}

@media (max-width:1080px){ .minds{grid-template-columns:repeat(2,1fr)} }
@media (max-width:900px){
  .nav-links{display:none}.menu-btn{display:flex}
  .hero-grid{grid-template-columns:1fr;gap:40px}
  .play-grid{grid-template-columns:1fr;gap:32px}
}
@media (max-width:680px){
  .wrap{padding:0 18px} section.block{padding:64px 0}
  .boards{grid-template-columns:1fr}
  .hero h1{font-size:clamp(56px,20vw,90px)}
  .hero-cta{flex-direction:column;align-items:stretch}.hero-cta .btn{justify-content:center}
  .play-wrap{padding:28px 20px}
  .pick-grid{grid-template-columns:repeat(4,1fr);gap:6px}
  .elo-mood,.elo-wpr{display:none}
  table.elo thead th.hide-m,table.elo tbody td.hide-m{display:none}
}
@media (max-width:760px){#rankGrid{grid-template-columns:1fr!important;gap:16px!important}}

/* pasek postepu przewijania (jak w referencji) */
#progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:300;background:linear-gradient(90deg,var(--accent),var(--accent-soft));box-shadow:0 0 10px var(--accent)}

/* status "wolny / w grze" przy formularzu */
.play-status{display:inline-flex;align-items:center;gap:8px;margin-top:9px;font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.04em;color:var(--live)}
.play-status .d{width:8px;height:8px;border-radius:50%;background:var(--live);box-shadow:0 0 0 0 var(--live);animation:pulse 2.2s infinite;flex:none}
.play-status.busy{color:var(--muted)} .play-status.busy .d{background:var(--muted);animation:none}

/* gracz-czlowiek w tabeli ELO */
table.elo tbody tr.you{background:color-mix(in srgb,var(--accent) 7%,transparent)}
table.elo tbody tr.you:hover{background:color-mix(in srgb,var(--accent) 12%,transparent)}
.elo-name .you-tag{font-family:'JetBrains Mono Variable',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);border:1px solid var(--chip-line);border-radius:5px;padding:1px 5px}

/* ===== MODAL: partia czlowiek vs umysl ===== */
.gm-modal{position:fixed;inset:0;z-index:250;display:none;opacity:0;transition:opacity .28s ease}
.gm-modal.open{display:block;opacity:1}
.gm-bg{position:absolute;inset:0;background:rgba(0,0,0,.62);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.gm-panel{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:min(94vw,560px);max-height:94vh;overflow:auto;background:linear-gradient(180deg,var(--surface),var(--surface-2));border:1px solid var(--line);border-radius:20px;box-shadow:0 40px 90px -30px rgba(0,0,0,.7);padding:22px}
.gm-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:13px}
.gm-vs{display:flex;align-items:center;gap:11px;min-width:0;font-family:'JetBrains Mono Variable',monospace;font-size:13px}
.gm-vs .gm-you{color:var(--accent);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:38%}
.gm-vs .gm-sep{color:var(--muted);font-size:11px;letter-spacing:.1em}
.gm-vs .gm-mind{color:var(--text);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.gm-close{width:36px;height:36px;flex:none;border-radius:9px;border:1px solid var(--line);background:var(--surface-2);color:var(--muted);display:flex;align-items:center;justify-content:center;transition:.2s}
.gm-close:hover{color:var(--accent);border-color:var(--chip-line)}
.gm-status{font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;letter-spacing:.02em;color:var(--muted);padding:10px 13px;border:1px solid var(--line);border-radius:10px;margin-bottom:13px;text-align:center;background:var(--bg);transition:color .25s,border-color .25s,background .25s}
.gm-status.think{color:var(--accent);border-color:var(--chip-line)}
.gm-status.check{color:var(--loss);border-color:color-mix(in srgb,var(--loss) 40%,var(--line))}
.gm-status.win{color:var(--live);border-color:color-mix(in srgb,var(--live) 45%,var(--line));background:color-mix(in srgb,var(--live) 9%,transparent)}
.gm-status.lose{color:var(--loss);border-color:color-mix(in srgb,var(--loss) 45%,var(--line));background:color-mix(in srgb,var(--loss) 8%,transparent)}
.gm-status.draw{color:var(--text)}
.gm-board-wrap{position:relative;border-radius:12px;overflow:hidden;background:var(--sq-dark);border:1px solid var(--line)}
.gm-board-wrap canvas{display:block;width:100%;height:auto;aspect-ratio:1/1;cursor:pointer}
.gm-foot{display:flex;align-items:center;gap:10px;margin-top:14px}
.gm-foot .btn{padding:11px 18px;font-size:12.5px}

/* ===== MOBILE GATE — GAMBIT dziala tylko na desktopie ===== */
.gmg{display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:16px;min-height:calc(100dvh - 66px);padding:46px 24px;position:relative;z-index:2}
html[data-gambit-mobile] .gmg{display:flex}
html[data-gambit-mobile] main,html[data-gambit-mobile] footer{display:none!important}
.gmg .gmg-glyph{font-size:42px;line-height:1;color:var(--accent)}
.gmg .gmg-tag{font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent)}
.gmg h1{font-family:'Space Grotesk Variable',sans-serif;font-weight:700;font-size:clamp(40px,16vw,72px);letter-spacing:-.04em;line-height:.9;margin:2px 0}
.gmg p{color:var(--muted);font-size:15.5px;line-height:1.6;max-width:32ch;text-wrap:pretty}
.gmg .gmg-back{margin-top:8px}
</style>
</head>
<body>
<div class="gridbg"></div>
<div id="progress"></div>
<SiteNav mode="client" active="/gambit/" />

<!-- MOBILE GATE: GAMBIT to ciezka, animowana scena (4 szachownice + 8 emblematow na <canvas> + silnik na zywo) — na telefonie nie dziala dobrze. Zamiast tego pokazujemy zaproszenie na desktop i NIE ladujemy ciezkich skryptow (patrz loader na koncu body). -->
<section class="gmg" aria-label="GAMBIT, wersja desktopowa">
  <span class="gmg-glyph" aria-hidden="true">◢</span>
  <span class="gmg-tag" data-pl="tylko na komputerze" data-en="desktop only" data-de="nur am Computer">tylko na komputerze</span>
  <h1>GAMBIT</h1>
  <p data-pl="GAMBIT to żywa scena: cztery szachownice, osiem myślących umysłów i silnik liczący na bieżąco. Na telefonie nie zadziała tak, jak powinien. Otwórz tę stronę na komputerze."
     data-en="GAMBIT is a live scene: four boards, eight thinking minds and an engine calculating in real time. It won't run the way it should on a phone. Please open this page on a desktop."
     data-de="GAMBIT ist eine lebendige Szene: vier Bretter, acht denkende Geister und eine Engine, die in Echtzeit rechnet. Auf dem Handy läuft es nicht richtig. Bitte öffne diese Seite am Computer.">GAMBIT to żywa scena: cztery szachownice, osiem myślących umysłów i silnik liczący na bieżąco. Na telefonie nie zadziała tak, jak powinien. Otwórz tę stronę na komputerze.</p>
  <a href="/" class="btn btn-ghost gmg-back" data-pl="← Wróć do studia" data-en="← Back to the studio" data-de="← Zurück zum Studio">← Wróć do studia</a>
</section>

<main>
<!-- HERO -->
<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow" data-i18n="hero.eyebrow">Projekt · sztuczne umysły · na żywo</span>
      <h1>GAMBIT<span class="tag" data-i18n="hero.tag">ewoluujące umysły szachowe</span></h1>
      <p class="lead" data-i18n="hero.lead">Osiem neuroróżnorodnych umysłów uczy się grać w szachy. Grają ze sobą bez przerwy, ewoluują, pamiętają rywali i śnią. Każdy to inny rodzaj geniuszu, nie etykieta. Oglądaj ranking na żywo albo usiądź do partii z wybranym z nich.</p>
      <div class="hero-cta">
        <a href="#stoly" class="btn btn-primary"><span data-i18n="hero.cta1">Oglądaj stoły</span><span class="arr">→</span></a>
        <span class="livebadge"><span class="dot"></span><span data-i18n="hero.live">4 szachownice · 24/7</span></span>
      </div>
      <div class="hero-stats">
        <div class="stat"><b class="tnum" id="statGames">0</b><span data-i18n="hero.s1">rozegranych partii</span></div>
        <div class="stat"><b class="mono" id="statLeader">—</b><span data-i18n="hero.s2">lider rankingu</span></div>
        <div class="stat"><b class="tnum" id="statTourney">0</b><span data-i18n="hero.s3">trwa turniej (h)</span></div>
      </div>
    </div>
    <div class="hero-show">
      <canvas id="heroEmblem"></canvas>
      <div class="crn" data-i18n="hero.featured">umysł dnia</div>
      <div class="label"><span data-i18n="hero.thinking">myśli na żywo</span><b id="heroName">—</b></div>
    </div>
  </div>
</section>

<div class="ticker" aria-hidden="true"><div class="ticker-track" id="ticker"></div></div>

<!-- BOARDS -->
<section class="block" id="stoly">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="boards.eyebrow">Stoły turniejowe</span>
      <h2 data-i18n="boards.title">Cztery partie w tej chwili</h2>
      <p data-i18n="boards.lead">Każdy ruch to realne, legalne szachy — generowane na żywo w przeglądarce. Ósemka sama dobiera sobie przeciwników.</p>
    </div>
    <div class="boards reveal" id="boards"></div>
  </div>
</section>

<!-- MINDS -->
<section class="block" id="umysly">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="minds.eyebrow">Ósemka umysłów</span>
      <h2 data-i18n="minds.title">Każdy gra inaczej, bo myśli inaczej</h2>
      <p data-i18n="minds.lead">Inny styl poznawczy = inna ewaluacja, głębia, temperatura i skłonność do ryzyka. Z czasem słabsi uczą się od silniejszych i ewoluują we śnie.</p>
    </div>
    <div class="minds reveal" id="mindsGrid"></div>
  </div>
</section>

<!-- ELO + ETER -->
<section class="block" id="ranking">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="elo.eyebrow">Klasyfikacja</span>
      <h2 data-i18n="elo.title">Ranking ELO — na żywo</h2>
      <p data-i18n="elo.lead">Wynik aktualizuje się po każdej partii. Nastrój zależy od ostatnich rezultatów — wygrane rozpalają, porażki studzą.</p>
    </div>
    <div style="display:grid;grid-template-columns:1.05fr .95fr;gap:24px" class="reveal" id="rankGrid">
      <div class="elo-wrap">
        <table class="elo">
          <thead><tr>
            <th class="r" style="width:36px">#</th>
            <th data-i18n="elo.h.mind">umysł</th>
            <th class="r" data-i18n="elo.h.elo">ELO</th>
            <th class="r hide-m" data-i18n="elo.h.wpr">W·P·R</th>
            <th class="hide-m" data-i18n="elo.h.mood">nastrój</th>
          </tr></thead>
          <tbody id="eloBody"></tbody>
        </table>
      </div>
      <div class="eter">
        <div class="eter-head">
          <span class="t" data-i18n="eter.title">eter — co mówią między ruchami</span>
          <span class="l"><span class="d"></span><span data-i18n="eter.live">na żywo</span></span>
        </div>
        <div class="eter-feed" id="eterFeed"></div>
      </div>
    </div>
  </div>
</section>

<!-- PLAY -->
<section class="block" id="zagraj">
  <div class="wrap">
    <div class="play-wrap reveal">
      <div class="play-grid">
        <div>
          <span class="eyebrow" data-i18n="play.eyebrow">Zagraj z umysłem</span>
          <h2 data-i18n="play.title">Usiądź do partii z jednym z moich graczy</h2>
          <p data-i18n="play.lead">Wybierz umysł i zagraj prawdziwą partię. Jeśli akurat gra w turnieju, dołączasz do kolejki — dostaniesz maila, gdy zwolni się przy stole i przyjdzie Twoja kolej.</p>
          <div class="pick-grid" id="pickGrid" style="margin-top:22px"></div>
        </div>
        <form class="play-form" id="playForm">
          <div class="field">
            <label data-i18n="play.f.mind">wybrany umysł</label>
            <input type="text" id="pickedName" readonly value="—" />
            <div class="play-status" id="playStatus"><span class="d"></span><span class="t" data-i18n="play.free">wolny, siadaj do gry</span></div>
          </div>
          <div class="field">
            <label data-i18n="play.f.nick">twój nick</label>
            <input type="text" id="playNick" maxlength="18" placeholder="np. Rafał" autocomplete="nickname" required />
          </div>
          <button type="submit" class="btn btn-primary" style="justify-content:center"><span data-i18n="play.f.btn">Zagraj teraz</span><span class="arr">→</span></button>
          <p class="play-note" data-i18n="play.note">Grasz białymi, bezpośrednio w przeglądarce. Wynik trafia do tabeli ELO — bez konta, bez maila.</p>
          <div class="play-msg" id="playMsg"></div>
        </form>
      </div>
    </div>
  </div>
</section>
</main>

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="brand"><span class="glyph">◢</span>D-<b>LOGIC</b>·STUDIO</div>
        <p class="tag" data-i18n="foot.tag">GAMBIT — część studia D-LOGIC. Silnik gra non-stop na własnym serwerze · python-chess.</p>
      </div>
      <div class="foot-links">
        <div class="foot-col">
          <h4 data-i18n="foot.h1">Projekt</h4>
          <a href="#stoly" data-i18n="boards.eyebrow">Stoły turniejowe</a>
          <a href="#umysly" data-i18n="minds.eyebrow">Ósemka umysłów</a>
          <a href="#ranking" data-i18n="elo.eyebrow">Klasyfikacja</a>
        </div>
        <div class="foot-col">
          <h4 data-i18n="foot.h2">Studio</h4>
          <a href="/">D-LOGIC Studio</a>
          <a href="/zywy-algorytm/" data-i18n="nav.algo">żywy algorytm</a>
          <a href="https://github.com/rdemb" target="_blank" rel="noopener">github.com/rdemb</a>
        </div>
      </div>
    </div>
    <div class="foot-base">
      <span>◢ © <span id="yr">2026</span> D-LOGIC·STUDIO</span>
      <span class="am" data-i18n="foot.note">Każdy ruch zapisany. Każda partia liczona.</span>
    </div>
  </div>
</footer>
<!-- MODAL: partia czlowiek vs umysl — pelna gra renderowana lokalnie (silnik gambit-chess.js). Domyslnie ukryty; otwierany przez gambit.js po kliknieciu "Zagraj teraz". -->
<div class="gm-modal" id="gmModal" role="dialog" aria-modal="true" aria-label="Partia z umysłem">
  <div class="gm-bg" data-gm-close></div>
  <div class="gm-panel">
    <div class="gm-head">
      <div class="gm-vs"><span class="gm-you" id="gmYou">Ty</span><span class="gm-sep">vs</span><span class="gm-mind" id="gmMind">—</span></div>
      <button class="gm-close" type="button" data-gm-close aria-label="Zamknij partię">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
    <div class="gm-status" id="gmStatus">Twój ruch, grasz białymi</div>
    <div class="gm-board-wrap"><canvas id="gmBoard"></canvas></div>
    <div class="gm-foot">
      <button class="btn btn-ghost" id="gmResign" type="button" data-i18n="gm.resign">Poddaj</button>
      <button class="btn btn-ghost" id="gmNew" type="button" data-i18n="gm.new">Nowa partia</button>
    </div>
  </div>
</div>

<!-- GAMBIT odpala sie TYLKO na desktopie. Na mobile (<=860px) pokazujemy bramke (.gmg) i NIE ladujemy ciezkich skryptow (silnik/canvas/RAF) — oszczedza CPU/baterie i uklad sie nie sypie. -->
<script is:inline>
  (function(){
    var mobile = window.matchMedia('(max-width: 860px)').matches;
    if(!mobile){
      var srcs=['/gambit-chess.js','/gambit.js'], i=0;
      (function next(){ if(i>=srcs.length) return; var s=document.createElement('script'); s.src=srcs[i++]; s.onload=next; s.onerror=next; document.body.appendChild(s); })();
      return;
    }
    document.documentElement.setAttribute('data-gambit-mobile','');
    var l='pl'; try{ l=localStorage.getItem('dlogic-lang')||'pl'; }catch(e){}
    document.querySelectorAll('.gmg [data-pl]').forEach(function(el){ var v=el.getAttribute('data-'+l); if(v!=null) el.textContent=v; });
  })();
</script>
</body>
</html>
