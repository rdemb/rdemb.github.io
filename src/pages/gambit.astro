  foot:"die Engine spielt rund um die Uhr auf eigenem Server · python-chess", min:"Min", busy:"am Tisch", free:"frei", play:"spielen", queue:"in der Schlange"},
};
let LANG=(()=>{try{return localStorage.getItem("dlogic-lang")||"pl"}catch(e){return"pl"}})();
function applyLang(l){
  LANG=l; try{localStorage.setItem("dlogic-lang",l)}catch(e){}
  document.documentElement.lang=l;
  const d=I18N[l]||I18N.pl;
  document.querySelectorAll("[data-i18n]").forEach(e=>{const v=d[e.getAttribute("data-i18n")];if(v!=null)e.textContent=v;});
  document.querySelectorAll("[data-i18n-ph]").forEach(e=>{const v=d[e.getAttribute("data-i18n-ph")];if(v!=null)e.setAttribute("placeholder",v);});
  document.querySelectorAll("[data-pl],[data-de],[data-en]").forEach(e=>{const v=e.getAttribute("data-"+l);if(v!=null)e.textContent=v;});
  document.querySelectorAll('#lang [data-lang]').forEach(b=>b.classList.toggle("on",b.getAttribute("data-lang")===l));
  if(window.__G) render(window.__G);
}
document.addEventListener("click",e=>{const b=e.target.closest('#lang [data-lang]');if(b){e.preventDefault();applyLang(b.getAttribute("data-lang"));}});

/* ---------- render szachownicy z FEN ---------- */
const GLYPH={k:"♚",q:"♛",r:"♜",b:"♝",n:"♞",p:"♟"};
function boardHTML(fen,lastUci){
  const rows=fen.split(" ")[0].split("/");
  const from=lastUci&&lastUci.length>=4?lastUci.slice(0,2):null, to=lastUci&&lastUci.length>=4?lastUci.slice(2,4):null;
  let html="";
  for(let r=0;r<8;r++){
    let file=0;
    for(const ch of rows[r]){
      if(/\d/.test(ch)){ for(let i=0;i<+ch;i++){ html+=sq(r,file,null); file++; } }
      else { html+=sq(r,file,ch,from,to); file++; }
    }
  }
  return html;
}
function sq(r,f,ch,from,to){
  const dark=(r+f)%2===1; const coord="abcdefgh"[f]+(8-r);
  const hl=(coord===from||coord===to)?" hl":"";
  let pc="";
  if(ch){const w=ch===ch.toUpperCase();pc=`<span class="pc ${w?'w':'b'}">${GLYPH[ch.toLowerCase()]}</span>`;}
  return `<div class="sq ${dark?'d':'l'}${hl}">${pc}</div>`;
}

/* ---------- pobieranie danych ---------- */
let _base=null;
async function fetchData(){
  try{
    if(_base===null){const j=await (await fetch("/pracownia-demos.json",{cache:"no-store"})).json();_base=(j.base||"").replace(/\/+$/,"");}
    if(!_base) return null;
    return await (await fetch(_base+"/_live/chess.json",{cache:"no-store"})).json();
  }catch(e){return null;}
}

function render(d){
  window.__G=d; const t=I18N[LANG]||I18N.pl;
  const by={}; d.agents.forEach(a=>by[a.id]=a);
  // hero stats
  const lead=by[d.ranking[0]];
  document.getElementById("st-games").textContent=d.totalGames;
  document.getElementById("st-leader").textContent=lead?lead.glyph+" "+lead.name:"—";
  document.getElementById("st-age").textContent=Math.max(1,Math.round((d.t-d.since)/60))+" "+t.min;
  // boards
  document.getElementById("boards").innerHTML=d.boards.sort((a,b)=>a.id-b.id).map(b=>{
    const w=by[b.white],bl=by[b.black];const ev=Math.max(-8,Math.min(8,b.evalcp||0));
    const lw=50+ev/16*100; // pasek przewagi
    return `<div class="bcard">
      <div class="bcard__top">
        <span class="bp"><span class="bp__g" style="background:color-mix(in oklab,${w.color} 20%,transparent);color:${w.color}">${w.glyph}</span><span class="bp__n">${w.name}</span></span>
        <span class="bp__vs">vs</span>
        <span class="bp" style="justify-content:flex-end"><span class="bp__n" style="text-align:right">${bl.name}</span><span class="bp__g" style="background:color-mix(in oklab,${bl.color} 20%,transparent);color:${bl.color}">${bl.glyph}</span></span>
      </div>
      <div class="evalbar"><i style="left:${Math.min(lw,50)}%;width:${Math.abs(lw-50)}%"></i></div>
      <div class="board">${boardHTML(b.fen,b.lastUci)}</div>
      <div class="bcard__foot"><span>${b.ply} ${LANG==='de'?'Halbzüge':(LANG==='en'?'plies':'półruchów')}</span><span>${b.check?'<span class="chk">szach</span> · ':''}${b.lastSan||'—'}</span></div>
    </div>`;
  }).join("");
  // roster
  document.getElementById("roster").innerHTML=d.agents.map(a=>{
    const busy=a.playing!=null;
    return `<div class="mind" style="--mc:${a.color}">
      <span class="mind__bar"></span>
      <div class="mind__top"><span class="mind__g">${a.glyph}</span><span class="mind__id"><b>${a.name}</b><span>${a.arch}</span></span></div>
      <div class="mind__desc">${(a.desc&&(a.desc[LANG]||a.desc.pl))||""}</div>
      <div class="mind__stats">
        <div class="ms"><b>${a.elo}</b><span>ELO</span></div>
        <div class="ms"><b>${a.w}·${a.l}·${a.d}</b><span>W·P·R</span></div>
        <div class="ms"><b>${Math.round((a.skill||0)*100)}</b><span>skill</span></div>
      </div>
      <div class="mind__foot"><span class="mood">${a.mood}</span><span class="energy"><i style="width:${Math.round((a.energy||0)*100)}%"></i></span><button class="playbtn ${busy?'busy':''}" data-play="${a.id}">${busy?t.busy:t.play} →</button></div>
    </div>`;
  }).join("");
  // ranking
  document.getElementById("rankbody").innerHTML=d.ranking.map((id,i)=>{const a=by[id];return `<tr>
    <td>${i+1}</td>
    <td><span class="nm"><i style="background:color-mix(in oklab,${a.color} 22%,transparent);color:${a.color}">${a.glyph}</i>${a.name}</span></td>
    <td class="elo">${a.elo}</td><td class="wld">${a.w}·${a.l}·${a.d}</td><td class="mood" style="background:none;padding:0;color:var(--bone-soft);font-family:var(--mono);font-size:.78rem">${a.mood}</td></tr>`;}).join("");
  // chat (najnowsze na dole)
  const ch=document.getElementById("chat");
  ch.innerHTML=(d.chat||[]).slice(-16).map(c=>{const a=by[c.by];if(!a)return"";
    const msg = (typeof c.msg==='string')?c.msg:((c.msg&&(c.msg[LANG]||c.msg.pl))||'');
    const dl = ({pl:'sen',en:'dream',de:'Traum'})[LANG]||'sen';
    return `<div class="cmsg ${c.kind==='dream'?'dream':''}"><i style="background:color-mix(in oklab,${a.color} 22%,transparent);color:${a.color}">${a.glyph}</i><span><b>${a.name}</b>${c.kind==='dream'?` <span class="k">${dl}</span>`:''} — ${msg}</span></div>`;}).join("");
  ch.scrollTop=ch.scrollHeight;
  // play select
  const sel=document.getElementById("pSel");
  if(sel.dataset.n!=String(d.agents.length)){ sel.dataset.n=String(d.agents.length);
    sel.innerHTML=d.agents.map(a=>`<option value="${a.id}">${a.glyph} ${a.name} — ${a.arch}</option>`).join(""); }
}

/* play (na razie kolejka / placeholder do backendu) */
document.getElementById("pBtn").addEventListener("click",()=>{
  const t=I18N[LANG]||I18N.pl; const mail=document.getElementById("pMail").value.trim();
  const note=document.getElementById("pNote");
  if(!mail||!/.+@.+\..+/.test(mail)){ note.textContent=({pl:"Podaj poprawny e-mail.",en:"Enter a valid email.",de:"Gültige E-Mail eingeben."})[LANG]; return; }
  note.textContent=({pl:"Zapisuję do kolejki… (uruchamiamy rozgrywkę wkrótce)",en:"Adding you to the queue… (play launching soon)",de:"Du kommst in die Schlange… (Spiel startet bald)"})[LANG];
});
document.addEventListener("click",e=>{const b=e.target.closest("[data-play]");if(b){document.getElementById("pSel").value=b.getAttribute("data-play");document.getElementById("play")||document.querySelector(".play").scrollIntoView({behavior:"smooth",block:"center"});document.getElementById("pMail").focus();}});

/* loop */
async function tick(){const d=await fetchData();if(d)render(d);}
applyLang(LANG); tick(); setInterval(tick,2200);
</script>
</body>
</html>
