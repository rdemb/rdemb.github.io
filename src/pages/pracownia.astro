    'lab.title': "Things you can <span class='hl'>touch.</span>",
    'lab.lead': 'Interactive demos. Each one is proof that something works, not a promise. Start by moving your mouse across the field below.',
    'lab.hint': 'move your cursor',
    'lab.grid.head': 'What is being built here',
    'lab.c1.k': '01 · 3D / WebGL', 'lab.c1.t': 'Signal field', 'lab.c1.d': 'An interactive 3D field rendered live in your browser, the one above. It reacts to the cursor.', 'lab.c1.s': 'live',
    'lab.c2.k': '02 · data', 'lab.c2.t': 'Dashboard: drop one file', 'lab.c2.d': 'Upload your CSV and see an honest visualization with explicit uncertainty. No login, computed locally in your browser.', 'lab.c2.s': 'soon',
    'lab.c3.k': '03 · web', 'lab.c3.t': 'Sites: from minimal to 3D', 'lab.c3.d': 'Diverse templates and work. Clean minimalism, immersive 3D, multilingual PL/DE/EN.', 'lab.c3.s': 'soon',
    'lab.c4.k': '04 · community', 'lab.c4.t': 'A mini portal for groups', 'lab.c4.d': 'A light portal for small communities, clubs and companies. A place, posts, people. A concept in progress.', 'lab.c4.s': 'concept',
    'lab.foot': 'An idea for something not here yet? Write to me, I will build a demo.',
  },
  de: {
    'lab.eyebrow': 'Werkstatt',
    'lab.title': "Dinge, die man <span class='hl'>anfassen</span> kann.",
    'lab.lead': 'Interaktive Demos. Jede ist ein Beweis, dass etwas funktioniert, kein Versprechen. Beweg zuerst die Maus über das Feld unten.',
    'lab.hint': 'beweg den Cursor',
    'lab.grid.head': 'Was hier entsteht',
    'lab.c1.k': '01 · 3D / WebGL', 'lab.c1.t': 'Signalfeld', 'lab.c1.d': 'Ein interaktives 3D-Feld, live im Browser gerendert, das oben. Es reagiert auf den Cursor.', 'lab.c1.s': 'live',
    'lab.c2.k': '02 · Daten', 'lab.c2.t': 'Dashboard: eine Datei rein', 'lab.c2.d': 'Lade deine CSV hoch und sieh eine ehrliche Visualisierung mit klarer Unsicherheit. Kein Login, lokal im Browser berechnet.', 'lab.c2.s': 'bald',
    'lab.c3.k': '03 · Web', 'lab.c3.t': 'Seiten: von minimal bis 3D', 'lab.c3.d': 'Vielfältige Vorlagen und Arbeiten. Klares Minimal, immersives 3D, mehrsprachig DE/PL/EN.', 'lab.c3.s': 'bald',
    'lab.c4.k': '04 · Community', 'lab.c4.t': 'Ein Mini-Portal für Gruppen', 'lab.c4.d': 'Ein leichtes Portal für kleine Communities, Vereine und Firmen. Ein Ort, Beiträge, Menschen. Ein Konzept in Arbeit.', 'lab.c4.s': 'Konzept',
