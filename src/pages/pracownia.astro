 try{localStorage.setItem(KEY,l);}catch(e){}}
function init(){let l="pl";try{const s=localStorage.getItem(KEY);if(s&&SUP.includes(s))l=s;}catch(e){}apply(l);
 document.addEventListener("click",e=>{const b=e.target.closest("[data-lang]");if(!b)return;e.preventDefault();apply(b.getAttribute("data-lang"));});}
g.DLi18n={apply,get(){try{return localStorage.getItem(KEY)||"pl";}catch(e){return "pl";}}};
if(document.readyState!=="loading")init();else document.addEventListener("DOMContentLoaded",init);
