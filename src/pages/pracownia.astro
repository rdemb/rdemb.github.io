      pal:["#0f1b2d","#c6f04a","#f5c518"], pp:{bg:"#0f1b2d",bar:"#16263f",hero:"#0f1b2d",acc:"#c6f04a",ink:"#f4f6f8"} },
    { id:"fracht", name:"FRACHT", href:"FRACHT.html", live:true, cms:"fracht-studio.html", cmsLabel:{pl:"Panel dyspozytora",de:"Dispo-Panel"},
      ind:{pl:"Spedycja · logistyka kontraktowa",de:"Spedition · Kontraktlogistik"},
      desc:{pl:"Śledzenie przesyłek na żywo, wyceny, magazyn.",de:"Live-Sendungsverfolgung, Angebote, Lager."},
      pal:["#1c2128","#ff6a1f","#f3f5f7"], pp:{bg:"#1c2128",bar:"#2a313b",hero:"#1c2128",acc:"#ff6a1f",ink:"#f3f5f7"} },
    { id:"zaczyn", name:"ZACZYN", href:"ZACZYN.html", live:true, cms:"zaczyn-studio.html", cmsLabel:{pl:"Panel zamówień",de:"Bestell-Panel"},
      ind:{pl:"Piekarnia rzemieślnicza · na zakwasie",de:"Handwerksbäckerei · Sauerteig"},
      desc:{pl:"Katalog wypieków, koszyk przedsprzedaży świątecznej.",de:"Backwaren-Katalog, Vorbestellungs-Korb."},
      pal:["#7a4a22","#e8a33d","#f7efe1"], pp:{bg:"#5a3416",bar:"#7a4a22",hero:"#5a3416",acc:"#e8a33d",ink:"#f7efe1"} },
    { id:"dentis", name:"DENTIS", href:"DENTIS.html", live:true, cms:"dentis-studio.html", cmsLabel:{pl:"Panel rejestracji",de:"Empfangs-Panel"},
      ind:{pl:"Stomatologia · klinika dentystyczna",de:"Zahnmedizin · Zahnklinik"},
      desc:{pl:"Cennik, zespół, rezerwacja wizyt online z wyborem godziny.",de:"Preise, Team, Online-Terminbuchung."},
      pal:["#1bb6c1","#143a52","#f0f8f9"], pp:{bg:"#143a52",bar:"#1d5066",hero:"#143a52",acc:"#1bb6c1",ink:"#f0f8f9"} },
    { id:"sloj", name:"SŁÓJ", href:"S%C5%81%C3%93J.html", live:true, cms:"sloj-studio.html", cmsLabel:{pl:"Panel wycen",de:"Angebots-Panel"},
      ind:{pl:"Stolarnia · meble na wymiar",de:"Tischlerei · Möbel nach Maß"},
      desc:{pl:"Konfigurator mebla z wyceną na żywo, galeria realizacji.",de:"Möbelkonfigurator mit Live-Preis, Projektgalerie."},
      pal:["#5a3a22","#b8895a","#f4ece0"], pp:{bg:"#2a1c10",bar:"#5a3a22",hero:"#3a2410",acc:"#b8895a",ink:"#f4ece0"} },
