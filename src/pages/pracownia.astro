---
import Chrome from '../components/Chrome.astro';
import { withUi } from '../i18n';

const dict = withUi({
  pl: {
    'lab.eyebrow': 'Przykładowe strony',
    'lab.title': "Tak może wyglądać <span class='hl'>Twoja strona.</span>",
    'lab.lead': 'Kompletne przykłady dla różnych branż, od pierwszego ekranu po stopkę. Wybierz tę, która pasuje do Ciebie, i zobacz gotowy kierunek, który dopasuję do Twojej marki.',
    'lab.grid.head': 'Wybierz branżę',
    'lab.shop.t': 'Butik / sklep internetowy', 'lab.shop.d': 'Pełny sklep: ekspozycja, kategorie, koszyk. Elegancki, gotowy do wypełnienia Twoimi produktami.', 'lab.shop.s': 'zobacz przykład',
    'lab.rest.t': 'Restauracja', 'lab.rest.d': 'Apetyczny landing: menu, atmosfera, rezerwacja. Ciepły, zmysłowy, lokalny.', 'lab.rest.s': 'wkrótce',
    'lab.serv.t': 'Usługi lokalne', 'lab.serv.d': 'Strona rzemieślnika lub firmy usługowej: zaufanie, realizacje, szybki kontakt. PL i DE.', 'lab.serv.s': 'wkrótce',
    'lab.clin.t': 'Gabinet / klinika', 'lab.clin.d': 'Spokojna, czysta strona dla zdrowia i urody: usługi, zespół, rezerwacja wizyt.', 'lab.clin.s': 'wkrótce',
    'lab.foot': 'Twojej branży tu nie ma? Napisz, a dorobię przykład skrojony pod Ciebie.',
  },
  en: {
    'lab.eyebrow': 'Example sites',
    'lab.title': "This could be <span class='hl'>your site.</span>",
    'lab.lead': 'Complete examples for different industries, from the first screen to the footer. Pick the one that fits you and see a ready direction that I will tailor to your brand.',
    'lab.grid.head': 'Choose an industry',
    'lab.shop.t': 'Boutique / online store', 'lab.shop.d': 'A full shop: showcase, categories, cart. Elegant, ready to fill with your products.', 'lab.shop.s': 'see the example',
    'lab.rest.t': 'Restaurant', 'lab.rest.d': 'An appetising landing: menu, atmosphere, booking. Warm, sensual, local.', 'lab.rest.s': 'soon',
    'lab.serv.t': 'Local services', 'lab.serv.d': 'A site for a tradesperson or service firm: trust, work, fast contact. PL and DE.', 'lab.serv.s': 'soon',
    'lab.clin.t': 'Practice / clinic', 'lab.clin.d': 'A calm, clean site for health and beauty: services, team, appointment booking.', 'lab.clin.s': 'soon',
    'lab.foot': 'Your industry not here? Write to me and I will add an example tailored to you.',
  },
  de: {
    'lab.eyebrow': 'Beispielseiten',
    'lab.title': "So könnte <span class='hl'>deine Seite</span> aussehen.",
    'lab.lead': 'Komplette Beispiele für verschiedene Branchen, vom ersten Bildschirm bis zur Fußzeile. Wähle das passende und sieh eine fertige Richtung, die ich auf deine Marke zuschneide.',
    'lab.grid.head': 'Wähle eine Branche',
    'lab.shop.t': 'Boutique / Onlineshop', 'lab.shop.d': 'Ein voller Shop: Schaufenster, Kategorien, Warenkorb. Elegant, bereit für deine Produkte.', 'lab.shop.s': 'Beispiel ansehen',
    'lab.rest.t': 'Restaurant', 'lab.rest.d': 'Ein appetitlicher Landing: Menü, Atmosphäre, Reservierung. Warm, sinnlich, lokal.', 'lab.rest.s': 'bald',
    'lab.serv.t': 'Lokale Dienstleistungen', 'lab.serv.d': 'Eine Seite für Handwerker oder Dienstleister: Vertrauen, Arbeiten, schneller Kontakt. PL und DE.', 'lab.serv.s': 'bald',
    'lab.clin.t': 'Praxis / Klinik', 'lab.clin.d': 'Eine ruhige, klare Seite für Gesundheit und Schönheit: Leistungen, Team, Terminbuchung.', 'lab.clin.s': 'bald',
    'lab.foot': 'Deine Branche fehlt? Schreib mir, ich ergänze ein Beispiel, zugeschnitten auf dich.',
  },
});

const cards = [
  { t: 'lab.shop.t', d: 'lab.shop.d', s: 'lab.shop.s', href: '/pracownia/sklep/', live: true, g: 'linear-gradient(135deg,#1b1f26,#2a2018)', accent: '#c98a5e' },
  { t: 'lab.rest.t', d: 'lab.rest.d', s: 'lab.rest.s', href: '', live: false, g: 'linear-gradient(135deg,#241a16,#3a221a)', accent: '#d98b5f' },
  { t: 'lab.serv.t', d: 'lab.serv.d', s: 'lab.serv.s', href: '', live: false, g: 'linear-gradient(135deg,#161e26,#1d2c38)', accent: '#5b91c9' },
  { t: 'lab.clin.t', d: 'lab.clin.d', s: 'lab.clin.s', href: '', live: false, g: 'linear-gradient(135deg,#16201d,#1d2e2a)', accent: '#5bb39a' },
];
---
<Chrome title="Przykładowe strony · D-LOGIC studio" description="Kompletne przykłady stron dla różnych branż: sklep, restauracja, usługi lokalne, gabinet. Gotowe kierunki do dopasowania." dict={dict} active="/pracownia/">
  <section class="wrap lab-head">
    <span class="eyebrow" data-i18n="lab.eyebrow">•</span>
    <h1 data-i18n-html="lab.title">•</h1>
    <p class="lead" data-i18n="lab.lead">•</p>
  </section>

  <section class="wrap" style="padding:8px 0 80px">
    <div class="sec-head reveal"><h2 data-i18n="lab.grid.head">•</h2></div>
    <div class="gal">
      {cards.map((c, i) => {
        const Tag = c.live ? 'a' : 'div';
        return (
          <Tag class:list={['gal-card reveal', { live: c.live, soon: !c.live }]} data-delay={i % 2} {...(c.live ? { href: c.href } : {})}>
            <div class="gal-prev" style={`background:${c.g}`}>
              <span class="gal-chip" style={`color:${c.accent}`}>{['◆','❋','▲','✚'][i]}</span>
              {!c.live && <span class="gal-soon" data-i18n={c.s}>•</span>}
            </div>
            <div class="gal-body">
              <h3 data-i18n={c.t}>•</h3>
              <p data-i18n={c.d}>•</p>
              {c.live && <span class="gal-go" data-i18n={c.s}>•</span>}
            </div>
          </Tag>
        );
      })}
    </div>
    <p class="lab-foot reveal" data-i18n="lab.foot">•</p>
  </section>

  <style>
    .lab-head { padding: 64px 0 26px; }
    .lab-head h1 { font-family: 'Space Grotesk Variable', sans-serif; font-weight: 600; font-size: clamp(34px, 6vw, 64px); line-height: 1.05; letter-spacing: -0.02em; margin: 14px 0 0; max-width: 18ch; }
    .lab-head .lead { font-size: clamp(16px, 2.2vw, 20px); color: var(--muted); max-width: 60ch; margin-top: 18px; }
    .gal { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; }
    .gal-card { display: block; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: var(--surface); text-decoration: none; color: inherit; transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease; }
    .gal-card.live:hover { border-color: color-mix(in srgb, var(--accent) 50%, var(--line)); transform: translateY(-3px); box-shadow: 0 18px 40px -24px rgba(0,0,0,.6); }
    .gal-card.soon { opacity: .82; }
    .gal-prev { position: relative; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
    .gal-chip { font-size: 40px; opacity: .9; }
    .gal-soon { position: absolute; top: 12px; right: 12px; font-family: 'JetBrains Mono Variable', monospace; font-size: 10.5px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); background: color-mix(in srgb, var(--bg) 70%, transparent); border: 1px solid var(--line); border-radius: 999px; padding: 4px 10px; }
    .gal-body { padding: 22px 24px 26px; }
    .gal-body h3 { font-family: 'Space Grotesk Variable', sans-serif; font-size: 22px; font-weight: 600; margin: 0 0 8px; }
    .gal-body p { color: var(--muted); line-height: 1.6; font-size: 15px; margin: 0; }
    .gal-go { display: inline-block; margin-top: 16px; color: var(--accent); font-weight: 600; font-size: 14.5px; }
    .gal-go::after { content: ' →'; }
    .lab-foot { margin-top: 30px; color: var(--muted); font-size: 14.5px; }
    @media (max-width: 680px) { .gal { grid-template-columns: 1fr; } }
  </style>
</Chrome>
