    'lab.c3.k': '03 · web', 'lab.c3.t': 'Strony: od minimalizmu po 3D', 'lab.c3.d': 'Zróżnicowane szablony i realizacje. Czysty minimalizm, immersyjne 3D, wielojęzyczność PL/DE/EN.', 'lab.c3.s': 'wkrótce',
    'lab.c4.k': '04 · społeczność', 'lab.c4.t': 'Mini-portal dla grup', 'lab.c4.d': 'Lekki portal dla małych społeczności, klubów i firm. Miejsce, ogłoszenia, ludzie. Koncept w budowie.', 'lab.c4.s': 'koncept',
    'lab.foot': 'Pomysł na coś, czego tu nie ma? Napisz, zbuduję demo.',
  },
  en: {
