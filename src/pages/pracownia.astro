---
<Chrome title="Pracownia · D-LOGIC studio" description="Interaktywne dema: pole 3D WebGL, dashboard na dane, strony, mini-portal. Dowód, nie obietnica." dict={dict} active="/pracownia/">
  <section class="lab-hero">
    <canvas id="field" aria-hidden="true"></canvas>
    <div class="lab-hero-veil"></div>
    <div class="wrap lab-hero-text">
      <span class="eyebrow" data-i18n="lab.eyebrow">•</span>
      <h1 data-i18n-html="lab.title">•</h1>
      <p class="lead" data-i18n="lab.lead">•</p>
      <span class="lab-hint"><span class="pulse"></span><span data-i18n="lab.hint">•</span></span>
    </div>
  </section>

  <section class="wrap" style="padding:54px 0 80px">
    <div class="sec-head reveal"><h2 data-i18n="lab.grid.head">•</h2></div>
    <div class="lab-grid">
      <article class="lab-card reveal live">
        <div class="lab-card-top"><span class="k" data-i18n="lab.c1.k">•</span><span class="badge on" data-i18n="lab.c1.s">•</span></div>
        <h3 data-i18n="lab.c1.t">•</h3><p data-i18n="lab.c1.d">•</p>
      </article>
      <article class="lab-card reveal" data-delay="1">
        <div class="lab-card-top"><span class="k" data-i18n="lab.c2.k">•</span><span class="badge" data-i18n="lab.c2.s">•</span></div>
        <h3 data-i18n="lab.c2.t">•</h3><p data-i18n="lab.c2.d">•</p>
      </article>
      <article class="lab-card reveal">
        <div class="lab-card-top"><span class="k" data-i18n="lab.c3.k">•</span><span class="badge" data-i18n="lab.c3.s">•</span></div>
        <h3 data-i18n="lab.c3.t">•</h3><p data-i18n="lab.c3.d">•</p>
      </article>
      <article class="lab-card reveal" data-delay="1">
        <div class="lab-card-top"><span class="k" data-i18n="lab.c4.k">•</span><span class="badge" data-i18n="lab.c4.s">•</span></div>
        <h3 data-i18n="lab.c4.t">•</h3><p data-i18n="lab.c4.d">•</p>
      </article>
    </div>
    <p class="lab-foot reveal" data-i18n="lab.foot">•</p>
  </section>

  <script>
    import * as THREE from 'three';
    const canvas = document.getElementById('field') as HTMLCanvasElement | null;
    if (canvas) {
      const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true, powerPreference: 'high-performance' });
      renderer.setPixelRatio(Math.min(devicePixelRatio || 1, 2));
      const scene = new THREE.Scene();
      scene.fog = new THREE.FogExp2(0x0c0e12, 0.11);
      const camera = new THREE.PerspectiveCamera(54, 1, 0.1, 100);
      camera.position.set(0, 2.4, 6.4);

      const N = 78, S = 15;
      const count = N * N;
      const base = new Float32Array(count * 3);
      let i = 0;
      for (let x = 0; x < N; x++) for (let z = 0; z < N; z++) {
        base[i * 3] = (x / (N - 1) - 0.5) * S;
        base[i * 3 + 1] = 0;
        base[i * 3 + 2] = (z / (N - 1) - 0.5) * S;
        i++;
      }
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(base.slice(), 3));
      const mat = new THREE.PointsMaterial({ color: 0xe8b23a, size: 0.05, transparent: true, opacity: 0.92, sizeAttenuation: true });
      const points = new THREE.Points(geo, mat);
      scene.add(points);

      function resize() {
        const r = canvas!.getBoundingClientRect();
        renderer.setSize(r.width, r.height, false);
        camera.aspect = r.width / Math.max(r.height, 1);
        camera.updateProjectionMatrix();
      }
      resize();
      addEventListener('resize', resize);

      let mx = 0, my = 0, tx = 0, ty = 0;
      addEventListener('pointermove', (e) => { tx = e.clientX / innerWidth - 0.5; ty = e.clientY / innerHeight - 0.5; });

      const pos = geo.attributes.position.array as Float32Array;
      let t = 0;
      function frame() {
        t += 0.012;
        mx += (tx - mx) * 0.05; my += (ty - my) * 0.05;
        for (let k = 0; k < count; k++) {
          const px = base[k * 3], pz = base[k * 3 + 2];
          const d = Math.sqrt(px * px + pz * pz);
          const mxs = mx * 6, mzs = my * 6;
          const md = Math.sqrt((px - mxs) * (px - mxs) + (pz - mzs) * (pz - mzs));
          pos[k * 3 + 1] =
            Math.sin(d * 0.85 - t * 1.6) * 0.55 +
            Math.sin(px * 0.5 + t) * 0.22 +
            Math.cos(pz * 0.6 - t * 0.8) * 0.22 +
            Math.exp(-md * 0.5) * 1.1; // cursor lifts the field
        }
        geo.attributes.position.needsUpdate = true;
        camera.position.x += (mx * 3.4 - camera.position.x) * 0.04;
        camera.position.y += ((-my * 2.2 + 2.6) - camera.position.y) * 0.04;
        camera.lookAt(0, 0, 0);
        points.rotation.y += 0.0007;
        renderer.render(scene, camera);
        if (!reduce) requestAnimationFrame(frame);
      }
      frame();
    }
  </script>

  <style>
    .lab-hero { position: relative; height: 74vh; min-height: 540px; max-height: 760px; overflow: hidden; border-bottom: 1px solid var(--line); }
    #field { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
    .lab-hero-veil { position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(120% 90% at 18% 30%, color-mix(in srgb, var(--bg) 70%, transparent) 0%, transparent 55%),
                  linear-gradient(180deg, transparent 40%, var(--bg) 100%); }
    .lab-hero-text { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; justify-content: center; pointer-events: none; }
    .lab-hero-text h1 { font-family: 'Space Grotesk Variable', sans-serif; font-weight: 600; font-size: clamp(34px, 6vw, 68px); line-height: 1.04; letter-spacing: -0.02em; margin: 12px 0 0; max-width: 16ch; }
    .lab-hero-text .lead { font-size: clamp(16px, 2.2vw, 20px); color: var(--muted); max-width: 54ch; margin-top: 18px; }
    .lab-hint { display: inline-flex; align-items: center; gap: 8px; margin-top: 22px; font-family: 'JetBrains Mono Variable', monospace; font-size: 12.5px; color: var(--accent); text-transform: lowercase; letter-spacing: .04em; }
    .lab-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .lab-card { border: 1px solid var(--line); border-radius: 16px; padding: 24px; background: var(--surface); transition: border-color .2s ease, transform .2s ease; }
    .lab-card:hover { border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); transform: translateY(-2px); }
    .lab-card.live { border-color: color-mix(in srgb, var(--accent) 55%, var(--line)); background: color-mix(in srgb, var(--accent) 5%, var(--surface)); }
    .lab-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .lab-card .k { font-family: 'JetBrains Mono Variable', monospace; font-size: 12px; color: var(--muted); letter-spacing: .03em; }
    .lab-card h3 { font-family: 'Space Grotesk Variable', sans-serif; font-size: 21px; font-weight: 600; margin: 0 0 8px; }
    .lab-card p { color: var(--muted); line-height: 1.6; font-size: 15px; margin: 0; }
    .badge { font-family: 'JetBrains Mono Variable', monospace; font-size: 10.5px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 3px 9px; }
    .badge.on { color: #1a1205; background: var(--accent); border-color: var(--accent); }
    .lab-foot { margin-top: 26px; color: var(--muted); font-size: 14.5px; }
    @media (max-width: 680px) { .lab-grid { grid-template-columns: 1fr; } .lab-hero { height: 64vh; } }
  </style>
</Chrome>
