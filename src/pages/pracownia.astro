      ind:{pl:"Portal społecznościowy · intranet",de:"Community-Portal · Intranet"},
      desc:{pl:"Tablica, członkowie, wydarzenia, grupy i czat.",de:"Pinnwand, Mitglieder, Events, Gruppen und Chat."},
      pal:["#4f46e5","#0ea5e9","#f4f5f8"], pp:{bg:"#f4f5f8",bar:"#ffffff",hero:"#eef0f6",acc:"#4f46e5",ink:"#1e2230"} }
  ];
const _EN={
 oliva:{ind:"Restaurant · seasonal kitchen",desc:"Seasonal menu, cinematic hero, step-by-step booking."},
 forma:{ind:"Architecture & interior studio",desc:"Raw grid, concrete and light. Project portfolio."},
 mare:{ind:"Fashion brand · concept store",desc:"Editorial, big type, shop and lookbook."},
 horyzont:{ind:"Developer · premium real estate",desc:"Investments, interactive floor plan, prestige and trust."},
 lumen:{ind:"Aesthetic medicine clinic · SPA",desc:"Calm, treatments, price list and online booking."},
 meridian:{ind:"Law firm · advisory",desc:"Authority, practice areas, team and contact."},
 cisza:{ind:"Boutique hotel · guesthouse",desc:"Rooms, mountain mood, book your stay."},
 grunhof:{ind:"Plant nursery · garden centre",desc:"Seasonal plant catalogue, B2B wholesale, garden design."},
 swietlik:{ind:"Kindergarten · parent & teacher portal",desc:"Parent/teacher login, groups, notices, messages.",cms:"Parent portal"},
 ratusz:{ind:"Public institution · citizen portal",desc:"e-Services, issue reporting with status tracking, news.",cms:"Clerk panel"},
 solaris:{ind:"Photovoltaics · turnkey installs",desc:"Interactive savings calculator, packages, audit.",cms:"Lead panel"},
 fracht:{ind:"Freight · contract logistics",desc:"Live shipment tracking, quotes, warehouse.",cms:"Dispatcher panel"},
 zaczyn:{ind:"Craft bakery · sourdough",desc:"Bakery catalogue, holiday pre-order cart.",cms:"Orders panel"},
 dentis:{ind:"Dentistry · dental clinic",desc:"Prices, team, online appointment booking.",cms:"Front-desk panel"},
 sloj:{ind:"Joinery · custom furniture",desc:"Furniture configurator with live pricing, project gallery.",cms:"Quotes panel"},
 kolektyw:{ind:"Community portal · intranet",desc:"Wall, members, events, groups and chat."}
};
PROJECTS.forEach(p=>{const e=_EN[p.id];if(e){p.ind.en=e.ind;p.desc.en=e.desc;if(e.cms){p.cmsLabel=p.cmsLabel||{};p.cmsLabel.en=e.cms;}}});

let BASE="";
const tot=String(PROJECTS.length).padStart(2,"0");
function card(p,i){
 const el=document.createElement("div");el.className="pcard rv";
 const no=String(i+1).padStart(2,"0");
 const site=BASE?BASE+"/"+p.href:"#";
 const cmsFile=p.cms||(p.id+"-studio.html");
 const cmsUrl=BASE?BASE+"/"+cmsFile:"#";
 const clp=p.cmsLabel?p.cmsLabel.pl:"Panel CMS",cld=p.cmsLabel?p.cmsLabel.de:"CMS-Panel",cle=p.cmsLabel&&p.cmsLabel.en?p.cmsLabel.en:"CMS panel";
 el.innerHTML=`
  <div class="pcard__top"><span class="pcard__no">${no} / ${tot}</span><span class="badge badge--live" data-pl="Gotowy" data-de="Fertig" data-en="Ready">Gotowy</span></div>
  <a class="prevframe" href="${site}" target="_blank" rel="noopener" aria-label="${p.name}">
    <iframe loading="lazy" tabindex="-1" title="${p.name}" ${BASE?`src="${site}"`:""} sandbox="allow-scripts allow-same-origin"></iframe>
    <span class="prevframe__shade"></span>
    <span class="prevframe__open" data-pl="Otwórz na żywo ↗" data-de="Live öffnen ↗" data-en="Open live ↗">Otwórz na żywo ↗</span>
  </a>
  <div class="pcard__body">
    <span class="pcard__ind" data-pl="${p.ind.pl}" data-de="${p.ind.de}" data-en="${p.ind.en}">${p.ind.pl}</span>
    <span class="pcard__name">${p.name}</span>
    <span class="pcard__desc" data-pl="${p.desc.pl}" data-de="${p.desc.de}" data-en="${p.desc.en}">${p.desc.pl}</span>
    <div class="pcard__foot">
      <div class="pcard__pal">${p.pal.map(c=>`<i style="background:${c}"></i>`).join("")}</div>
      <a class="pcard__cms" href="${cmsUrl}" target="_blank" rel="noopener" data-pl="${clp} ↗" data-de="${cld} ↗" data-en="${cle} ↗">${clp} ↗</a>
    </div>
  </div>`;
 el.style.setProperty("transition-delay",(i%2)*0.06+"s");
 return el;
}
function scaleFrames(){ $$(".prevframe").forEach(f=>{ f.style.setProperty("--s",(f.clientWidth/1280).toFixed(4)); const ifr=f.querySelector("iframe"); if(ifr) ifr.style.height=(f.clientHeight/(f.clientWidth/1280))+"px"; }); }
function render(){
 const g=$("#pgrid"); if(!g) return;
 PROJECTS.forEach((p,i)=>g.appendChild(card(p,i)));
 scaleFrames();
 if(window.DLi18n) DLi18n.apply(DLi18n.get());
 reveals();
}
function reveals(){
 const reduce=matchMedia("(prefers-reduced-motion: reduce)").matches;
 if(reduce){$$(".rv").forEach(e=>e.classList.add("in"));return;}
 const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target);}}),{threshold:.08,rootMargin:"0px 0px -4% 0px"});
 $$(".rv").forEach(el=>io.observe(el));
 setTimeout(()=>$$(".rv:not(.in)").forEach(el=>{if(el.getBoundingClientRect().top<innerHeight*1.1)el.classList.add("in");}),300);
}
function nav(){
 const bar=$("#scrollbar");
 addEventListener("scroll",()=>{if(bar){const h=document.documentElement.scrollHeight-innerHeight;bar.style.width=(h>0?scrollY/h*100:0)+"%";}},{passive:true});
}
let rT;addEventListener("resize",()=>{clearTimeout(rT);rT=setTimeout(scaleFrames,150);});
document.addEventListener("DOMContentLoaded",()=>{
 nav();
 fetch("/pracownia-demos.json",{cache:"no-store"}).then(r=>r.json()).then(d=>{BASE=(d&&d.base?d.base:"").replace(/\/$/,"");}).catch(()=>{}).finally(render);
});
})();

</script>
