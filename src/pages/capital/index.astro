---
import PageLayout from '../../layouts/PageLayout.astro';
import CapitalIndex from '../../components/CapitalIndex.astro';
import { reportsByLang, capitalSw } from '../../lib/content';
import { capitalI18n } from '../../lib/capital';
const lang = 'pl';
const reports = await reportsByLang(lang);
const t = capitalI18n[lang];
---
<PageLayout lang={lang} title={`${t.heroH1} · D-LOGIC Capital`} description={t.lead} sw={capitalSw}>
  <CapitalIndex lang={lang} reports={reports} base="" />
</PageLayout>
