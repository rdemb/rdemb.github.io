---
import PageLayout from '../../layouts/PageLayout.astro';
import CapitalReport from '../../components/CapitalReport.astro';
import { reportsByLang, reportSw } from '../../lib/content';
import { render } from 'astro:content';
const lang = 'pl';
export async function getStaticPaths() {
  const reports = await reportsByLang('pl');
  return reports.map((r) => ({ params: { key: r.data.key }, props: { entry: r } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<PageLayout lang={lang} title={`${d.company} (${d.ticker}) · raport D-LOGIC Capital`} description={d.excerpt} sw={reportSw(d.key)}>
  <CapitalReport lang={lang} d={d} base=""><Content /></CapitalReport>
</PageLayout>
