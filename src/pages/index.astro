---
import Base from '../layouts/Base.astro';
---
<Base>
<div id="progress"></div>

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a href="#top" class="brand"><span class="dot"></span>D&#8209;<b>LOGIC</b>&nbsp;<span style="color:var(--muted);font-weight:400">studio</span></a>
    <nav class="nav-links">
      <a href="#oferta" data-i18n="nav.work">Oferta</a>
      <a href="#proof" data-i18n="nav.proof">Clawbot</a>
      <a href="#lab" data-i18n="nav.lab">Lab</a>
      <a href="#notes" data-i18n="nav.notes">Notatki</a>
      <a href="#kontakt" data-i18n="nav.contact">Kontakt</a>
    </nav>
    <div class="nav-tools">
      <div class="seg" id="lang" role="group" aria-label="Język / Language">
        <button data-lang="pl" class="on">PL</button>
        <button data-lang="en">EN</button>
        <button data-lang="de">DE</button>
      </div>
      <button class="icon-btn" id="theme" aria-label="Przełącz motyw">
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
      </button>
      <button class="icon-btn menu-btn" id="menu" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

<main id="top">
<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow" data-i18n="hero.eyebrow">Solo studio · człowiek + AI</span>
      <h1 data-i18n-html="hero.title">Buduję narzędzia AI, które<br><span class="hl">naprawdę działają.</span></h1>
      <p class="lead" data-i18n="hero.lead">Narzędzia AI, strony i produkty danowe. Projektuję je i testuję jak strategie tradingowe: najpierw na sobie, potem dla Ciebie. Uczciwość zamiast hype'u.</p>
      <div class="hero-cta">
        <a href="#kontakt" class="btn btn-primary"><span data-i18n="hero.cta1">Zacznijmy projekt</span><span class="arr">→</span></a>
        <a href="#proof" class="btn btn-ghost"><span data-i18n="hero.cta2">Zobacz clawbot</span></a>
      </div>
      <div class="hero-meta">
        <div class="m"><b>100%</b><span data-i18n="hero.m1">testowane na sobie</span></div>
        <div class="m"><b>PL·DE·EN</b><span data-i18n="hero.m2">trzy języki</span></div>
        <div class="m"><b>0</b><span data-i18n="hero.m3">hype'u i ściemy</span></div>
      </div>
    </div>
    <div class="scope reveal">
      <div class="scope-head">
        <span class="lbl" data-i18n="scope.lbl">// signal-vs-noise</span>
        <span class="live"><span class="pulse"></span><span data-i18n="scope.live">clawbot · online</span></span>
      </div>
      <canvas id="scope" aria-hidden="true"></canvas>
      <div class="scope-foot">
        <span class="stat" data-i18n-html="scope.s1">warstwy <b>3</b></span>
        <span class="stat" data-i18n-html="scope.s2">kadencja <b>5/dzień</b></span>
        <span class="stat" data-i18n-html="scope.s3">fallback <b>100%</b></span>
      </div>
    </div>
  </div>
</section>

<section id="oferta">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="work.eyebrow">Co robię</span>
      <h2 data-i18n="work.title">Trzy rzeczy, robione dobrze</h2>
      <p data-i18n="work.lead">Bez agencyjnego przerostu. Pracujesz bezpośrednio ze mną, od pierwszej rozmowy do wdrożenia.</p>
    </div>
    <div class="cards">
      <article class="card reveal">
        <span class="num">01 · flagowa</span>
        <h3 data-i18n="work.c1.t">AI Desk</h3>
        <p data-i18n="work.c1.d">Agent pilnuje tego, co dla Ciebie ważne: cen konkurencji, Twoich metryk, newsów. Wysyła zwięzły, uczciwy brief tam, gdzie już jesteś. Na cronie, z fallbackiem, bez niańczenia.</p>
        <ul>
          <li data-i18n="work.c1.l1">monitoring na cronie</li>
          <li data-i18n="work.c1.l2">brief zamiast szumu</li>
          <li data-i18n="work.c1.l3">Telegram, Slack, mail</li>
        </ul>
      </article>
      <article class="card reveal">
        <span class="num">02 · web</span>
        <h3 data-i18n="work.c2.t">Strony i aplikacje</h3>
        <p data-i18n="work.c2.d">Szybkie, wielojęzyczne strony i panele po polsku, niemiecku i angielsku. Kod, który da się utrzymać, i UI, które ludzie rozumieją. Strona, którą czytasz, jest dowodem.</p>
        <ul>
          <li data-i18n="work.c2.l1">landingi i wizytówki</li>
          <li data-i18n="work.c2.l2">panele i dashboardy</li>
          <li data-i18n="work.c2.l3">aplikacje webowe</li>
        </ul>
      </article>
      <article class="card reveal">
        <span class="num">03 · dane</span>
        <h3 data-i18n="work.c3.t">Z danych do decyzji</h3>
        <p data-i18n="work.c3.d">Modele, backtesty, dashboardy. Lata przy rynku nauczyły mnie jednego: liczy się dowód, nie obietnica. Dostajesz analizę z jawnym poziomem pewności, nie pewną ściemę.</p>
        <ul>
          <li data-i18n="work.c3.l1">backtesting strategii</li>
          <li data-i18n="work.c3.l2">analiza i ETL</li>
          <li data-i18n="work.c3.l3">dashboardy</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<section id="proof" class="proof">
  <div class="wrap proof-grid">
    <div class="reveal">
      <span class="eyebrow" data-i18n="proof.eyebrow">Dowód, nie obietnica</span>
      <h2 style="font-family:'Space Grotesk Variable';font-weight:600;font-size:clamp(28px,3.6vw,42px);letter-spacing:-.02em;line-height:1.08;margin:16px 0 0" data-i18n="proof.title">Clawbot: quant-desk, który zbudowałem dla siebie</h2>
      <p style="color:var(--muted);font-size:17.5px;margin-top:18px;max-width:50ch" data-i18n="proof.lead">Codzienne briefy rynkowe na Telegram. Trzy warstwy (quant, kontekst, narracja) nigdy się nie mieszają. Syntezę pisze Claude, z twardym fallbackiem do wersji deterministycznej. Całość chodzi na cronie. To wzorzec każdego AI Desk, który zbuduję dla Ciebie.</p>
      <div class="metrics">
        <div class="metric"><b class="tnum" data-count="3">0</b><span data-i18n="proof.k1">warstwy, nigdy zlane</span></div>
        <div class="metric"><b class="tnum" data-count="2.5" data-dec="1" data-suffix="s">0</b><span data-i18n="proof.k2">czas briefu (Tier 1)</span></div>
        <div class="metric"><b class="tnum" data-count="5">0</b><span data-i18n="proof.k3">briefy dziennie</span></div>
        <div class="metric"><b class="tnum" data-count="100" data-suffix="%">0</b><span data-i18n="proof.k4">fallback, nigdy bez briefu</span></div>
      </div>
      <div class="limit reveal" data-i18n-html="proof.limit"><b>Uczciwa granica:</b> desk informuje, nie decyduje sam. Kierunek i wejście zostają u człowieka. To cecha, nie ograniczenie: tak buduje się zaufanie.</div>
    </div>
    <div class="proof-panel reveal" aria-hidden="true">
      <div class="row"><span>// status</span><b class="pos">● ONLINE</b></div>
      <div class="row"><span>tryb</span><b>OBSERVE-ONLY</b></div>
      <div class="row"><span>warstwy</span><b>quant · kontekst · narracja</b></div>
      <div class="row"><span>synteza</span><b>Claude + fallback</b></div>
      <div class="row"><span>kadencja</span><b>5 / dzień · cron</b></div>
      <div class="row"><span>okno_fade</span><b>NY-pm 18:00-22:00 CET</b></div>
      <div class="row"><span>kierunek</span><b class="pos">człowiek</b></div>
      <div class="row"><span>uptime_sesji</span><b class="tnum" id="hb">00:00</b></div>
    </div>
  </div>
</section>

<section id="lab">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="lab.eyebrow">Lab</span>
      <h2 data-i18n="lab.title">Co buduję i badam</h2>
      <p data-i18n="lab.lead">Rzeczy, które robię dla siebie. Czasem stają się produktem, czasem lekcją. Każda z zapisanym wynikiem, także negatywnym.</p>
    </div>
    <div class="cards">
      <article class="card reveal">
        <span class="num">market intelligence</span>
        <h3 data-i18n="lab.c1.t">forex-lab</h3>
        <p data-i18n="lab.c1.d">Czy mój własny edge przeżywa koszty i out-of-sample? Sprawdziłem to rygorystycznie: bootstrap, FDR, walk-forward. Część wyników wyszła negatywna, i to też jest wynik.</p>
      </article>
      <a class="card reveal" href="/lab/mocps/">
        <span class="num">diagnostyka predykcyjna</span>
        <h3 data-i18n="lab.c2.t">MOCPS</h3>
        <p data-i18n="lab.c2.d">Kiedy reprezentacja naprawdę przewiduje ruch obiektu lepiej niż ostatnia znana pozycja? Mały, sprawdzalny test, który da się powtórzyć na zwykłym CPU.</p>
      </a>
      <a class="card reveal" href="/lab/aai/">
        <span class="num">market structure</span>
        <h3 data-i18n="lab.c3.t">AAI</h3>
        <p data-i18n="lab.c3.d">Adaptive Auction Intelligence: porządkowanie rynku przed decyzją. Najpierw aukcja, koszt wykonania i jakość dowodów, dopiero potem kierunek. Brak przewagi to też wynik.</p>
      </a>
    </div>
  </div>
</section>

<section id="notes">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-i18n="notes.eyebrow">Notatki</span>
      <h2 data-i18n="notes.title">Piszę o tym, co buduję</h2>
      <p data-i18n="notes.lead">Krótkie zapiski o danych, AI i uczciwym budowaniu. Bez clickbaitu, za to z baseline'em i ograniczeniami.</p>
    </div>
    <div class="notes">
      <a href="/blog/mocps-learned-occlusion-gate/" class="note reveal">
        <span class="date mono">2026.05.19</span>
        <span class="ttl" data-i18n="notes.n1.t">MOCPS: learned occlusion gate</span>
        <span class="tag" data-i18n="notes.n1.g">projekt</span>
      </a>
      <a href="/blog/why-this-blog/" class="note reveal">
        <span class="date mono">2026.05.18</span>
        <span class="ttl" data-i18n="notes.n2.t">Po co ten blog</span>
        <span class="tag" data-i18n="notes.n2.g">refleksja</span>
      </a>
      <a href="/blog/llm-vs-mocps/" class="note reveal">
        <span class="date mono">2026.05.18</span>
        <span class="ttl" data-i18n="notes.n3.t">Czym LLM różni się od MOCPS</span>
        <span class="tag" data-i18n="notes.n3.g">ai</span>
      </a>
    </div>
  </div>
</section>

<section id="kontakt">
  <div class="wrap">
    <div class="cta-wrap reveal">
      <canvas id="cta-scope" aria-hidden="true"></canvas>
      <div class="inner">
        <span class="eyebrow" style="justify-content:center" data-i18n="cta.eyebrow">Kontakt</span>
        <h2 data-i18n="cta.title">Masz coś, co powinno być pilnowane albo zautomatyzowane?</h2>
        <p data-i18n="cta.lead">Napisz w dwóch, trzech zdaniach, co chcesz zbudować. Odpowiadam osobiście i szczerze, także wtedy, gdy czegoś nie zrobię dobrze.</p>
        <div class="hero-cta">
          <a href="mailto:rdem91@gmail.com" class="btn btn-primary"><span data-i18n="cta.btn1">Napisz maila</span><span class="arr">→</span></a>
          <a href="https://x.com/takitamrafal" target="_blank" rel="noopener" class="btn btn-ghost"><span data-i18n="cta.btn2">Napisz na X</span></a>
        </div>
      </div>
    </div>
  </div>
</section>
</main>

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="brand"><span class="dot"></span>D&#8209;<b>LOGIC</b>&nbsp;<span style="color:var(--muted);font-weight:400">studio</span></div>
        <p class="tag" data-i18n="foot.tag">Solo studio, człowiek + AI. Narzędzia, web i dane, testowane na sobie.</p>
      </div>
      <div class="foot-links">
        <div class="foot-col">
          <h4 data-i18n="foot.h1">Studio</h4>
          <a href="#oferta" data-i18n="nav.work">Oferta</a>
          <a href="#proof" data-i18n="nav.proof">Clawbot</a>
          <a href="#lab" data-i18n="nav.lab">Lab</a>
        </div>
        <div class="foot-col">
          <h4 data-i18n="foot.h2">Kontakt</h4>
          <a href="mailto:rdem91@gmail.com">rdem91@gmail.com</a>
          <a href="https://x.com/takitamrafal" target="_blank" rel="noopener">x.com/takitamrafal</a>
          <a href="https://github.com/rdemb" target="_blank" rel="noopener">github.com/rdemb</a>
        </div>
      </div>
    </div>
    <div class="foot-base">
      <span>© <span id="yr">2026</span> D-LOGIC studio</span>
      <span data-i18n="foot.made">Zbudowane uczciwie. Bez szablonów.</span>
    </div>
  </div>
</footer>

