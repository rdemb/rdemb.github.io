const moonPath='<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>';
function applyTheme(t){ docEl.setAttribute("data-theme",t); const s=document.querySelector("#theme svg"); if(s) s.innerHTML=(t==="dark"?sunPath:moonPath); try{ localStorage.setItem("dlogic-theme",t); }catch(e){} }
document.getElementById("theme").addEventListener("click", ()=>applyTheme(docEl.getAttribute("data-theme")==="dark"?"light":"dark"));

applyLang(localStorage.getItem("dlogic-lang")||"pl");
