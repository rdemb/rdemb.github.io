const io=new IntersectionObserver(es=>{ es.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target); } }); }, {threshold:.14, rootMargin:"0px 0px -8% 0px"});
document.querySelectorAll(".reveal").forEach(el=>io.observe(el));

const reduce=window.matchMedia("(prefers-reduced-motion:reduce)").matches;
function countUp(el){
  const target=parseFloat(el.dataset.count), dec=parseInt(el.dataset.dec||"0",10), pre=el.dataset.prefix||"", suf=el.dataset.suffix||"";
  if(reduce){ el.textContent=pre+target.toFixed(dec)+suf; return; }
  const dur=1300, t0=performance.now();
  function step(now){ const p=Math.min((now-t0)/dur,1), e=1-Math.pow(1-p,3); el.textContent=pre+(target*e).toFixed(dec)+suf; if(p<1) requestAnimationFrame(step); }
  requestAnimationFrame(step);
}
const ioC=new IntersectionObserver(es=>{ es.forEach(e=>{ if(e.isIntersecting){ countUp(e.target); ioC.unobserve(e.target); } }); }, {threshold:.5});
document.querySelectorAll("[data-count]").forEach(el=>ioC.observe(el));

const hb=document.getElementById("hb"); let hbS=0;
setInterval(()=>{ hbS++; const m=String(Math.floor(hbS/60)).padStart(2,"0"), s=String(hbS%60).padStart(2,"0"); if(hb) hb.textContent=`${m}:${s}`; }, 1000);

function cssVar(n){ return getComputedStyle(docEl).getPropertyValue(n).trim(); }
function makeScope(canvas, opts={}){
  if(!canvas) return; const ctx=canvas.getContext("2d");
  let W,H,dpr=Math.min(window.devicePixelRatio||1,2);
  function size(){ const r=canvas.getBoundingClientRect(); W=r.width; H=r.height; canvas.width=W*dpr; canvas.height=H*dpr; ctx.setTransform(dpr,0,0,dpr,0,0); }
  size(); window.addEventListener("resize", size);
  let t=0;
  function y(x){ const nx=x/W, base=H*0.62-nx*H*(opts.drift??0.1)*1.2, s=Math.sin(nx*Math.PI*2*(opts.freq??1.6)+t)*H*(opts.amp??0.16), s2=Math.sin(nx*Math.PI*2*(opts.freq??1.6)*2.3+t*1.7)*H*(opts.amp??0.16)*0.32, n=(Math.sin(nx*53+t*3.1)*0.5+Math.sin(nx*97-t*2.2)*0.5)*H*0.012; return base+s+s2+n; }
  function draw(){
    ctx.clearRect(0,0,W,H);
    const wave=cssVar("--wave"), ghost=cssVar("--wave-ghost"), line=cssVar("--line");
    ctx.strokeStyle=line; ctx.lineWidth=1; ctx.globalAlpha=.5;
    for(let gy=H*0.25; gy<H; gy+=H*0.25){ ctx.beginPath(); ctx.moveTo(0,gy); ctx.lineTo(W,gy); ctx.stroke(); }
    ctx.globalAlpha=1;
    ctx.strokeStyle=ghost; ctx.lineWidth=6; ctx.lineJoin="round"; ctx.beginPath();
    for(let x=0;x<=W;x+=4){ const yy=y(x)+8; x===0?ctx.moveTo(x,yy):ctx.lineTo(x,yy);} ctx.stroke();
    ctx.shadowColor=wave; ctx.shadowBlur=12; ctx.strokeStyle=wave; ctx.lineWidth=2.2; ctx.lineJoin="round"; ctx.beginPath();
    let lx=0,ly=0;
    for(let x=0;x<=W;x+=2){ const yy=y(x); x===0?ctx.moveTo(x,yy):ctx.lineTo(x,yy); lx=x; ly=yy; }
    ctx.stroke(); ctx.shadowBlur=0;
    ctx.fillStyle=wave; ctx.beginPath(); ctx.arc(lx,ly,3.4,0,Math.PI*2); ctx.fill();
    ctx.globalAlpha=.25; ctx.beginPath(); ctx.arc(lx,ly,8,0,Math.PI*2); ctx.fill(); ctx.globalAlpha=1;
    t+=opts.speed??0.03; requestAnimationFrame(draw);
  }
  if(reduce){ const wave=cssVar("--wave"); ctx.strokeStyle=wave; ctx.lineWidth=2.2; ctx.beginPath(); for(let x=0;x<=W;x+=2){ const yy=H*0.6-(x/W)*H*0.12+Math.sin(x/W*Math.PI*2*1.6)*H*0.14; x===0?ctx.moveTo(x,yy):ctx.lineTo(x,yy);} ctx.stroke(); }
  else { requestAnimationFrame(draw); }
}
makeScope(document.getElementById("scope"), {amp:0.16,freq:1.7,speed:0.032,drift:0.12});
makeScope(document.getElementById("cta-scope"), {amp:0.10,freq:1.2,speed:0.018,drift:0.04});
const yr=document.getElementById("yr"); if(yr) yr.textContent=new Date().getFullYear();
</script>
