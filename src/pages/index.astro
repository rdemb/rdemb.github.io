function applyTheme(t){
  docEl.setAttribute("data-theme", t);
  const svg = document.querySelector("#theme svg"); if(svg) svg.innerHTML = t==="dark"?sunPath:moonPath;
  try{ localStorage.setItem("dlogic-theme", t); }catch(e){}
}
const themeBtn = document.getElementById("theme");
themeBtn && themeBtn.addEventListener("click", ()=> applyTheme(docEl.getAttribute("data-theme")==="dark"?"light":"dark"));

