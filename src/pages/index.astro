---
<Chrome title="D-LOGIC studio, narzędzia AI, strony i dane" description="Solo studio. Narzędzia AI, strony internetowe i analiza danych. Uczciwie, testowane najpierw na sobie." dict={dict} active="/">
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow" data-i18n="h.eyebrow">•</span>
        <h1 data-i18n-html="h.title">•</h1>
        <p class="lead" data-i18n="h.lead">•</p>
        <div class="hero-cta">
          <a href="/oferta/" class="btn btn-primary sh"><span data-i18n="h.cta1">•</span><span class="arr">→</span></a>
          <a href="/o-mnie/" class="btn btn-ghost"><span data-i18n="h.cta2">•</span></a>
        </div>
      </div>
      <div class="scope reveal">
        <div class="scope-head">
          <span class="lbl" data-i18n="sc.lbl">•</span>
          <span class="live"><span class="pulse"></span><span data-i18n="sc.live">•</span></span>
        </div>
        <canvas id="scope" aria-hidden="true"></canvas>
        <div class="scope-foot">
          <span class="stat" data-i18n="sc.s1">•</span><span class="stat" data-i18n="sc.s2">•</span><span class="stat" data-i18n="sc.s3">•</span>
        </div>
      </div>
    </div>
  </section>

  <section style="padding-top:20px">
    <div class="wrap">
      <div class="sec-head reveal"><h2 data-i18n="hub.head">•</h2></div>
      <div class="hub">
        <a class="hub-card reveal" href="/o-mnie/"><span class="k" data-i18n="hub.about.k">•</span><h3 data-i18n="hub.about.t">•</h3><p data-i18n="hub.about.d">•</p><span class="go" data-i18n="hub.go">•</span></a>
        <a class="hub-card reveal" data-delay="1" href="/oferta/"><span class="k" data-i18n="hub.work.k">•</span><h3 data-i18n="hub.work.t">•</h3><p data-i18n="hub.work.d">•</p><span class="go" data-i18n="hub.go">•</span></a>
        <a class="hub-card reveal" href="/projekty/"><span class="k" data-i18n="hub.proj.k">•</span><h3 data-i18n="hub.proj.t">•</h3><p data-i18n="hub.proj.d">•</p><span class="go" data-i18n="hub.go">•</span></a>
        <a class="hub-card reveal" data-delay="1" href="/blog/"><span class="k" data-i18n="hub.blog.k">•</span><h3 data-i18n="hub.blog.t">•</h3><p data-i18n="hub.blog.d">•</p><span class="go" data-i18n="hub.go">•</span></a>
      </div>
    </div>
  </section>

  <section class="proof">
    <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap">
      <div class="reveal" style="max-width:60ch">
        <span class="eyebrow" data-i18n="pr.eyebrow">•</span>
        <p style="font-size:clamp(19px,2.6vw,24px);font-family:'Space Grotesk Variable';line-height:1.4;margin-top:14px" data-i18n-html="pr.text">•</p>
      </div>
      <a href="/projekty/" class="btn btn-ghost reveal"><span data-i18n="pr.cta">•</span><span class="arr">→</span></a>
    </div>
  </section>

  <section id="kontakt" class="cta">
    <div class="wrap">
      <div class="cta-wrap reveal">
        <div class="inner">
          <span class="eyebrow" style="justify-content:center" data-i18n="nav.contact">•</span>
          <h2 data-i18n="cta.t">•</h2>
          <p data-i18n="cta.lead">•</p>
          <div class="hero-cta">
            <a href="mailto:rdem91@gmail.com" class="btn btn-primary"><span data-i18n="cta.b1">•</span><span class="arr">→</span></a>
            <a href="https://x.com/takitamrafal" target="_blank" rel="noopener" class="btn btn-ghost"><span data-i18n="cta.b2">•</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline slot="page-script">
    (function(){
      const cv=document.getElementById('scope'); if(!cv) return;
      const ctx=cv.getContext('2d'), reduce=matchMedia('(prefers-reduced-motion:reduce)').matches;
      let W,H,dpr=Math.min(devicePixelRatio||1,2),t=0;
      function cssv(n){return getComputedStyle(document.documentElement).getPropertyValue(n).trim();}
      function size(){const r=cv.getBoundingClientRect();W=r.width;H=r.height;cv.width=W*dpr;cv.height=H*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);}
      size(); addEventListener('resize',size);
      function y(x){const nx=x/W;return H*0.6-nx*H*0.12+Math.sin(nx*Math.PI*2*1.7+t)*H*0.16+Math.sin(nx*Math.PI*2*3.9+t*1.7)*H*0.05;}
      function draw(){ctx.clearRect(0,0,W,H);const w=cssv('--wave'),g=cssv('--wave-ghost'),l=cssv('--line');ctx.strokeStyle=l;ctx.globalAlpha=.5;for(let gy=H*.25;gy<H;gy+=H*.25){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}ctx.globalAlpha=1;ctx.strokeStyle=g;ctx.lineWidth=6;ctx.lineJoin='round';ctx.beginPath();for(let x=0;x<=W;x+=4){const yy=y(x)+8;x===0?ctx.moveTo(x,yy):ctx.lineTo(x,yy);}ctx.stroke();ctx.shadowColor=w;ctx.shadowBlur=12;ctx.strokeStyle=w;ctx.lineWidth=2.2;ctx.beginPath();let lx=0,ly=0;for(let x=0;x<=W;x+=2){const yy=y(x);x===0?ctx.moveTo(x,yy):ctx.lineTo(x,yy);lx=x;ly=yy;}ctx.stroke();ctx.shadowBlur=0;ctx.fillStyle=w;ctx.beginPath();ctx.arc(lx,ly,3.4,0,7);ctx.fill();t+=0.03;requestAnimationFrame(draw);}
      if(reduce){t=1;draw();}else draw();
    })();
  </script>
</Chrome>
