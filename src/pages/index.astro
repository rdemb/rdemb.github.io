function applyLang(lang){
  const dict = I18N[lang] || I18N.pl;
  docEl.lang = lang;
  document.querySelectorAll("[data-i18n]").forEach(el=>{
    const v = dict[el.getAttribute("data-i18n")]; if(v==null) return;
    if(v.indexOf("<")>-1) el.innerHTML = v; else el.textContent = v;
  });
  document.querySelectorAll(".note .ttl[data-pl]").forEach(el=>{ const v=el.getAttribute("data-"+lang); if(v!=null) el.textContent=v; });
  document.querySelectorAll("#lang button").forEach(b=>b.classList.toggle("on", b.dataset.lang===lang));
  try{ localStorage.setItem("dlogic-lang", lang); }catch(e){}
  // re-run decode on the headline after text swap
  decodeAll();
}
const langSeg = document.getElementById("lang");
langSeg && langSeg.addEventListener("click", e=>{
  const b = e.target.closest("button"); if(b) applyLang(b.dataset.lang);
});

