const docEl = document.documentElement;
function applyLang(lang){
  const dict = I18N[lang] || I18N.pl;
  docEl.lang = lang;
  document.querySelectorAll("[data-i18n]").forEach(el=>{ const v=dict[el.getAttribute("data-i18n")]; if(v!=null) el.textContent=v; });
  document.querySelectorAll("[data-i18n-html]").forEach(el=>{ const v=dict[el.getAttribute("data-i18n-html")]; if(v!=null) el.innerHTML=v; });
  document.querySelectorAll("#lang button").forEach(b=>b.classList.toggle("on", b.dataset.lang===lang));
  try{ localStorage.setItem("dlogic-lang", lang); }catch(e){}
}
document.getElementById("lang").addEventListener("click", e=>{ const b=e.target.closest("button"); if(b) applyLang(b.dataset.lang); });

