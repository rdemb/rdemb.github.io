/* ================= TICKER ================= */
(function(){
  const terms=["BOOTSTRAP","WALK-FORWARD","FDR","OUT-OF-SAMPLE","BASELINE","CRON","FALLBACK","OBSERVE-ONLY","SHARPE","MONTE-CARLO","SIGNAL / NOISE","QUANT-DESK","CLAUDE-SYNTHESIS","RIGOR > HYPE"];
  const track=document.getElementById("ticker"); if(!track) return;
  let html=""; for(let k=0;k<2;k++){ terms.forEach(t=>{ html+='<span><i>◢</i>'+t+'</span>'; }); }
  track.innerHTML=html;
})();

/* ================= DECODE / SCRAMBLE TEXT ================= */
const GLYPHS = "ABCDEFGHJKLMNPQRSTUVWXYZ0123456789▮▯/<>{}#%·";
const decodeState = new WeakMap();
function decodeEl(el){
  const target = el.textContent;
  if(reduce){ el.textContent = target; return; }
  if(decodeState.get(el)) cancelAnimationFrame(decodeState.get(el));
  const chars = target.split("");
  const start = performance.now();
  const total = Math.max(420, chars.length*26);
  function frame(now){
    const p = Math.min((now-start)/total,1);
    const revealed = Math.floor(p*chars.length);
    let out="";
    for(let i=0;i<chars.length;i++){
      const c=chars[i];
      if(c===" "||c==="\n"){ out+=c; continue; }
      if(i<revealed) out+=c;
      else out+=GLYPHS[(Math.random()*GLYPHS.length)|0];
    }
    el.textContent = out;
    if(p<1) decodeState.set(el, requestAnimationFrame(frame));
    else { el.textContent = target; decodeState.delete(el); }
  }
  decodeState.set(el, requestAnimationFrame(frame));
}
let decodeArmed=false;
function decodeAll(){
  if(!decodeArmed) return; // only after boot
  document.querySelectorAll("[data-decode]").forEach(decodeEl);
}

/* ================= NAV scroll + progress ================= */
const nav=document.getElementById("nav"), prog=document.getElementById("progress");
function onScroll(){
  const st=window.scrollY;
  nav && nav.classList.toggle("scrolled", st>10);
  const h=document.documentElement.scrollHeight-window.innerHeight;
  if(prog) prog.style.width=(h>0?(st/h)*100:0)+"%";
}
window.addEventListener("scroll", onScroll, {passive:true}); onScroll();
/* ================= REVEAL ================= */
const io=new IntersectionObserver((es)=>{
  es.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target); } });
},{threshold:.12, rootMargin:"0px 0px -7% 0px"});
// hide via JS-applied class so content is NEVER stuck invisible if this code doesn't run
document.querySelectorAll(".reveal,.stagger").forEach(el=>{ el.classList.add("pre"); io.observe(el); });
// failsafe: never leave content hidden, even if IO doesn't fire
setTimeout(()=>document.querySelectorAll(".reveal,.stagger").forEach(el=>el.classList.add("in")), 1200);

/* ================= COUNT-UP ================= */
function countUp(el){
  const target=parseFloat(el.dataset.count), dec=parseInt(el.dataset.dec||"0",10);
  const pre=el.dataset.prefix||"", suf=el.dataset.suffix||"";
  if(reduce){ el.textContent=pre+target.toFixed(dec)+suf; return; }
  const dur=1400, t0=performance.now();
  (function step(now){
    const p=Math.min((now-t0)/dur,1), e=1-Math.pow(1-p,3);
    el.textContent=pre+(target*e).toFixed(dec)+suf;
    if(p<1) requestAnimationFrame(step);
  })(performance.now());
}
const ioC=new IntersectionObserver((es)=>{
  es.forEach(e=>{ if(e.isIntersecting){ countUp(e.target); ioC.unobserve(e.target);} });
},{threshold:.6});
document.querySelectorAll("[data-count]").forEach(el=>ioC.observe(el));
// failsafe: ensure metrics resolve even if IO never fires
setTimeout(()=>document.querySelectorAll("[data-count]").forEach(el=>{ if(el.textContent.trim()==="0") countUp(el); }), 2800);

/* ================= LIVE TERMINAL ================= */
(function(){
  const hb=document.getElementById("hb"), cron=document.getElementById("cron");
  if(!hb) return;
  let s=0;
  const pad=n=>String(n).padStart(2,"0");
  setInterval(()=>{
    s++; hb.textContent=pad((s/60|0)%60)+":"+pad(s%60);
    // countdown to 04:00
    const left=(4*3600 - (s%(4*3600)));
    if(cron) cron.textContent=pad(left/3600|0)+":"+pad((left/60|0)%60)+":"+pad(left%60);
  },1000);
})();

/* ================= CUSTOM CURSOR + MAGNETIC ================= */
const cursor=document.getElementById("cursor");
if(false && cursor && !isTouch && !reduce){ /* animowany kursor usunięty (na życzenie) */ }
if(!isTouch && !reduce){
  // magnetic pull (zostaje, bez kursora)
  document.querySelectorAll("[data-magnetic]").forEach(el=>{
    el.addEventListener("mousemove", e=>{
      const r=el.getBoundingClientRect();
      const mx=e.clientX-(r.left+r.width/2), my=e.clientY-(r.top+r.height/2);
      el.style.transform=`translate(${mx*0.22}px,${my*0.32}px)`;
    });
    el.addEventListener("mouseleave",()=>{ el.style.transform=""; });
  });
}

/* ================= 3D TILT CARDS ================= */
if(!isTouch && !reduce){
  document.querySelectorAll(".tilt").forEach(t=>{
    const card=t.querySelector(".card"), glare=t.querySelector(".glare");
    t.addEventListener("mousemove", e=>{
      const r=t.getBoundingClientRect();
      const px=(e.clientX-r.left)/r.width, py=(e.clientY-r.top)/r.height;
      const rx=(0.5-py)*8, ry=(px-0.5)*9;
      card.style.transform=`rotateX(${rx}deg) rotateY(${ry}deg) translateZ(0)`;
      if(glare){ glare.style.setProperty("--gx",(px*100)+"%"); glare.style.setProperty("--gy",(py*100)+"%"); }
    });
    t.addEventListener("mouseleave", ()=>{ card.style.transform=""; });
  });
}

/* =================================================================
   THE LIVING ALGORITHM, flow-field particle engine
   ================================================================= */
function makeNoise(seed){
  const perm=new Uint8Array(512), p=[];
  for(let i=0;i<256;i++) p[i]=i;
  let s=seed||1;
  for(let i=255;i>0;i--){ s=(s*16807)%2147483647; const j=s%(i+1); const tmp=p[i]; p[i]=p[j]; p[j]=tmp; }
  for(let i=0;i<512;i++) perm[i]=p[i&255];
  const fade=t=>t*t*t*(t*(t*6-15)+10);
  const lerp=(a,b,t)=>a+t*(b-a);
  function grad(h,x,y){ const u=(h&1)?x:-x, v=(h&2)?y:-y; return u+v; }
  return function(x,y){
    const X=Math.floor(x)&255, Y=Math.floor(y)&255;
    x-=Math.floor(x); y-=Math.floor(y);
    const u=fade(x), v=fade(y);
    const aa=perm[perm[X]+Y], ab=perm[perm[X]+Y+1], ba=perm[perm[X+1]+Y], bb=perm[perm[X+1]+Y+1];
    return lerp(lerp(grad(aa,x,y),grad(ba,x-1,y),u), lerp(grad(ab,x,y-1),grad(bb,x-1,y-1),u), v);
  };
}
function hexToRgb(hex){
  hex=hex.trim().replace("#","");
  if(hex.length===3) hex=hex.split("").map(c=>c+c).join("");
  const n=parseInt(hex,16); return [n>>16&255,n>>8&255,n&255];
}

function FlowField(canvas, opts){
  opts=opts||{};
  const ctx=canvas.getContext("2d", {alpha:true});
  const noise=makeNoise(opts.seed||7);
  let W=0,H=0, dpr=Math.min(devicePixelRatio||1, isTouch?1.3:1.75);
  let particles=[], nodes=[];
  let t=0, raf=0, running=false, visible=true;
  let _cn=0, _bg="12,14,18", _acc=[232,178,58], _dark=true;
  const mouse={x:-9999,y:-9999,active:false, down:false};
  const hcoord=document.getElementById("hcoord");

  function bgRgb(){ return getComputedStyle(docEl).getPropertyValue("--bg-rgb").trim()||"12,14,18"; }
  function accentRgb(){ return (getComputedStyle(docEl).getPropertyValue("--accent-rgb").trim()||"232,178,58").split(",").map(Number); }

  function size(){
    const r=canvas.getBoundingClientRect();
    W=Math.max(1,r.width); H=Math.max(1,r.height);
    canvas.width=W*dpr; canvas.height=H*dpr; ctx.setTransform(dpr,0,0,dpr,0,0);
    seedParticles();
  }
  function seedParticles(){
    const density = opts.density || 0.00010;
    const count = Math.min(opts.max||900, Math.max(120, Math.floor(W*H*density)));
    particles=[];
    for(let i=0;i<count;i++) particles.push(newP(true));
    // constellation nodes
    const nc = opts.nodes!=null ? opts.nodes : Math.min(14, Math.max(6, Math.floor(W/120)));
    nodes=[];
    for(let i=0;i<nc;i++) nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.18,vy:(Math.random()-.5)*.18,ph:Math.random()*6.28});
  }
  function newP(spread){
    return {
      x: spread?Math.random()*W:(-20+Math.random()*40),
      y: Math.random()*H,
      vx:0, vy:0,
      life: 30+Math.random()*240,
      sp: 0.6+Math.random()*1.0,
      hot: Math.random()<0.05
    };
  }
  function fieldAngle(x,y){
    const sc=opts.scale||0.0016;
    const n=noise(x*sc, y*sc + t*0.12);
    return n*Math.PI*2.4 + Math.sin((x+y)*0.0006 + t*0.2)*0.4;
  }

  function frame(){
    if(!running){ return; }
    // cache theme colors (avoid getComputedStyle every frame)
    if((_cn++ % 24)===0){ _bg=bgRgb(); _acc=accentRgb(); _dark=docEl.getAttribute("data-theme")==="dark"; }
    // trail fade
    const fade = opts.fade!=null?opts.fade:0.085;
    ctx.globalCompositeOperation="source-over";
    ctx.fillStyle=`rgba(${_bg},${fade})`;
    ctx.fillRect(0,0,W,H);

    const ar=_acc[0],ag=_acc[1],ab=_acc[2];
    const dark = _dark;
    ctx.globalCompositeOperation = dark?"lighter":"source-over";
    ctx.lineCap="round";

    for(let i=0;i<particles.length;i++){
      const p=particles[i];
      const a=fieldAngle(p.x,p.y);
      let ax=Math.cos(a)*0.10*p.sp, ay=Math.sin(a)*0.10*p.sp;
      // cursor interaction, swirl + pull ("tame the algorithm")
      if(mouse.active){
        const dx=p.x-mouse.x, dy=p.y-mouse.y, d2=dx*dx+dy*dy, R=mouse.down?220:150;
        if(d2 < R*R){
          const d=Math.sqrt(d2)||1, nx=dx/d, ny=dy/d;
          const f=(1-d/R);
          // perpendicular swirl
          ax += -ny*f*1.4; ay += nx*f*1.4;
          // gentle pull inward when holding
          if(mouse.down){ ax -= nx*f*0.9; ay -= ny*f*0.9; }
        }
      }
      p.vx=(p.vx+ax)*0.92; p.vy=(p.vy+ay)*0.92;
      const px=p.x, py=p.y;
      p.x+=p.vx; p.y+=p.vy; p.life--;
      const spd=Math.min(Math.hypot(p.vx,p.vy),3);
      const baseA=(dark?0.5:0.42);
      const alpha=Math.min(0.85, 0.12+spd*baseA);
      if(p.hot){
        ctx.strokeStyle=`rgba(${ar},${ag},${ab},${Math.min(1,alpha*1.5)})`;
        ctx.lineWidth=1.7;
      }else{
        ctx.strokeStyle=`rgba(${ar},${ag},${ab},${alpha})`;
        ctx.lineWidth=1.0;
      }
      ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(p.x,p.y); ctx.stroke();
      if(p.life<0 || p.x<-30||p.x>W+30||p.y<-30||p.y>H+30){ particles[i]=newP(false); }
    }

    // constellation
    ctx.globalCompositeOperation="source-over";
    for(const nd of nodes){ nd.x+=nd.vx; nd.y+=nd.vy; nd.ph+=0.03;
      if(nd.x<0||nd.x>W) nd.vx*=-1; if(nd.y<0||nd.y>H) nd.vy*=-1; }
    for(let i=0;i<nodes.length;i++){
      for(let j=i+1;j<nodes.length;j++){
        const a=nodes[i], b=nodes[j], dx=a.x-b.x, dy=a.y-b.y, d=Math.hypot(dx,dy);
        if(d<200){ ctx.strokeStyle=`rgba(${ar},${ag},${ab},${(1-d/200)*0.16})`; ctx.lineWidth=1;
          ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke(); }
      }
    }
    for(const nd of nodes){
      const pulse=0.5+0.5*Math.sin(nd.ph);
      ctx.fillStyle=`rgba(${ar},${ag},${ab},${0.35+pulse*0.4})`;
      ctx.beginPath(); ctx.arc(nd.x,nd.y,1.6+pulse*1.4,0,6.283); ctx.fill();
    }

    if(hcoord && (t*100|0)%4===0) hcoord.textContent="field "+(noise(t*0.1,t*0.07)).toFixed(2);
    t+=0.016;
    raf=requestAnimationFrame(frame);
  }

  function staticFrame(){
    // reduced-motion: one calm frame
    ctx.fillStyle=`rgba(${bgRgb()},1)`; ctx.fillRect(0,0,W,H);
    const [ar,ag,ab]=accentRgb();
    for(const p of particles){
      let x=p.x,y=p.y; ctx.strokeStyle=`rgba(${ar},${ag},${ab},0.28)`; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(x,y);
      for(let k=0;k<14;k++){ const a=fieldAngle(x,y); x+=Math.cos(a)*6; y+=Math.sin(a)*6; ctx.lineTo(x,y);} ctx.stroke();
    }
  }

  function start(){ if(running) return; running=true; raf=requestAnimationFrame(frame); }
  function stop(){ running=false; cancelAnimationFrame(raf); }

  size();
  let rs; window.addEventListener("resize", ()=>{ clearTimeout(rs); rs=setTimeout(size,180); });
  if(opts.interactive){
    window.addEventListener("mousemove", e=>{ const r=canvas.getBoundingClientRect(); mouse.x=e.clientX-r.left; mouse.y=e.clientY-r.top; mouse.active=true; }, {passive:true});
    canvas.parentElement.addEventListener("mouseleave", ()=>{ mouse.active=false; });
    window.addEventListener("mousedown", ()=>mouse.down=true);
    window.addEventListener("mouseup", ()=>mouse.down=false);
    window.addEventListener("touchmove", e=>{ const tch=e.touches[0]; const r=canvas.getBoundingClientRect(); mouse.x=tch.clientX-r.left; mouse.y=tch.clientY-r.top; mouse.active=true; }, {passive:true});
  }
  // pause when offscreen
  const vio=new IntersectionObserver((es)=>{ es.forEach(e=>{ visible=e.isIntersecting; if(visible && !reduce) start(); else stop(); }); },{threshold:0.02});
  vio.observe(canvas);

  if(reduce){ staticFrame(); } else { start(); }
  return {start,stop};
}

const heroCanvas=document.getElementById("algo");
if(heroCanvas) FlowField(heroCanvas, {density:0.00012, max:1000, scale:0.0016, fade:0.075, interactive:true, seed:7, nodes:16});
const ctaCanvas=document.getElementById("ctaAlgo");
if(ctaCanvas) FlowField(ctaCanvas, {density:0.00009, max:360, scale:0.0022, fade:0.11, interactive:false, seed:21, nodes:0});

/* ================= BOOT SEQUENCE ================= */
(function(){
  const boot=document.getElementById("boot"), lines=document.getElementById("bootLines"), bar=document.getElementById("bootBar");
  let finished=false;
  function finish(){
    if(finished) return; finished=true;
    if(boot) boot.classList.add("done");      // hide first, never get stuck
    decodeArmed=true;
    try{ applyLang(savedLang); }catch(e){ console.warn(e); }
  }
  // absolute safety net: clear boot no matter what
  setTimeout(finish, 3200);
  // skip-boot flag (for previews / repeat visits)
  if(location.search.indexOf("nb")>-1){ if(boot) boot.style.display="none"; finish(); return; }
  let booted=false;
  try{ booted=sessionStorage.getItem("dlogic-booted")==="1"; }catch(e){}
  if(reduce || booted || !boot){
    if(boot) boot.classList.add("done");
    finish();
    return;
  }
  try{ sessionStorage.setItem("dlogic-booted","1"); }catch(e){}
  const seq=[
    {t:'<span class="muted">$</span> init d-logic.studio --honest', d:120},
    {t:'load algorithm.flow_field ......... <span class="ok">ok</span>', d:230},
    {t:'mount clawbot --observe-only ...... <span class="ok">live</span>', d:230},
    {t:'verify signal / noise ............. <span class="am">clean</span>', d:230},
    {t:'render <span class="am">◢ instrument</span> ............... <span class="ok">ready</span>', d:260}
  ];
  let i=0, html="";
  function next(){
    if(i>=seq.length){ if(bar) bar.style.transition="width .3s"; if(bar) bar.style.width="100%"; setTimeout(finish, 360); return; }
    html += seq[i].t + "<br>"; if(lines) lines.innerHTML=html;
    if(bar) bar.style.width=((i+1)/seq.length*100)+"%";
    i++; setTimeout(next, seq[i-1].d);
  }
  next();
})();

/* year */
const yr=document.getElementById("yr"); if(yr) yr.textContent=new Date().getFullYear();
})();

