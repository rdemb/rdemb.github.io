---
import PageLayout from '../../../layouts/PageLayout.astro';
import { postsByLang, blogSw, blogText, kindLabel, type Lang } from '../../../lib/content';
export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'de' } }];
}
const lang = Astro.params.lang as Lang;
const posts = await postsByLang(lang);
const t = blogText[lang];
const base = '/' + lang;
const kinds = [...new Set(posts.map((p) => p.data.kind))];
const allLabel = lang === 'de' ? 'alle' : 'all';
---
<PageLayout lang={lang} title={`${t.title} · D-LOGIC studio`} description={t.lead} sw={blogSw}>
  <div class="crumbs"><a href="/">D-LOGIC</a> <span>/</span> {t.title}</div>
  <header class="article-head">
    <span class="meta mono">// {t.title.toLowerCase()}</span>
    <h1>{t.title}</h1>
    <p class="excerpt">{t.lead}</p>
  </header>
  <div class="start-bar mono">
    <a href={`${base}/blog/zacznij-tutaj/`} class="start-link">★ {lang === 'de' ? 'Neu hier? Starte mit der Karte des Blogs' : 'New here? Start with the blog map'} →</a>
    <span class="follow">{lang === 'de' ? 'folgen' : 'follow'}: <a href="/rss.xml">RSS</a> · <a href="https://x.com/takitamrafal" target="_blank" rel="noopener">X</a></span>
  </div>
  <div class="kind-filter mono" id="kindFilter">
    <button class="on" data-kind="all">{allLabel}</button>
    {kinds.map((k) => <button data-kind={k}>{kindLabel[lang][k] ?? k}</button>)}
  </div>
  <div class="post-index" id="postIndex">
    {posts.map((p) => (
      <a href={`${base}/blog/${p.data.key}/`} data-kind={p.data.kind}>
        <span class="d">{p.data.date.replaceAll('-', '.')}</span>
        <span class="h">{p.data.title}</span>
        <span class="t">{kindLabel[lang][p.data.kind] ?? p.data.kind}</span>
        <span class="x">{p.data.excerpt}</span>
      </a>
    ))}
  </div>
  <script is:inline>
    (function(){
      var bar=document.getElementById('kindFilter'); if(!bar) return;
      bar.addEventListener('click',function(e){
        var b=e.target.closest('button'); if(!b) return;
        bar.querySelectorAll('button').forEach(function(x){x.classList.toggle('on',x===b);});
        var k=b.dataset.kind;
        document.querySelectorAll('#postIndex a').forEach(function(a){
          a.style.display=(k==='all'||a.dataset.kind===k)?'':'none';
        });
      });
    })();
  </script>
</PageLayout>
