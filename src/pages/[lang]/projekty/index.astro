---
import PageLayout from '../../../layouts/PageLayout.astro';
import { projectsByLang, type Lang } from '../../../lib/content';
export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'de' } }];
}
const lang = Astro.params.lang as Lang;
const order = ['clawbot', 'forex-lab', 'aai', 'mocps'];
const all = await projectsByLang(lang);
const projects = order.map((k) => all.find((p) => p.data.key === k)).filter(Boolean);
const base = '/' + lang;
const t = {
  en: { title: 'Projects', lead: 'Things I have built and studied. With a note on what worked and what did not. Because a failed result is a result too.' },
  de: { title: 'Projekte', lead: 'Dinge, die ich gebaut und untersucht habe. Mit einer Notiz, was funktioniert hat und was nicht. Denn ein gescheitertes Ergebnis ist auch ein Ergebnis.' },
}[lang];
const flag = {
  en: { g: 'Eight neurodiverse minds learn to play chess. They play 24/7, evolve, remember rivals and dream. Live ranking and a game against a chosen player.', o: 'A living market organism driven by real crypto order flow. Four algorithms, true order-flow and a prediction layer.' },
  de: { g: 'Acht neurodiverse Geister lernen Schach. Sie spielen 24/7, entwickeln sich, erinnern Rivalen und träumen. Live-Ranking und eine Partie gegen einen gewählten Spieler.', o: 'Ein lebender Marktorganismus, angetrieben von echtem Krypto-Order-Flow. Vier Algorithmen, echter Order-Flow und eine Vorhersage-Ebene.' },
}[lang];
---
<PageLayout lang={lang} title={`${t.title} · D-LOGIC studio`} description={t.lead} sw={{ pl: '/projekty/', en: '/en/projekty/', de: '/de/projekty/' }}>
  <div class="crumbs"><a href="/">D-LOGIC</a> <span>/</span> {t.title}</div>
  <header class="article-head"><span class="meta mono">// {t.title.toLowerCase()}</span><h1>{t.title}</h1><p class="excerpt">{t.lead}</p></header>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:6px">
    <a class="card" href="/gambit/">
      <span class="num">gambit · <span style="color:#39d98a">● live</span></span>
      <h3 style="margin-top:14px">GAMBIT</h3>
      <p>{flag.g}</p>
    </a>
    <a class="card" href="/zywy-algorytm/">
      <span class="num">order flow · <span style="color:#39d98a">● live</span></span>
      <h3 style="margin-top:14px">Order Flow</h3>
      <p>{flag.o}</p>
    </a>
    {projects.map((p) => (
      <a class="card" href={`${base}/projekty/${p.data.key}/`}>
        <span class="num">{p.data.key}</span>
        <h3 style="margin-top:14px">{p.data.title}</h3>
        <p>{p.data.excerpt}</p>
      </a>
    ))}
  </div>
</PageLayout>
<style>@media (max-width:620px){ div[style*="repeat(2"]{grid-template-columns:1fr!important} }</style>
