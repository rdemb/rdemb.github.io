    {
      '@type': 'ProfessionalService',
      '@id': `${site}/#dlogic`,
      name: 'D-LOGIC',
      url: site,
      description: 'Uczciwe prześwietlenie i naprawa obecności firmy w sieci, w tym widoczność w wyszukiwarkach AI (ChatGPT, Perplexity, Google AI).',
      founder: { '@type': 'Person', name: 'Rafał Dembski', jobTitle: 'Założyciel', address: { '@type': 'PostalAddress', addressRegion: 'NRW', addressCountry: 'DE' } },
      areaServed: ['PL', 'DE', 'AT', 'CH'],
      knowsAbout: ['Generative Engine Optimization', 'Answer Engine Optimization', 'audyt widoczności w AI', 'SEO', 'agenci AI'],
    },
    {
      '@type': 'Service',
      name: 'Prześwietlenie firmy w sieci',
      serviceType: 'Audyt widoczności i obecności firmy w internecie i wyszukiwarkach AI',
      provider: { '@id': `${site}/#dlogic` },
      areaServed: ['PL', 'DE'],
      offers: { '@type': 'Offer', price: '390', priceCurrency: 'EUR' },
      url: `${site}/preswietlenie/`,
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'Czym jest prześwietlenie firmy w sieci?', acceptedAnswer: { '@type': 'Answer', text: 'To uczciwa, oparta na dowodach analiza obecności firmy w internecie: widoczność w Google i wyszukiwarkach AI, jakość strony pod sprzedaż, pozycja na tle konkurentów, z konkretną listą trzech rzeczy do naprawy najpierw.' } },
