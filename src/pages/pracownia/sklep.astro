---
// Standalone example site (boutique e-commerce) for the D-LOGIC examples gallery.
// Own design language, intentionally different from the D-LOGIC brand, to show range.
const products = [
  { n: 'Płaszcz wełniany Oslo', p: '890', s: 'maison-coat' },
  { n: 'Sweter z merynosa', p: '420', s: 'maison-knit' },
  { n: 'Koszula lniana', p: '290', s: 'maison-shirt' },
  { n: 'Spodnie szerokie', p: '360', s: 'maison-trousers' },
  { n: 'Skórzana torba', p: '740', s: 'maison-bag' },
  { n: 'Szalik kaszmirowy', p: '280', s: 'maison-scarf' },
];
const cats = [
  { n: 'Odzież', s: 'maison-c1' },
  { n: 'Akcesoria', s: 'maison-c2' },
  { n: 'Dom', s: 'maison-c3' },
];
const img = (seed: string, w: number, h: number) => `https://picsum.photos/seed/${seed}/${w}/${h}?grayscale`;
---
<!doctype html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MAISON · rzeczy zrobione dobrze</title>
  <meta name="description" content="Butik MAISON. Ubrania i przedmioty szyte w Europie, z dbałością o szczegół." />
  <meta name="robots" content="noindex" />
</head>
<body>
  <a class="ribbon" href="/pracownia/">
    <span>Przykład realizacji · <b>D&#8209;LOGIC studio</b></span>
    <span class="ribbon-back">← galeria przykładów</span>
  </a>

  <header class="hd" id="hd">
    <div class="hd-in">
      <a class="logo" href="#">MAISON</a>
      <nav class="hd-nav">
        <a href="#kolekcja">Nowości</a>
        <a href="#kat">Kolekcje</a>
        <a href="#hist">O nas</a>
        <a href="#stopka">Kontakt</a>
      </nav>
      <button class="cart-btn" id="cartOpen" aria-label="Koszyk">
        Koszyk <span class="cart-n" id="cartN">2</span>
      </button>
    </div>
  </header>

  <section class="hero">
    <img src={img('maison-hero', 1700, 1000)} alt="" loading="eager" />
    <div class="hero-tx">
      <p class="kicker">Kolekcja jesień / zima</p>
      <h1>Rzeczy zrobione<br />dobrze.</h1>
      <p class="sub">Ubrania i przedmioty szyte w Europie, z naturalnych materiałów. Mniej, ale lepiej.</p>
      <a class="btn" href="#kolekcja">Zobacz kolekcję</a>
    </div>
  </section>

  <div class="strip">
    <span>Darmowa dostawa od 300 zł</span><i>·</i><span>Zwroty w 30 dni</span><i>·</i><span>Szyte w Europie</span><i>·</i><span>Pakowane bez plastiku</span>
  </div>

  <section class="kat" id="kat">
    {cats.map((c) => (
      <a class="kat-card" href="#kolekcja">
        <img src={img(c.s, 700, 880)} alt="" loading="lazy" />
        <span class="kat-name">{c.n}</span>
      </a>
    ))}
  </section>

  <section class="coll" id="kolekcja">
    <div class="coll-head">
      <h2>Nowości</h2>
      <a href="#kolekcja" class="seeall">Zobacz wszystko →</a>
    </div>
    <div class="grid">
      {products.map((pr) => (
        <article class="prod">
          <div class="prod-img"><img src={img(pr.s, 640, 800)} alt={pr.n} loading="lazy" /><button class="add" data-add aria-label={`Dodaj ${pr.n}`}>Dodaj do koszyka</button></div>
          <div class="prod-row"><span class="prod-n">{pr.n}</span><span class="prod-p">{pr.p} zł</span></div>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial" id="hist">
    <div class="ed-img"><img src={img('maison-ed', 1100, 1300)} alt="" loading="lazy" /></div>
    <div class="ed-tx">
      <p class="kicker">Nasza historia</p>
      <h2>Robimy mniej, żeby robić lepiej.</h2>
      <p>Każdą rzecz projektujemy tak, by służyła latami. Współpracujemy z małymi szwalniami w Polsce i Portugalii, wybieramy wełnę, len i kaszmir z certyfikowanych źródeł.</p>
      <p>To nie jest moda na jeden sezon. To garderoba na lata.</p>
      <a class="btn ghost" href="#stopka">Poznaj markę</a>
    </div>
  </section>

  <section class="news">
    <h2>Dołącz do MAISON</h2>
    <p>Zapisz się i odbierz 10% na pierwsze zakupy. Bez spamu, tylko nowe kolekcje.</p>
    <form class="news-form" onsubmit="return false">
      <input type="email" placeholder="Twój e-mail" aria-label="E-mail" />
      <button class="btn" type="submit">Zapisz się</button>
    </form>
  </section>

  <footer class="ft" id="stopka">
    <div class="ft-in">
      <div class="ft-brand">
        <div class="logo">MAISON</div>
        <p>ul. Próżna 12, Warszawa<br />kontakt@maison.example · +48 500 000 000</p>
      </div>
      <div class="ft-col"><h4>Sklep</h4><a href="#kolekcja">Nowości</a><a href="#kat">Kolekcje</a><a href="#kolekcja">Wyprzedaż</a></div>
      <div class="ft-col"><h4>Pomoc</h4><a href="#stopka">Dostawa</a><a href="#stopka">Zwroty</a><a href="#stopka">Rozmiary</a></div>
      <div class="ft-col"><h4>Marka</h4><a href="#hist">O nas</a><a href="#stopka">Zrównoważony rozwój</a><a href="#stopka">Kontakt</a></div>
    </div>
    <div class="ft-bot"><span>© 2026 MAISON. Przykład wykonany przez D-LOGIC studio.</span><span>Visa · Mastercard · BLIK · Przelewy24</span></div>
  </footer>

  <div class="drawer-bg" id="drawerBg"></div>
  <aside class="drawer" id="drawer" aria-label="Koszyk">
    <div class="dr-head"><span>Twój koszyk</span><button id="cartClose" aria-label="Zamknij">✕</button></div>
    <div class="dr-items">
      <div class="dr-item"><img src={img('maison-knit', 120, 150)} alt="" /><div><div class="dr-n">Sweter z merynosa</div><div class="dr-meta">Rozmiar M · 1 szt.</div></div><span class="dr-p">420 zł</span></div>
      <div class="dr-item"><img src={img('maison-scarf', 120, 150)} alt="" /><div><div class="dr-n">Szalik kaszmirowy</div><div class="dr-meta">1 szt.</div></div><span class="dr-p">280 zł</span></div>
    </div>
    <div class="dr-foot">
      <div class="dr-sum"><span>Razem</span><b>700 zł</b></div>
      <button class="btn full">Przejdź do kasy</button>
      <p class="dr-note">Darmowa dostawa od 300 zł. Masz ją.</p>
    </div>
  </aside>

  <style is:global>
    :root {
      --bg:#F6F1E9; --surf:#FFFFFF; --soft:#EFE7DA; --tx:#221E1A; --mut:#6F665B; --acc:#B25B36; --line:#E4DAC9;
      --serif:'Cormorant Garamond', Georgia, 'Times New Roman', serif;
      --sans:'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { background:var(--bg); color:var(--tx); font-family:var(--sans); -webkit-font-smoothing:antialiased; }
    img { display:block; max-width:100%; }
    a { color:inherit; text-decoration:none; }
    h1,h2,h3,h4 { font-family:var(--serif); font-weight:600; letter-spacing:-.01em; }
    .btn { display:inline-block; background:var(--tx); color:var(--bg); padding:14px 26px; border:0; border-radius:2px; font-size:14px; letter-spacing:.04em; text-transform:uppercase; cursor:pointer; transition:background .2s; font-family:var(--sans); }
    .btn:hover { background:var(--acc); }
    .btn.ghost { background:transparent; color:var(--tx); border:1px solid var(--tx); }
    .btn.ghost:hover { background:var(--tx); color:var(--bg); }
    .btn.full { width:100%; }
    .kicker { font-size:12px; letter-spacing:.22em; text-transform:uppercase; color:var(--acc); margin-bottom:14px; }

    .ribbon { position:sticky; top:0; z-index:60; display:flex; align-items:center; justify-content:center; gap:18px; background:#1b1714; color:#e9e0d3; font-size:12.5px; letter-spacing:.03em; padding:8px 16px; }
    .ribbon b { color:#fff; } .ribbon-back { color:#c9a98f; }

    .hd { position:sticky; top:33px; z-index:50; background:color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter:blur(10px); border-bottom:1px solid var(--line); }
    .hd-in { max-width:1180px; margin:0 auto; padding:18px 26px; display:flex; align-items:center; justify-content:space-between; }
    .logo { font-family:var(--serif); font-size:25px; font-weight:600; letter-spacing:.18em; }
    .hd-nav { display:flex; gap:30px; font-size:13.5px; letter-spacing:.05em; text-transform:uppercase; }
    .hd-nav a:hover { color:var(--acc); }
    .cart-btn { background:none; border:0; font-family:var(--sans); font-size:13.5px; letter-spacing:.05em; text-transform:uppercase; cursor:pointer; color:var(--tx); display:flex; align-items:center; gap:8px; }
    .cart-n { background:var(--acc); color:#fff; border-radius:999px; min-width:20px; height:20px; display:inline-flex; align-items:center; justify-content:center; font-size:11px; }

    .hero { position:relative; height:82vh; min-height:560px; overflow:hidden; }
    .hero img { width:100%; height:100%; object-fit:cover; filter:brightness(.82) sepia(.12); }
    .hero-tx { position:absolute; inset:0; display:flex; flex-direction:column; justify-content:center; max-width:1180px; margin:0 auto; padding:0 26px; left:0; right:0; color:#fff; }
    .hero-tx .kicker { color:#f0c9b4; }
    .hero h1 { font-size:clamp(46px,8vw,104px); line-height:.98; }
    .hero .sub { max-width:42ch; margin:22px 0 30px; font-size:clamp(15px,2vw,18px); color:#f2ece2; }
    .hero .btn { background:#fff; color:#1b1714; align-self:flex-start; }
    .hero .btn:hover { background:var(--acc); color:#fff; }

    .strip { display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:14px; background:var(--tx); color:var(--bg); font-size:12.5px; letter-spacing:.08em; text-transform:uppercase; padding:14px; }
    .strip i { color:var(--acc); font-style:normal; }

    .kat { max-width:1180px; margin:78px auto; padding:0 26px; display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
    .kat-card { position:relative; overflow:hidden; border-radius:3px; aspect-ratio:4/5; }
    .kat-card img { width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
    .kat-card:hover img { transform:scale(1.05); }
    .kat-name { position:absolute; left:0; right:0; bottom:0; padding:22px; font-family:var(--serif); font-size:27px; color:#fff; background:linear-gradient(transparent, rgba(20,16,12,.66)); }

    .coll { max-width:1180px; margin:0 auto 90px; padding:0 26px; }
    .coll-head { display:flex; align-items:baseline; justify-content:space-between; border-bottom:1px solid var(--line); padding-bottom:18px; margin-bottom:34px; }
    .coll-head h2 { font-size:clamp(30px,4vw,44px); }
    .seeall { font-size:13px; letter-spacing:.05em; text-transform:uppercase; color:var(--mut); }
    .seeall:hover { color:var(--acc); }
    .grid { display:grid; grid-template-columns:repeat(3,1fr); gap:26px 22px; }
    .prod-img { position:relative; overflow:hidden; aspect-ratio:4/5; background:var(--soft); border-radius:3px; }
    .prod-img img { width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
    .prod:hover .prod-img img { transform:scale(1.04); }
    .add { position:absolute; left:14px; right:14px; bottom:14px; transform:translateY(120%); opacity:0; transition:all .28s ease; background:#fff; color:var(--tx); border:0; padding:13px; border-radius:2px; font-size:12.5px; letter-spacing:.06em; text-transform:uppercase; cursor:pointer; }
    .prod:hover .add { transform:none; opacity:1; }
    .add:hover { background:var(--acc); color:#fff; }
    .prod-row { display:flex; justify-content:space-between; align-items:baseline; margin-top:15px; }
    .prod-n { font-family:var(--serif); font-size:19px; }
    .prod-p { color:var(--mut); font-size:15px; }

    .editorial { display:grid; grid-template-columns:1fr 1fr; gap:0; background:var(--soft); }
    .ed-img img { width:100%; height:100%; object-fit:cover; min-height:420px; }
    .ed-tx { padding:clamp(40px,6vw,90px); display:flex; flex-direction:column; justify-content:center; }
    .ed-tx h2 { font-size:clamp(30px,4vw,48px); line-height:1.05; margin:6px 0 20px; max-width:16ch; }
    .ed-tx p { color:var(--mut); line-height:1.75; margin-bottom:14px; max-width:46ch; }
    .ed-tx .btn { align-self:flex-start; margin-top:14px; }

    .news { text-align:center; padding:clamp(64px,9vw,120px) 26px; }
    .news h2 { font-size:clamp(30px,4vw,46px); }
    .news p { color:var(--mut); margin:14px auto 28px; max-width:44ch; }
    .news-form { display:flex; gap:10px; max-width:440px; margin:0 auto; }
    .news-form input { flex:1; padding:14px 16px; border:1px solid var(--line); background:var(--surf); border-radius:2px; font-size:15px; font-family:var(--sans); }
    .news-form input:focus { outline:none; border-color:var(--acc); }

    .ft { background:var(--tx); color:#d9cfc0; padding:70px 26px 26px; }
    .ft-in { max-width:1180px; margin:0 auto; display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:30px; }
    .ft .logo { color:#fff; margin-bottom:14px; }
    .ft-brand p { font-size:14px; line-height:1.8; color:#a99f90; }
    .ft-col h4 { font-family:var(--sans); font-size:12px; letter-spacing:.1em; text-transform:uppercase; color:#fff; margin-bottom:14px; }
    .ft-col a { display:block; font-size:14px; color:#a99f90; margin-bottom:9px; }
    .ft-col a:hover { color:var(--acc); }
    .ft-bot { max-width:1180px; margin:46px auto 0; padding-top:22px; border-top:1px solid rgba(255,255,255,.1); display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; font-size:12.5px; color:#8a8174; }

    .drawer-bg { position:fixed; inset:0; background:rgba(20,16,12,.45); opacity:0; pointer-events:none; transition:opacity .3s; z-index:70; }
    .drawer-bg.on { opacity:1; pointer-events:auto; }
    .drawer { position:fixed; top:0; right:0; height:100%; width:min(400px,92vw); background:var(--bg); z-index:80; transform:translateX(100%); transition:transform .34s cubic-bezier(.4,0,.2,1); display:flex; flex-direction:column; box-shadow:-20px 0 50px -20px rgba(0,0,0,.4); }
    .drawer.on { transform:none; }
    .dr-head { display:flex; align-items:center; justify-content:space-between; padding:22px 24px; border-bottom:1px solid var(--line); font-family:var(--serif); font-size:21px; }
    .dr-head button { background:none; border:0; font-size:18px; cursor:pointer; color:var(--mut); }
    .dr-items { flex:1; overflow:auto; padding:18px 24px; }
    .dr-item { display:grid; grid-template-columns:48px 1fr auto; gap:14px; align-items:center; padding:14px 0; border-bottom:1px solid var(--line); }
    .dr-item img { width:48px; height:60px; object-fit:cover; border-radius:2px; }
    .dr-n { font-family:var(--serif); font-size:16px; }
    .dr-meta { font-size:12.5px; color:var(--mut); margin-top:3px; }
    .dr-p { font-size:14px; }
    .dr-foot { padding:22px 24px; border-top:1px solid var(--line); }
    .dr-sum { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px; font-size:15px; }
    .dr-sum b { font-family:var(--serif); font-size:22px; }
    .dr-note { text-align:center; font-size:12.5px; color:var(--mut); margin-top:12px; }

    @media (max-width:860px) {
      .hd-nav { display:none; }
      .kat, .grid { grid-template-columns:1fr 1fr; }
      .editorial { grid-template-columns:1fr; }
      .ft-in { grid-template-columns:1fr 1fr; }
    }
    @media (max-width:520px) { .kat, .grid { grid-template-columns:1fr; } }
  </style>

  <script is:inline>
    (function(){
      const bg=document.getElementById('drawerBg'), dr=document.getElementById('drawer');
      const open=()=>{bg.classList.add('on');dr.classList.add('on');document.body.style.overflow='hidden';};
      const close=()=>{bg.classList.remove('on');dr.classList.remove('on');document.body.style.overflow='';};
      document.getElementById('cartOpen').addEventListener('click',open);
      document.getElementById('cartClose').addEventListener('click',close);
      bg.addEventListener('click',close);
      const n=document.getElementById('cartN');
      document.querySelectorAll('[data-add]').forEach(b=>b.addEventListener('click',()=>{n.textContent=String(+n.textContent+1);open();}));
      addEventListener('keydown',e=>{if(e.key==='Escape')close();});
    })();
  </script>
</body>
</html>
