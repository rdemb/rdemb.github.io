---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import SiteNav from '../components/SiteNav.astro';
---
<!doctype html>
<html lang="pl" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>ATLAS · Silnik Świata · fizyczna warstwa rynków · D-LOGIC studio</title>
<meta name="description" content="Interaktywny globus 3D fizycznej warstwy rynków: złoża surowców, chokepointy, banki centralne i ich kaskady. Silnik liczy kruchość podaży (HHI) i symuluje rok świata metodą Monte Carlo. Kontekst, nie wyrocznia." />
<meta name="theme-color" content="#0C0E12" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="canonical" href="https://rdemb.github.io/atlas/" />
<meta property="og:title" content="ATLAS · Silnik Świata · D-LOGIC studio" />
<meta property="og:description" content="Globus 3D fizycznej warstwy rynków: złoża, chokepointy, banki i kaskady. Monte Carlo ryzyka świata." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://rdemb.github.io/atlas/" />
<meta property="og:site_name" content="D-LOGIC studio" />
<meta property="og:image" content="https://rdemb.github.io/og-default.png" />

<!-- three.js (zwendorowane, offline) — import map dla bare specifiera 'three' -->
<script type="importmap">
{ "imports": { "three": "/vendor/three-0.160/build/three.module.js" } }
</script>

<style is:global>
:root[data-theme="dark"]{
  --bg:#080A0E; --surface:#14171C; --surface-2:#191D24; --line:#23272E; --line-2:rgba(231,233,236,0.07);
  --text:#E7E9EC; --muted:#9AA1AB; --accent:#E8B23A; --accent-soft:#F0C766; --live:#4ADE80; --loss:#E8675A;
  --glass:rgba(13,16,21,0.72); --chip-line:rgba(232,178,58,0.30);
}
:root[data-theme="light"]{
  --bg:#0c0f14; --surface:#14171C; --surface-2:#191D24; --line:#23272E; --line-2:rgba(231,233,236,0.07);
  --text:#E7E9EC; --muted:#9AA1AB; --accent:#B6831F; --accent-soft:#C8922A; --live:#1A8F4C; --loss:#C0503F;
  --glass:rgba(13,16,21,0.72); --chip-line:rgba(182,131,31,0.30);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{background:radial-gradient(ellipse 120% 90% at 50% -10%,#0e1722 0%,var(--bg) 60%);color:var(--text);font-family:'Inter Variable',system-ui,sans-serif;overflow:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input{font-family:inherit}
.mono{font-family:'JetBrains Mono Variable',ui-monospace,monospace}
.muted{color:var(--muted)}
::selection{background:var(--accent);color:#0C0E12}
::-webkit-scrollbar{width:9px;height:9px}::-webkit-scrollbar-thumb{background:var(--line);border-radius:6px}::-webkit-scrollbar-thumb:hover{background:#39414c}

/* STAGE / GLOBUS */
#stage{position:fixed;inset:0;z-index:1}
#atlas-canvas{width:100%;height:100%;display:block;cursor:grab}
#atlas-canvas:active{cursor:grabbing}

.eyebrow{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:9px}
.eyebrow::before{content:"";width:20px;height:1px;background:var(--accent);opacity:.7}

.glass{background:var(--glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--line);border-radius:16px;box-shadow:0 30px 80px -30px rgba(0,0,0,.7)}

/* RAIL */
#rail{position:fixed;left:16px;top:80px;bottom:16px;width:336px;z-index:20;padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:18px}
.rail-head h1{font-family:'Space Grotesk Variable',sans-serif;font-weight:700;font-size:34px;letter-spacing:-.03em;line-height:.96;margin:10px 0 0}
.rail-sub{font-size:12.5px;color:var(--muted);margin-top:9px;line-height:1.5}
.hud{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.hud-cell{border:1px solid var(--line);border-radius:11px;background:var(--surface);padding:11px 12px}
.hud-cell b{font-family:'Space Grotesk Variable',sans-serif;font-size:23px;font-weight:600;color:var(--accent);display:block;line-height:1;font-variant-numeric:tabular-nums}
.hud-cell span{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);margin-top:6px;display:block}
.rail-block{display:flex;flex-direction:column;gap:9px}
.rail-label{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--muted)}
.rail-foot{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.06em;color:var(--muted);border-top:1px solid var(--line-2);padding-top:12px;text-transform:uppercase}

#search-input{background:var(--surface);border:1px solid var(--line);border-radius:10px;padding:11px 13px;color:var(--text);font-size:13px;width:100%}
#search-input:focus{outline:none;border-color:var(--accent)}
#search-results{display:flex;flex-direction:column;gap:2px}
.sr-row{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;background:var(--surface);border:1px solid var(--line-2);font-size:12.5px;text-align:left}
.sr-row:hover{border-color:var(--chip-line);color:var(--accent)}
.sr-row em{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;color:var(--muted);font-style:normal;text-transform:uppercase;letter-spacing:.06em}

.tg-row{display:flex;flex-wrap:wrap;gap:6px}
.tg{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.03em;padding:7px 11px;border-radius:8px;border:1px solid var(--line);background:var(--surface);color:var(--muted);transition:.18s}
.tg.on{border-color:var(--chip-line);color:var(--accent);background:color-mix(in srgb,var(--accent) 10%,var(--surface))}
.tg.wide{width:100%;text-align:center}

.legend{display:flex;flex-direction:column;gap:3px}
.lg-chip{display:flex;align-items:center;gap:9px;padding:7px 9px;border-radius:8px;border:1px solid var(--line-2);background:transparent;transition:.18s;opacity:.42}
.lg-chip.on{opacity:1;background:var(--surface)}
.lg-chip i{width:10px;height:10px;border-radius:3px;flex:none}
.lg-chip span{font-size:12.5px;flex:1;text-align:left}
.lg-chip b{font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--muted);font-variant-numeric:tabular-nums}

.rank{display:flex;flex-direction:column;gap:3px}
.rk-row{display:grid;grid-template-columns:1fr 70px auto;gap:9px;align-items:center;padding:6px 8px;border-radius:7px;background:transparent;text-align:left;transition:.15s}
.rk-row:hover{background:var(--surface)}
.rk-name{font-size:12.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rk-bar{height:5px;border-radius:3px;background:var(--surface-2);overflow:hidden}
.rk-bar i{display:block;height:100%;border-radius:3px}
.rk-row b{font-family:'JetBrains Mono Variable',monospace;font-size:11px;color:var(--text);font-variant-numeric:tabular-nums;text-align:right}

.btn-sim{width:100%;font-family:'JetBrains Mono Variable',monospace;font-size:12.5px;font-weight:600;letter-spacing:.02em;padding:13px;border-radius:11px;background:var(--accent);color:#0C0E12;transition:.2s}
.btn-sim:hover{background:var(--accent-soft);transform:translateY(-1px);box-shadow:0 12px 30px -12px var(--accent)}
.btn-sim:disabled{opacity:.6;cursor:wait;transform:none}
#sim-status{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.04em}
.sm-sec{margin-top:12px}
.sm-sec h4{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--text);margin-bottom:8px;font-weight:600}
.sm-row{display:grid;grid-template-columns:1fr 60px auto;gap:8px;align-items:center;padding:3px 0;font-size:12px}
.sm-bar{height:5px;border-radius:3px;background:var(--surface-2);overflow:hidden}.sm-bar i{display:block;height:100%}
.sm-row b{font-family:'JetBrains Mono Variable',monospace;font-size:11px;text-align:right;font-variant-numeric:tabular-nums}
.sm-pf{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.sm-pf div{border:1px solid var(--line-2);border-radius:9px;padding:8px 10px;background:var(--surface)}
.sm-pf label{font-family:'JetBrains Mono Variable',monospace;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);display:block}
.sm-pf b{font-family:'Space Grotesk Variable',sans-serif;font-size:18px;font-variant-numeric:tabular-nums}
.up{color:var(--live)} .dn{color:var(--loss)}

/* DETAIL PANEL */
#detail{position:fixed;right:16px;top:80px;bottom:16px;width:372px;z-index:25;padding:22px;overflow-y:auto;transform:translateX(120%);opacity:0;transition:transform .4s cubic-bezier(.2,.7,.3,1),opacity .3s}
#detail.open{transform:none;opacity:1}
.d-close{position:absolute;top:14px;right:14px;width:32px;height:32px;border-radius:8px;border:1px solid var(--line);background:var(--surface);color:var(--muted)}
.d-close:hover{color:var(--accent);border-color:var(--chip-line)}
.d-eyebrow{font-family:'JetBrains Mono Variable',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase}
#detail h3{font-family:'Space Grotesk Variable',sans-serif;font-size:23px;font-weight:600;letter-spacing:-.02em;margin:8px 0 0;line-height:1.05;padding-right:30px}
.d-note{font-size:13px;color:var(--muted);margin-top:9px;line-height:1.5}
.d-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px}
.d-grid div{border:1px solid var(--line-2);border-radius:9px;padding:9px 10px;background:var(--surface)}
.d-grid label{font-family:'JetBrains Mono Variable',monospace;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);display:block}
.d-grid b{font-size:13px;font-weight:600;margin-top:3px;display:block}
.d-frag{margin-top:13px;border:1px solid var(--line-2);border-radius:9px;padding:11px;background:var(--surface)}
.d-frag label{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px}
.d-frag .rk-bar{height:7px;margin-bottom:6px}
.d-frag span{font-size:11px}
.d-sec{margin-top:16px}
.d-sec h4{font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--text);font-weight:600;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--line-2)}
.cs-row{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:4px 0;font-size:12.5px}
.cs-row span{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cs-row em{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;color:var(--muted);font-style:normal;margin-left:7px}
.cs-row b{font-family:'JetBrains Mono Variable',monospace;font-size:12px;font-variant-numeric:tabular-nums;flex:none}
.d-obs{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;line-height:1.5;color:var(--muted);margin-top:16px;border:1px solid var(--line-2);border-radius:8px;padding:9px 10px;background:color-mix(in srgb,var(--accent) 5%,transparent)}

/* TOOLTIP */
#tooltip{position:fixed;z-index:60;pointer-events:none;max-width:260px;background:var(--glass);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid var(--chip-line);border-radius:11px;padding:11px 13px;opacity:0;transition:opacity .14s;box-shadow:0 18px 40px -16px rgba(0,0,0,.7)}
#tooltip.show{opacity:1}
#tooltip b{font-family:'Space Grotesk Variable',sans-serif;font-size:14px;font-weight:600;display:block;line-height:1.15}
#tooltip .t-sub{font-family:'JetBrains Mono Variable',monospace;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);display:block;margin-top:3px}
#tooltip p{font-size:11.5px;color:var(--muted);margin-top:7px;line-height:1.4}
#tooltip .t-row{display:flex;justify-content:space-between;gap:12px;font-size:11.5px;margin-top:6px;color:var(--muted)}
#tooltip .t-row b{font-family:'JetBrains Mono Variable',monospace;font-size:11.5px;color:var(--text);display:inline}

/* TITLE OVERLAY (gora-prawo, nad globusem) */
#hint{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);z-index:15;font-family:'JetBrains Mono Variable',monospace;font-size:10.5px;letter-spacing:.06em;color:var(--muted);background:var(--glass);border:1px solid var(--line-2);border-radius:999px;padding:8px 16px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
#hint b{color:var(--accent)}

/* LOADING / FATAL */
#loading{position:fixed;inset:0;z-index:80;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:var(--bg);transition:opacity .5s}
#loading.done{opacity:0;pointer-events:none}
#loading .spin{width:46px;height:46px;border-radius:50%;border:2px solid var(--line);border-top-color:var(--accent);animation:spin 1s linear infinite}
#loading span{font-family:'JetBrains Mono Variable',monospace;font-size:12px;letter-spacing:.08em;color:var(--muted)}
@keyframes spin{to{transform:rotate(360deg)}}
#fatal{position:fixed;inset:0;z-index:90;display:none;align-items:center;justify-content:center;padding:24px;background:var(--bg)}
#fatal div{max-width:420px;text-align:center}
#fatal b{font-family:'Space Grotesk Variable',sans-serif;font-size:22px;display:block;margin-bottom:10px}
#fatal p{font-family:'JetBrains Mono Variable',monospace;font-size:12px;color:var(--loss)}

/* MOBILE GATE — globus to ciezka scena WebGL, desktop-only */
.amg{display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:16px;min-height:100dvh;padding:46px 24px;position:relative;z-index:40}
html[data-atlas-mobile] .amg{display:flex}
html[data-atlas-mobile] #stage,html[data-atlas-mobile] #rail,html[data-atlas-mobile] #detail,html[data-atlas-mobile] #hint,html[data-atlas-mobile] #loading{display:none!important}
.amg-glyph{font-size:40px;color:var(--accent)}
.amg .tag{font-family:'JetBrains Mono Variable',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent)}
.amg h1{font-family:'Space Grotesk Variable',sans-serif;font-weight:700;font-size:clamp(38px,15vw,68px);letter-spacing:-.04em;line-height:.9}
.amg p{color:var(--muted);font-size:15px;line-height:1.6;max-width:34ch}
.amg a{margin-top:8px;font-family:'JetBrains Mono Variable',monospace;font-size:13px;border:1px solid var(--line);border-radius:10px;padding:12px 20px;color:var(--text)}
.amg a:hover{border-color:var(--chip-line);color:var(--accent)}

@media (max-width:1180px){ #rail{width:300px} #detail{width:330px} }
@media (max-width:980px){ #rail,#detail{display:none} }
</style>
</head>
<body>
<SiteNav mode="client" active="/atlas/" overlay={true} />

<!-- MOBILE GATE -->
<section class="amg" aria-label="ATLAS, wersja desktopowa">
  <span class="amg-glyph" aria-hidden="true">◢</span>
  <span class="tag" data-pl="tylko na komputerze" data-en="desktop only" data-de="nur am Computer">tylko na komputerze</span>
  <h1>ATLAS</h1>
  <p data-pl="Atlas to żywy globus 3D z setkami złóż, chokepointów i silnikiem Monte Carlo. Na telefonie nie zadziała tak, jak powinien. Otwórz tę stronę na komputerze."
     data-en="The Atlas is a live 3D globe with hundreds of deposits, chokepoints and a Monte Carlo engine. It won't run the way it should on a phone. Please open it on a desktop."
     data-de="Der Atlas ist ein lebendiger 3D-Globus mit Hunderten Lagerstätten, Chokepoints und einer Monte-Carlo-Engine. Auf dem Handy läuft er nicht richtig. Bitte am Computer öffnen.">Atlas to żywy globus 3D z setkami złóż, chokepointów i silnikiem Monte Carlo. Na telefonie nie zadziała tak, jak powinien. Otwórz tę stronę na komputerze.</p>
  <a href="/" data-pl="← Wróć do studia" data-en="← Back to the studio" data-de="← Zurück zum Studio">← Wróć do studia</a>
</section>

<!-- STAGE -->
<div id="stage"><canvas id="atlas-canvas"></canvas></div>

<!-- RAIL -->
<aside id="rail" class="glass">
  <div class="rail-head">
    <span class="eyebrow">D-LOGIC · Atlas</span>
    <h1>Silnik Świata</h1>
    <p class="rail-sub">Fizyczna warstwa rynków: złoża, chokepointy, banki i ich kaskady. Klik węzeł = scenariusz „co-jeśli". Obróć globus myszą, kółko = zoom.</p>
  </div>
  <div class="hud">
    <div class="hud-cell"><b id="stat-nodes">0</b><span>złóż / węzłów</span></div>
    <div class="hud-cell"><b id="stat-commodities">0</b><span>surowców</span></div>
    <div class="hud-cell"><b id="stat-choke">0</b><span>chokepointów</span></div>
    <div class="hud-cell"><b id="stat-sources">0</b><span>źródeł danych</span></div>
  </div>
  <div class="rail-block">
    <input id="search-input" type="text" placeholder="szukaj: złoże, kraj, firma..." autocomplete="off" />
    <div id="search-results"></div>
  </div>
  <div class="rail-block">
    <div class="rail-label">Warstwy</div>
    <div id="layers" class="tg-row"></div>
    <button id="colormode" class="tg wide">Kolor: kategoria</button>
  </div>
  <div class="rail-block">
    <div class="rail-label">Kategorie złóż <span class="muted">· klik = filtr</span></div>
    <div id="legend" class="legend"></div>
  </div>
  <div class="rail-block">
    <div class="rail-label">Co najmocniej trzęsie układem <span class="muted">· centralność</span></div>
    <div id="rank-sys" class="rank"></div>
  </div>
  <div class="rail-block">
    <div class="rail-label">Najbardziej kruche surowce <span class="muted">· HHI</span></div>
    <div id="rank-frag" class="rank"></div>
  </div>
  <div class="rail-block sim">
    <button id="sim-run" class="btn-sim">▶ Symuluj rok świata · Monte Carlo</button>
    <div id="sim-status" class="muted"></div>
    <div id="sim-out"></div>
  </div>
  <div class="rail-foot">OBSERVE_ONLY · dane skalibrowane zgrubnie + datowane · kontekst, nie wyrocznia</div>
</aside>

<!-- DETAIL -->
<aside id="detail" class="glass">
  <button id="detail-close" class="d-close" aria-label="Zamknij">✕</button>
  <div id="detail-body"></div>
</aside>

<div id="tooltip"></div>
<div id="hint">obróć <b>myszą</b> · kółko = <b>zoom</b> · klik węzeł = <b>kaskada</b> · podwójny klik = reset</div>

<div id="loading"><div class="spin"></div><span>ładowanie atlasu świata…</span></div>
<div id="fatal"><div><b>Nie udało się uruchomić globusa</b><p></p></div></div>

<!-- ATLAS odpala sie TYLKO na desktopie (ciezka scena WebGL). Na mobile -> bramka, bez ladowania modulow. -->
<script is:inline>
  (function(){
    var mobile = window.matchMedia('(max-width: 980px)').matches;
    if(mobile){
      document.documentElement.setAttribute('data-atlas-mobile','');
      var l='pl'; try{ l=localStorage.getItem('dlogic-lang')||'pl'; }catch(e){}
      document.querySelectorAll('.amg [data-pl]').forEach(function(el){ var v=el.getAttribute('data-'+l); if(v!=null) el.textContent=v; });
      return;
    }
    var s=document.createElement('script'); s.type='module'; s.src='/atlas/app.js';
    s.onerror=function(){ var f=document.getElementById('fatal'); if(f){ f.style.display='flex'; f.querySelector('p').textContent='Nie udało się wczytać /atlas/app.js'; } var ld=document.getElementById('loading'); if(ld) ld.classList.add('done'); };
    document.body.appendChild(s);
  })();
</script>
</body>
</html>
