---
import PageLayout from '../../layouts/PageLayout.astro';
import RepoBrowser from '../../components/RepoBrowser.astro';
import { projectsByLang, labSw } from '../../lib/content';
import { render } from 'astro:content';
const lang = 'pl';
export async function getStaticPaths() {
  const projects = await projectsByLang('pl');
  return projects.map((p) => ({ params: { key: p.data.key }, props: { entry: p } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<PageLayout lang={lang} title={`${entry.data.title} · D-LOGIC studio`} description={entry.data.excerpt} sw={labSw(entry.data.key)}>
  <div class="crumbs"><a href="/">D-LOGIC</a> <span>/</span> <a href="/#lab">Lab</a> <span>/</span> {entry.data.key}</div>
  <header class="article-head">
    <span class="meta mono">lab · {entry.data.key}</span>
    <h1>{entry.data.title}</h1>
    {entry.data.excerpt && <p class="excerpt">{entry.data.excerpt}</p>}
  </header>
  {entry.data.key === 'mocps' && (
    <figure class="mocps-hero">
      <img src="/mocps/mocps_hero.gif" alt="Animacja: dwie kulki krzyżują się, jedna znika i zmienia ruch; po powrocie trzeba rozpoznać, która to cel" />
      <figcaption>Dwie identyczne kulki krzyżują się, jedna znika i zmienia ruch. Po powrocie, która to cel? Pamięć bezstanowa: 18%, nauczony stan rekurencyjny: 100%.</figcaption>
    </figure>
  )}
  {entry.data.key === 'mocps' && <RepoBrowser lang="pl" />}
  <article class="prose"><Content /></article>
  <div class="article-foot"><a class="mono" href="/#lab" style="color:var(--accent)">← lab</a></div>
</PageLayout>
