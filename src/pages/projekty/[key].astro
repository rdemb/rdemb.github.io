---
import PageLayout from '../../layouts/PageLayout.astro';
import RepoBrowser from '../../components/RepoBrowser.astro';
import ClawbotScope from '../../components/ClawbotScope.astro';
import { projectsByLang, labSw } from '../../lib/content';
import { render } from 'astro:content';
const lang = 'pl';
export async function getStaticPaths() {
  const projects = await projectsByLang('pl');
  return projects.map((p) => ({ params: { key: p.data.key }, props: { entry: p } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<PageLayout lang={lang} title={`${entry.data.title} · D-LOGIC studio`} description={entry.data.excerpt} sw={labSw(entry.data.key)} ogType="article">
  <div class="crumbs"><a href="/">D-LOGIC</a> <span>/</span> <a href="/#lab">Lab</a> <span>/</span> {entry.data.key}</div>
  <header class="article-head">
    <span class="meta mono">lab · {entry.data.key}</span>
    <h1>{entry.data.title}</h1>
    {entry.data.excerpt && <p class="excerpt">{entry.data.excerpt}</p>}
  </header>
  {entry.data.key === 'clawbot' && <ClawbotScope lang="pl" />}
  {entry.data.key === 'mocps' && (
    <figure class="mocps-hero">
      <iframe src="/mocps/live.html" title="Pod Kloszem — żywy organizm uczący się fizyki" loading="lazy" allow="fullscreen"></iframe>
      <figcaption>Pod Kloszem — żywy organizm. Przybysz z gwiazd uczy się fizyki Ziemi: model JEPA przewiduje łuk lecącej piłki, trzyma jej pozycję, gdy znika za przeszkodą, i wzdryga się tylko wtedy, gdy świat złamie grawitację. Możliwe od niemożliwego rozróżnia w 96%. Przeciągnij, by obejrzeć; klawisz T stawia pułapkę.</figcaption>
    </figure>
  )}
  {entry.data.key === 'mocps' && <RepoBrowser lang="pl" />}
  <article class="prose"><Content /></article>
  <div class="article-foot"><a class="mono" href="/#lab" style="color:var(--accent)">← lab</a></div>
</PageLayout>

<style>
  .mocps-hero{ margin:0 0 2rem }
  .mocps-hero iframe{ width:100%; aspect-ratio:16/10; min-height:460px; border:1px solid var(--line); border-radius:14px; background:#0a0c10; display:block }
  .mocps-hero figcaption{ margin-top:.7rem; color:var(--muted); font-size:13.5px; line-height:1.55 }
  @media (max-width:680px){ .mocps-hero iframe{ aspect-ratio:3/4; min-height:520px } }
</style>
