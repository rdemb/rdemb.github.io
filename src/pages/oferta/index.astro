      <div class="hub">
        <div class="hub-card reveal"><span class="k">01</span><h3 data-i18n="o.p1.t">•</h3><p data-i18n="o.p1.d">•</p></div>
        <div class="hub-card reveal" data-delay="1"><span class="k">02</span><h3 data-i18n="o.p2.t">•</h3><p data-i18n="o.p2.d">•</p></div>
