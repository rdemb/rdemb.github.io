<Chrome title="Oferta, D-LOGIC studio" description="Narzędzia AI, strony internetowe i analiza danych. Po ludzku, z jasnym zakresem i uczciwą wyceną." dict={dict} active="/oferta/">
  <section style="padding-bottom:40px">
    <div class="wrap">
      <div class="sec-head reveal" style="margin-bottom:34px">
        <span class="eyebrow" data-i18n="o.eyebrow">•</span>
        <h2 data-i18n="o.title">•</h2>
        <p data-i18n="o.lead">•</p>
      </div>
      <div class="cards">
        <article class="card reveal"><span class="num" data-i18n="o.c1.k">•</span><h3 data-i18n="o.c1.t">•</h3><p data-i18n="o.c1.d">•</p><p class="mono" style="font-size:13px;color:var(--accent);margin-top:14px" data-i18n="o.c1.f">•</p></article>
        <article class="card reveal" data-delay="1"><span class="num" data-i18n="o.c2.k">•</span><h3 data-i18n="o.c2.t">•</h3><p data-i18n="o.c2.d">•</p><p class="mono" style="font-size:13px;color:var(--accent);margin-top:14px" data-i18n="o.c2.f">•</p></article>
